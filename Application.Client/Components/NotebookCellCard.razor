@using System.Net.Http.Json
@using System.Text
@using System.Text.RegularExpressions
@using Application.Shared.Enums
@using Application.Shared.Models
@using Application.Shared.Models.Data
@using Application.Shared.Models.Notebooks
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject IJSRuntime _jsRuntime

<div class="nc-card">
    <div class="nc-head">
        <div class="nc-head-left">
            @if (ShowDragHandle)
            {
                <span class="nc-grip" title="Drag to reorder" draggable="true"
                      @ondragstart="() => OnDragStart.InvokeAsync()" @ondragend="() => OnDragEnd.InvokeAsync()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                </span>
            }
            <button class="btn-icon" title="@(_collapsed ? "Expand" : "Collapse")" @onclick="() => _collapsed = !_collapsed">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (_collapsed)
                    {
                        <polyline points="9 18 15 12 9 6" />
                    }
                    else
                    {
                        <polyline points="6 9 12 15 18 9" />
                    }
                </svg>
            </button>
            @if (Cell.CellType == "sql")
            {
                <input class="ds-input nc-name" placeholder="cell_name" @bind="_name" @bind:event="oninput" />
                <DatasetTablePicker Compact="true"
                                    ShowTable="false"
                                    CompanyId="@(CompanyId ?? string.Empty)"
                                    Datasets="@Datasets"
                                    DatasetPlaceholder="Dataset…"
                                    DatasetId="@(_datasetId ?? string.Empty)"
                                    DatasetIdChanged="OnDatasetPicked"
                                    CanViewSource="@CanViewSource"
                                    @bind-SnapshotMode="_snapshotMode"
                                    @bind-SnapshotMode:after="LoadTablesAsync" />
            }
            else
            {
                <span class="nc-title">Markdown</span>
            }
        </div>
        <div class="nc-actions">
            @if (Cell.CellType == "sql")
            {
                @if (_running)
                {
                    <button class="btn-icon" title="Cancel" @onclick="CancelRun">
                        <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span>
                    </button>
                }
                else
                {
                    <button class="btn-icon" title="Run (Ctrl+Enter)" @onclick="OnRunClicked" disabled="@_saving">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                    </button>
                }
                <div class="nc-ai-anchor">
                    <button class="btn-icon @(_showAskAi ? "nc-ai-btn-active" : "")" title="Ask AI" @onclick="ToggleAskAi">
                        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
                    </button>
                    @if (_showAskAi)
                    {
                        <div class="nc-ai-backdrop" @onclick="() => _showAskAi = false"></div>
                        <div class="nc-ai-pop" @onclick:stopPropagation="true">
                            <div class="nc-ai-pop-head">
                                <span class="nc-ai-pop-title">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
                                    Ask AI
                                </span>
                                <button type="button" class="nc-ai-close" title="Close" @onclick="() => _showAskAi = false">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                </button>
                            </div>
                            <div class="nc-ai-pop-body">
                                @if (_aiAsking)
                                {
                                    <div class="nc-ai-reply nc-ai-thinking"><span class="ds-spinner" style="width:12px;height:12px;border-width:1.5px"></span> Thinking…</div>
                                }
                                else if (_aiReply != null)
                                {
                                    <div class="nc-ai-reply">@_aiReply</div>
                                }
                                <div class="nc-ai-input-row">
                                    <textarea class="nc-ai-textarea" rows="4" placeholder="Describe the query you want…" @ref="_aiTextareaRef"
                                              @bind="_aiPrompt" @bind:event="oninput" @onkeydown="OnAiKeyDown" disabled="@_aiAsking"></textarea>
                                    <button type="button" class="nc-ai-send" title="Ask" @onclick="AskAi" disabled="@(_aiAsking || string.IsNullOrWhiteSpace(_aiPrompt))">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                                    </button>
                                </div>
                                <p class="nc-ai-hint">Enter to ask · Shift+Enter for a new line</p>
                            </div>
                        </div>
                    }
                </div>
                <button class="btn-icon" title="Save" @onclick="() => SaveCellAsync()" disabled="@(_saving || _running)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                </button>
                <div class="nc-ai-anchor">
                    <button class="btn-icon" title="Run history" @onclick="ToggleHistory">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
                    </button>
                    @if (_showHistory)
                    {
                        <div class="nc-ai-backdrop" @onclick="() => _showHistory = false"></div>
                        <div class="nc-ai-pop" @onclick:stopPropagation="true" style="width:320px">
                            <div class="nc-ai-pop-head">
                                <span class="nc-ai-pop-title">Run history</span>
                                <button type="button" class="nc-ai-close" title="Close" @onclick="() => _showHistory = false">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                </button>
                            </div>
                            <div class="nc-history-body">
                                @if (_historyLoading)
                                {
                                    <div style="display:flex;justify-content:center;padding:1rem 0"><div class="ds-spinner"></div></div>
                                }
                                else if (_history.Count == 0)
                                {
                                    <p class="nc-hint" style="padding:0.75rem 0.9rem">No runs yet.</p>
                                }
                                else
                                {
                                    @foreach (var run in _history)
                                    {
                                        <div class="nc-history-item">
                                            <span class="nc-history-status @(run.Status == "success" ? "nc-history-success" : "nc-history-error")">@(run.Status == "success" ? "✓" : "✗")</span>
                                            <div style="flex:1;min-width:0">
                                                <div class="nc-history-line">
                                                    @(run.Status == "success" ? $"{run.RowsReturned ?? 0} rows · {run.ElapsedMs ?? 0} ms" : (run.Error ?? "Failed"))
                                                </div>
                                                <div class="nc-history-meta">@run.StartedAt.ToLocalTime().ToString("MMM dd, h:mm tt") · @TriggerLabel(run.TriggeredBy)</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
                @if (_result?.IsSelect == true && _result.Rows.Count > 0)
                {
                    <button class="btn-icon" title="Expand" @onclick="() => _expanded = true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
                    </button>
                }
            }
            <div class="nc-ai-anchor">
                <button class="btn-icon @(_showComments ? "nc-ai-btn-active" : "")" title="Comments" style="position:relative" @onclick="ToggleComments">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    @if (_commentCount > 0)
                    {
                        <span class="nc-comment-badge">@_commentCount</span>
                    }
                </button>
                @if (_showComments)
                {
                    <div class="nc-ai-backdrop" @onclick="() => _showComments = false"></div>
                    <div class="nc-ai-pop" @onclick:stopPropagation="true" style="width:auto">
                        <div class="nc-ai-pop-head">
                            <span class="nc-ai-pop-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                Comments
                            </span>
                            <button type="button" class="nc-ai-close" title="Close" @onclick="() => _showComments = false">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            </button>
                        </div>
                        <NotebookCellComments CompanyId="@CompanyId" NotebookId="@NotebookId" CellId="@Cell.Id" OnCountChanged="c => _commentCount = c" />
                    </div>
                }
            </div>
            <button class="btn-icon btn-icon-delete" title="Delete cell" @onclick="() => OnRemove.InvokeAsync(Cell.Id)">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
        </div>
    </div>

    @if (!_collapsed)
    {
        <div class="nc-body">
            @if (Cell.CellType == "sql")
            {
                <MonacoSqlEditor @bind-Value="_sql" Height="160px" Tables="@CompletionItems" Columns="@_columnsByTable" OnRunRequested="OnRunClicked" />

                @if (AvailableReferences.Count > 0)
                {
                    <div class="nc-refs">
                        <span class="nc-refs-label">References:</span>
                        @foreach (var r in AvailableReferences)
                        {
                            <label class="nc-ref-chip">
                                <input type="checkbox" checked="@_referencedCellIds.Contains(r.Id)" @onchange="e => ToggleRef(r.Id, (bool)e.Value!)" />
                                @r.Name
                            </label>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Cell.LastMaterializedObject))
                {
                    <p class="nc-hint">Available to later cells as <code>@Cell.LastMaterializedObject</code>.</p>
                }

                @if (_runError != null)
                {
                    <div class="nc-err">@_runError</div>
                }
                else if (_result != null && _result.IsSelect)
                {
                    <div class="nc-status">
                        <span>@_result.RowsReturned row@(_result.RowsReturned == 1 ? "" : "s")@(_result.Truncated ? " (truncated)" : "") · @_result.ElapsedMs ms</span>
                        <span style="display:flex;align-items:center;gap:0.25rem;flex-shrink:0">
                            @if (_result.Rows.Count > 0)
                            {
                                <button type="button" class="nc-open-table" @onclick="() => ExportCsv(_result.Rows)" title="Export this result to CSV">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3"/><path d="m6 10 6 6 6-6"/><path d="M19 21H5"/></svg>
                                    CSV
                                </button>
                                <button type="button" class="nc-open-table" @onclick="() => ExportExcel(_result.Rows)" title="Export this result to Excel">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3"/><path d="m6 10 6 6 6-6"/><path d="M19 21H5"/></svg>
                                    Excel
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(_result.MaterializedObjectName))
                            {
                                <button type="button" class="nc-open-table" @onclick="OpenTableView" title="Open this result as a table">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                                    Open in Table View
                                </button>
                                @if (!IsExternalDataset || _snapshotMode)
                                {
                                    <button type="button" class="nc-open-table" @onclick="OpenCreateIngestionJob" title="Schedule this query to keep refreshing the table">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        Create Ingestion Job
                                    </button>
                                }
                            }
                        </span>
                    </div>
                    @if (_result.Rows.Count > 0)
                    {
                        <div class="nc-table-wrap">
                            <table class="nc-table">
                                <thead><tr>@foreach (var c in ColumnNames()) { <th>@c</th> }</tr></thead>
                                <tbody>
                                    @foreach (var row in _result.Rows.Take(50))
                                    {
                                        <tr>@foreach (var c in ColumnNames()) { <td>@Display(row, c)</td> }</tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="nc-hint">No rows returned.</p>
                    }
                }
                else if (_result != null)
                {
                    <p class="nc-status nc-ok" style="color:#16a34a">Statement executed — @_result.RowsAffected row(s) affected.</p>
                }
            }
            else
            {
                <div class="nc-md-wrap">
                    <div class="nc-md-toolbar">
                        <button type="button" class="nc-md-tab @(!_markdownPreview ? "nc-md-tab-active" : "")" @onclick="() => _markdownPreview = false">Edit</button>
                        <button type="button" class="nc-md-tab @(_markdownPreview ? "nc-md-tab-active" : "")" @onclick="() => _markdownPreview = true">Preview</button>
                    </div>
                    @if (_markdownPreview)
                    {
                        <div class="nc-md-preview" @onclick="() => _markdownPreview = false">
                            @if (string.IsNullOrWhiteSpace(_markdown))
                            {
                                <span class="nc-hint">Click to write notes…</span>
                            }
                            else
                            {
                                @((MarkupString)RenderMarkdown(_markdown))
                            }
                        </div>
                    }
                    else
                    {
                        <textarea class="ds-input nc-md-input" rows="6" placeholder="Write notes in Markdown…"
                                  @bind="_markdown" @bind:event="oninput" @bind:after="SaveCellAsync"></textarea>
                    }
                </div>
            }
        </div>
    }
</div>

@if (_showParamPrompt)
{
    <div class="nc-modal-backdrop" @onclick="() => _showParamPrompt = false">
        <div class="ds-modal" style="width:min(420px, 90vw)" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Run parameters</h2>
                <button class="ds-modal-close" @onclick="() => _showParamPrompt = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                @foreach (var name in _pendingParamNames)
                {
                    <div class="ds-field">
                        <label class="ds-label">@("{{" + name + "}}")</label>
                        <input class="ds-input" @bind="_paramValues[name]" @bind:event="oninput"
                               @onkeydown="@(async e => { if (e.Key == "Enter") await ConfirmParamPromptAndRun(); })" />
                    </div>
                }
                <div class="ds-modal-footer">
                    <button type="button" class="btn btn-default" style="flex:1" @onclick="ConfirmParamPromptAndRun">Run</button>
                    <button type="button" class="btn btn-outline" style="flex:1" @onclick="() => _showParamPrompt = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_expanded && _result != null)
{
    <div class="nc-modal-backdrop" @onclick="() => _expanded = false">
        <div class="nc-modal" @onclick:stopPropagation="true">
            <div class="nc-modal-head">
                <span class="nc-title">@(_name)</span>
                <span class="nc-modal-count">@_result.Rows.Count row@(_result.Rows.Count == 1 ? "" : "s")@(_result.Truncated ? " (truncated)" : "")</span>
                @if (_result.Rows.Count > 0)
                {
                    <button type="button" class="nc-open-table" @onclick="() => ExportCsv(_result.Rows)" title="Export this result to CSV">CSV</button>
                    <button type="button" class="nc-open-table" @onclick="() => ExportExcel(_result.Rows)" title="Export this result to Excel">Excel</button>
                }
                <button class="btn-icon" title="Close" @onclick="() => _expanded = false">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="nc-modal-body">
                <div class="nc-modal-tabs">
                    <button type="button" class="nc-tab @(_modalTab == "table" ? "nc-tab-active" : "")" @onclick='() => _modalTab = "table"'>Table</button>
                    <button type="button" class="nc-tab @(_modalTab == "chart" ? "nc-tab-active" : "")" @onclick='() => _modalTab = "chart"'>Chart</button>
                </div>
                @if (_modalTab == "table")
                {
                    <table class="nc-table">
                        <thead><tr>@foreach (var c in ColumnNames()) { <th>@c</th> }</tr></thead>
                        <tbody>
                            @foreach (var row in _result.Rows)
                            {
                                <tr>@foreach (var c in ColumnNames()) { <td>@Display(row, c)</td> }</tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="nc-chart-controls">
                        <select class="ds-input" @bind="_chartType">
                            <option value="bar">Bar</option>
                            <option value="line">Line</option>
                            <option value="pie">Pie</option>
                        </select>
                        <select class="ds-input" @bind="_chartX">
                            <option value="">X axis…</option>
                            @foreach (var col in ColumnNames()) { <option value="@col">@col</option> }
                        </select>
                        <div class="nc-chart-y">
                            @foreach (var col in ColumnNames())
                            {
                                <label><input type="checkbox" checked="@_chartY.Contains(col)" @onchange="e => ToggleY(col, (bool)e.Value!)" /> @col</label>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_chartX) && _chartY.Count > 0)
                    {
                        <div style="height:60vh">
                            <ResultChart Rows="@_result.Rows" ChartType="@_chartType" XColumn="@_chartX" YColumns="@_chartY" Height="60vh" />
                        </div>
                    }
                    else
                    {
                        <p class="nc-hint">Choose an X axis and at least one value column.</p>
                    }
                }
            </div>
        </div>
    </div>
}

@if (_showCreateIngestion)
{
    <div class="ds-modal-backdrop" @onclick="() => _showCreateIngestion = false">
        <div class="ds-modal" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Create Ingestion Job</h2>
                <button class="ds-modal-close" @onclick="() => _showCreateIngestion = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                <div class="ds-field">
                    <label class="ds-label">Target table</label>
                    <input class="ds-input" value="@_ingestionTargetTable" disabled />
                    <span class="ds-hint">This job keeps this cell's own materialized table refreshed on a schedule.</span>
                </div>
                <div class="ds-field">
                    <label class="ds-label">Job name</label>
                    <input class="ds-input" @bind="_ingestionName" />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                    <div class="ds-field" style="margin-bottom:0">
                        <label class="ds-label">Mode</label>
                        <select class="ds-select" @bind="_ingestionMode">
                            <option value="Replace">Replace</option>
                            <option value="Append">Append</option>
                            <option value="Upsert">Upsert</option>
                        </select>
                    </div>
                    <div class="ds-field" style="margin-bottom:0">
                        <label class="ds-label">Schedule (cron)</label>
                        <input class="ds-input" @bind="_ingestionCron" placeholder="0 * * * *" />
                    </div>
                </div>
                @if (_ingestionMode == "Upsert")
                {
                    <div class="ds-field" style="margin-top:0.5rem">
                        <label class="ds-label">Key column(s) <span style="color:#71717a;font-weight:400">(comma-separated)</span></label>
                        <input class="ds-input" @bind="_ingestionKeyColumnsText" placeholder="id" />
                    </div>
                }
                <label style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem;font-size:0.875rem;cursor:pointer">
                    <input type="checkbox" class="ds-checkbox" @bind="_ingestionEnabled" /> Enabled (run on schedule)
                </label>
                <span class="ds-hint" style="display:block;margin-top:0.5rem">
                    This job re-runs the cell's current query on its own — editing the cell's SQL later won't update it.
                </span>
                <div class="ds-modal-footer">
                    <button type="button" class="btn btn-default" style="flex:1" @onclick="CreateIngestionJobSubmit" disabled="@_creatingIngestion">
                        @if (_creatingIngestion) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span><span>Creating...</span> }
                        else { <span>Create Job</span> }
                    </button>
                    <button type="button" class="btn btn-outline" style="flex:1" @onclick="() => _showCreateIngestion = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public NotebookCellDto Cell { get; set; } = new();
    [Parameter] public string NotebookId { get; set; } = string.Empty;
    [Parameter] public string? CompanyId { get; set; }
    /// <summary>Whether the user may query an External dataset's live source (data admins only). When false
    /// the picker hides the Source/Snapshot toggle and the cell stays on the Snapshot layer.</summary>
    [Parameter] public bool CanViewSource { get; set; } = true;
    [Parameter] public List<Dataset> Datasets { get; set; } = new();
    [Parameter] public List<NotebookCellDto> AvailableReferences { get; set; } = new();
    [Parameter] public bool ShowDragHandle { get; set; }
    /// <summary>Only the grip handle is draggable (not the whole card) so the browser doesn't have to
    /// snapshot a heavy subtree (Monaco editor, results table…) for the native drag-ghost image — that
    /// snapshot cost is what made starting a drag feel stuck for a few seconds.</summary>
    [Parameter] public EventCallback OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }
    [Parameter] public EventCallback<NotebookCellDto> OnUpdated { get; set; }
    [Parameter] public EventCallback<string> OnRemove { get; set; }
    /// <summary>Set by the parent after a "Run All" so this card reflects the result without the user
    /// having to re-run it individually. Applied once per distinct instance (reference-compared).</summary>
    [Parameter] public NotebookCellRunResult? ExternalResult { get; set; }

    private string _name = string.Empty;
    private string? _datasetId;
    private string _sql = string.Empty;
    private string _markdown = string.Empty;
    private List<string> _referencedCellIds = new();
    private bool _snapshotMode;
    private bool _collapsed;
    private bool _saving;
    private bool _running;
    private bool _expanded;
    private string _modalTab = "table";
    private bool _showAskAi;
    private bool _showComments;
    private int _commentCount;
    private bool _focusAiPending;
    private ElementReference _aiTextareaRef;
    private string _aiPrompt = string.Empty;
    private bool _aiAsking;
    private string? _aiReply;
    private bool _markdownPreview = true;

    private NotebookCellRunResult? _result;
    private string? _runError;

    // Create Ingestion Job dialog
    private bool _showCreateIngestion;
    private string _ingestionTargetTable = string.Empty;
    private string _ingestionName = string.Empty;
    private string _ingestionMode = "Replace";
    private string _ingestionKeyColumnsText = string.Empty;
    private string _ingestionCron = "0 * * * *";
    private bool _ingestionEnabled = true;
    private bool _creatingIngestion;

    private string _chartType = "bar";
    private string _chartX = string.Empty;
    private List<string> _chartY = new();

    private bool IsExternalDataset => Datasets.FirstOrDefault(d => d.Id == _datasetId)?.SourceType == DatasetSourceType.External;
    private NotebookCellRunResult? _lastAppliedExternalResult;

    // Table names for the current dataset, fed to Monaco for autocomplete — combined with the names of
    // referenced cells (also valid FROM targets once materialized).
    private List<string> _tableNames = new();
    private List<string> CompletionItems => _tableNames
        .Concat(AvailableReferences.Where(r => !string.IsNullOrWhiteSpace(r.Name)).Select(r => r.Name!))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    // Per-table column names for the current dataset — only available for the dataset's own DuckDB tables
    // (not a live External source, which has no column-listing endpoint), sourced from the dataset schema.
    private Dictionary<string, List<string>> _columnsByTable = new();

    protected override async Task OnInitializedAsync()
    {
        // Seed local editable state once per cell instance (keyed by Cell.Id in the parent's @foreach) —
        // later parent re-renders (e.g. another cell running) must not clobber in-progress edits here.
        _name = Cell.Name ?? string.Empty;
        _datasetId = Cell.DatasetId;
        _sql = Cell.Sql ?? string.Empty;
        _markdown = Cell.Markdown ?? string.Empty;
        _referencedCellIds = new List<string>(Cell.ReferencedCellIds);
        // A cell saved in live-source mode by a data admin must fall back to the snapshot layer for a user
        // without source access — they can't read the admin-gated source-tables endpoint.
        _snapshotMode = Cell.SnapshotMode || (!CanViewSource && IsExternalDataset);
        _runError = Cell.LastRunError;

        if (!string.IsNullOrWhiteSpace(_datasetId)) await LoadTablesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusAiPending)
        {
            _focusAiPending = false;
            try { await _aiTextareaRef.FocusAsync(); } catch { /* element may not be focusable yet — non-critical */ }
        }
    }

    private void ToggleAskAi()
    {
        _showAskAi = !_showAskAi;
        if (_showAskAi) _focusAiPending = true;
    }

    private void ToggleComments() => _showComments = !_showComments;

    private async Task OnAiKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await AskAi();
    }

    private async Task LoadTablesAsync()
    {
        if (string.IsNullOrWhiteSpace(_datasetId)) { _tableNames = new(); _columnsByTable = new(); return; }
        // In Source mode (the default for an External dataset), the user is querying the live database
        // itself, so autocomplete/discovery should reflect its real (schema-qualified) tables — not the
        // dataset's local DuckDB snapshot, which the RunCellAsync path only ever writes to, not from.
        var isLiveSource = IsExternalDataset && !_snapshotMode && CanViewSource;
        var endpoint = isLiveSource
            ? $"api/datasets/{_datasetId}/source-tables"
            : $"api/datasets/{_datasetId}/tables";
        try { _tableNames = await _httpClient.GetFromJsonAsync<List<string>>(endpoint) ?? new(); }
        catch { _tableNames = new(); }

        // No column-listing endpoint for a live external source — table-name-only completion there.
        if (isLiveSource) { _columnsByTable = new(); return; }
        try
        {
            var columns = await _httpClient.GetFromJsonAsync<Dictionary<string, List<Column>>>($"api/datasets/{_datasetId}/tables/columns");
            _columnsByTable = columns?.ToDictionary(kv => kv.Key, kv => kv.Value.Select(c => c.Name).ToList()) ?? new();
        }
        catch { _columnsByTable = new(); }
    }

    // The picker owns dataset + Source/Snapshot mode selection; reload this cell's table/column autocomplete
    // when the dataset changes. A mode change reloads via @bind-SnapshotMode:after="LoadTablesAsync".
    private async Task OnDatasetPicked(string value)
    {
        _datasetId = string.IsNullOrEmpty(value) ? null : value;
        await LoadTablesAsync();
    }

    protected override void OnParametersSet()
    {
        // A "Run All" on the parent produces a fresh result object per cell — adopt it once so this card
        // reflects the run without the user having to re-run it individually.
        if (ExternalResult != null && !ReferenceEquals(ExternalResult, _lastAppliedExternalResult))
        {
            _lastAppliedExternalResult = ExternalResult;
            _result = ExternalResult;
            _runError = ExternalResult.Error;
            if (_result.Error == null)
            {
                _chartX = ColumnNames().FirstOrDefault() ?? string.Empty;
                _chartY = ColumnNames().Skip(1).Take(1).ToList();
            }
        }
    }

    private async Task ToggleRef(string id, bool on)
    {
        if (on)
        {
            if (!_referencedCellIds.Contains(id)) _referencedCellIds.Add(id);
            // Convenience: a fresh cell that's just "building on" another one shouldn't also require
            // picking a dataset separately — default to the referenced cell's dataset if none is set yet.
            if (string.IsNullOrWhiteSpace(_datasetId))
            {
                var referenced = AvailableReferences.FirstOrDefault(r => r.Id == id);
                if (referenced != null && !string.IsNullOrWhiteSpace(referenced.DatasetId))
                {
                    _datasetId = referenced.DatasetId;
                    await LoadTablesAsync();
                }
            }
        }
        else
        {
            _referencedCellIds.Remove(id);
        }
    }

    private void ToggleY(string col, bool on)
    {
        if (on) { if (!_chartY.Contains(col)) _chartY.Add(col); }
        else _chartY.Remove(col);
    }

    private async Task<NotebookCellDto?> SaveCellAsync()
    {
        _saving = true;
        StateHasChanged();
        try
        {
            var request = new SaveNotebookCellRequest
            {
                DatasetId = Cell.CellType == "markdown" ? null : _datasetId,
                CellType = Cell.CellType,
                Name = _name,
                Sql = _sql,
                Markdown = _markdown,
                ReferencedCellIds = _referencedCellIds,
                SnapshotMode = _snapshotMode,
            };
            var response = await _httpClient.PutAsJsonAsync($"api/query-notebooks/{NotebookId}/cells/{Cell.Id}", request);
            if (response.IsSuccessStatusCode)
            {
                var updated = await response.Content.ReadFromJsonAsync<NotebookCellDto>();
                if (updated != null) await OnUpdated.InvokeAsync(updated);
                return updated;
            }
            _toastService.ShowError(await response.Content.ReadAsStringAsync());
            return null;
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Save failed: {ex.Message}");
            return null;
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    // {{name}} placeholders in the cell's SQL — detected client-side purely to decide whether to prompt
    // for values before running; the actual substitution happens server-side in QueryNotebookService.
    private static readonly Regex ParamPattern = new(@"\{\{\s*(\w+)\s*\}\}", RegexOptions.Compiled);
    private List<string> DetectParameterNames() => ParamPattern.Matches(_sql ?? "")
        .Select(m => m.Groups[1].Value).Distinct(StringComparer.OrdinalIgnoreCase).ToList();

    private bool _showParamPrompt;
    private List<string> _pendingParamNames = new();
    // Remembers this cell's last-used values for the session (component lifetime) so re-running doesn't
    // require retyping every parameter — never sent anywhere until the user hits Run.
    private Dictionary<string, string> _paramValues = new(StringComparer.OrdinalIgnoreCase);

    private async Task OnRunClicked()
    {
        var names = DetectParameterNames();
        if (names.Count == 0) { await Run(); return; }

        _pendingParamNames = names;
        foreach (var n in names)
            if (!_paramValues.ContainsKey(n)) _paramValues[n] = string.Empty;
        _showParamPrompt = true;
    }

    private async Task ConfirmParamPromptAndRun()
    {
        _showParamPrompt = false;
        await Run();
    }

    private async Task Run()
    {
        if (string.IsNullOrWhiteSpace(_name)) { _toastService.ShowWarning("Give this cell a name first."); return; }
        if (string.IsNullOrWhiteSpace(_datasetId)) { _toastService.ShowWarning("Pick a dataset first."); return; }

        _running = true;
        _runError = null;
        StateHasChanged();
        try
        {
            var saved = await SaveCellAsync();
            if (saved == null) return;

            var paramNames = DetectParameterNames();
            var request = new RunNotebookRequest
            {
                Parameters = paramNames.Count == 0 ? null : paramNames.ToDictionary(n => n, n => _paramValues.TryGetValue(n, out var v) ? v : "", StringComparer.OrdinalIgnoreCase)
            };

            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{NotebookId}/cells/{Cell.Id}/run", request);
            if (response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadFromJsonAsync<NotebookCellRunResult>();
                _runError = _result?.Error;
                if (_result != null)
                {
                    _chartX = ColumnNames().FirstOrDefault() ?? string.Empty;
                    _chartY = ColumnNames().Skip(1).Take(1).ToList();
                }
            }
            else
            {
                _runError = $"Run failed ({(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private async Task CancelRun()
    {
        try { await _httpClient.PostAsync($"api/query-notebooks/{NotebookId}/cells/{Cell.Id}/cancel", null); }
        catch { /* best-effort — the run's own finally block still clears _running once it observes the cancellation */ }
    }

    private bool _showHistory;
    private bool _historyLoading;
    private List<NotebookCellRunDto> _history = new();

    private async Task ToggleHistory()
    {
        _showHistory = !_showHistory;
        if (!_showHistory) return;

        _historyLoading = true;
        StateHasChanged();
        try
        {
            _history = await _httpClient.GetFromJsonAsync<List<NotebookCellRunDto>>($"api/query-notebooks/{NotebookId}/cells/{Cell.Id}/runs") ?? new();
        }
        catch { _history = new(); }
        finally
        {
            _historyLoading = false;
            StateHasChanged();
        }
    }

    private static string TriggerLabel(string triggeredBy) => triggeredBy switch
    {
        "run_all" => "Run All",
        "scheduled" => "Scheduled",
        _ => "Manual",
    };

    private async Task AskAi()
    {
        _aiAsking = true;
        StateHasChanged();
        try
        {
            // Persist first so the server-side context (prior/referenced cells) reflects this cell's
            // latest dataset/name.
            var saved = await SaveCellAsync();
            if (saved == null) return;

            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{NotebookId}/cells/{Cell.Id}/ai-assist", new NotebookAiAssistRequest { Message = _aiPrompt });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<NotebookAiAssistResult>();
                _aiReply = result?.Reply;
                if (!string.IsNullOrWhiteSpace(result?.Sql)) _sql = result!.Sql!;
            }
            else
            {
                _aiReply = $"AI assist failed ({(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            _aiReply = ex.Message;
        }
        finally
        {
            _aiAsking = false;
            StateHasChanged();
        }
    }

    private List<string> ColumnNames()
    {
        if (_result?.Columns?.Any() == true) return _result.Columns.Select(c => c.Name).ToList();
        return _result?.Rows.FirstOrDefault()?.Keys.ToList() ?? new();
    }

    private static string Display(Dictionary<string, object?> row, string col)
        => row.TryGetValue(col, out var v) && v != null ? v.ToString() ?? "" : "";

    private async Task ExportCsv(List<Dictionary<string, object?>> rows)
    {
        var columns = ColumnNames();
        var csv = new StringBuilder();
        csv.AppendLine(string.Join(",", columns.Select(CsvField)));
        foreach (var row in rows)
            csv.AppendLine(string.Join(",", columns.Select(c => CsvField(Display(row, c)))));

        var fileName = $"{(string.IsNullOrWhiteSpace(_name) ? "cell_result" : _name)}.csv";
        await _jsRuntime.InvokeVoidAsync("downloadTextFile", fileName, "text/csv;charset=utf-8", csv.ToString());
    }

    private static string CsvField(string value) => "\"" + value.Replace("\"", "\"\"") + "\"";

    // No Excel-writer library is referenced in this solution, so this uses the well-known zero-dependency
    // trick of serving an HTML table with a .xls extension/MIME type — Excel opens it as a normal workbook.
    private async Task ExportExcel(List<Dictionary<string, object?>> rows)
    {
        var columns = ColumnNames();
        var html = new StringBuilder();
        html.Append("<html><head><meta charset=\"utf-8\"/></head><body><table><thead><tr>");
        foreach (var c in columns) html.Append("<th>").Append(System.Net.WebUtility.HtmlEncode(c)).Append("</th>");
        html.Append("</tr></thead><tbody>");
        foreach (var row in rows)
        {
            html.Append("<tr>");
            foreach (var c in columns) html.Append("<td>").Append(System.Net.WebUtility.HtmlEncode(Display(row, c))).Append("</td>");
            html.Append("</tr>");
        }
        html.Append("</tbody></table></body></html>");

        var fileName = $"{(string.IsNullOrWhiteSpace(_name) ? "cell_result" : _name)}.xls";
        await _jsRuntime.InvokeVoidAsync("downloadTextFile", fileName, "application/vnd.ms-excel", html.ToString());
    }

    // The cell's result is a real DuckDB table once materialized — jump straight to the standard table
    // view (same page ListTable's "View" action opens) instead of only browsing it inline here.
    private void OpenTableView()
    {
        var table = _result?.MaterializedObjectName ?? Cell.LastMaterializedObject;
        if (string.IsNullOrEmpty(_datasetId) || string.IsNullOrEmpty(table)) return;
        _navigationManager.NavigateTo($"/data/view?c={CompanyId}&DatasetId={_datasetId}&TableName={Uri.EscapeDataString(table)}");
    }

    private void OpenCreateIngestionJob()
    {
        var table = _result?.MaterializedObjectName ?? Cell.LastMaterializedObject;
        if (string.IsNullOrEmpty(table)) return;

        _ingestionTargetTable = table;
        _ingestionName = _name;
        _ingestionMode = "Replace";
        _ingestionKeyColumnsText = string.Empty;
        _ingestionCron = "0 * * * *";
        _ingestionEnabled = true;
        _showCreateIngestion = true;
    }

    private async Task CreateIngestionJobSubmit()
    {
        if (string.IsNullOrWhiteSpace(_ingestionName))
        {
            _toastService.ShowWarning("Give the job a name.");
            return;
        }
        if (string.IsNullOrWhiteSpace(_datasetId) || string.IsNullOrEmpty(_ingestionTargetTable))
        {
            _toastService.ShowWarning("This cell hasn't materialized a table yet — run it first.");
            return;
        }

        try
        {
            _creatingIngestion = true;
            StateHasChanged();

            var keyColumns = _ingestionKeyColumnsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

            var request = new SaveIngestionSourceRequest
            {
                Name = _ingestionName.Trim(),
                TargetTable = _ingestionTargetTable,
                SourceKind = "SqlQuery",
                Config = new IngestionSourceConfig { Query = _sql },
                ImportMode = _ingestionMode,
                KeyColumns = keyColumns,
                CreateIfNotExists = true,
                CronExpression = string.IsNullOrWhiteSpace(_ingestionCron) ? "0 * * * *" : _ingestionCron,
                IsEnabled = _ingestionEnabled
            };

            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{_datasetId}/ingestion", request);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Ingestion job '{_ingestionName}' created.");
                _showCreateIngestion = false;
            }
            else
            {
                _toastService.ShowError($"Failed to create ingestion job: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error creating ingestion job: {ex.Message}");
        }
        finally
        {
            _creatingIngestion = false;
            StateHasChanged();
        }
    }

    // Minimal, SAFE Markdown-subset renderer: HTML-encode the raw text FIRST, then layer a handful of
    // inline/block transforms on top of the already-escaped text — so no literal HTML the user types can
    // ever reach the page (matches CommentsSidebar's HtmlEncode-then-transform pattern). Supports #/##/###
    // headings, **bold**, *italic*, "- " list items and blank-line paragraphs — enough for notebook notes,
    // not a full CommonMark implementation.
    private static string RenderMarkdown(string raw)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(raw);
        var lines = encoded.Replace("\r\n", "\n").Split('\n');
        var sb = new StringBuilder();
        var inList = false;

        foreach (var line in lines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("- "))
            {
                if (!inList) { sb.Append("<ul>"); inList = true; }
                sb.Append("<li>").Append(InlineFormat(trimmed[2..])).Append("</li>");
                continue;
            }
            if (inList) { sb.Append("</ul>"); inList = false; }

            if (trimmed.StartsWith("### ")) sb.Append("<h3>").Append(InlineFormat(trimmed[4..])).Append("</h3>");
            else if (trimmed.StartsWith("## ")) sb.Append("<h2>").Append(InlineFormat(trimmed[3..])).Append("</h2>");
            else if (trimmed.StartsWith("# ")) sb.Append("<h1>").Append(InlineFormat(trimmed[2..])).Append("</h1>");
            else if (trimmed.Length == 0) sb.Append("<br/>");
            else sb.Append("<p>").Append(InlineFormat(trimmed)).Append("</p>");
        }
        if (inList) sb.Append("</ul>");
        return sb.ToString();
    }

    private static string InlineFormat(string text)
    {
        text = Regex.Replace(text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        text = Regex.Replace(text, @"\*(.+?)\*", "<em>$1</em>");
        return text;
    }
}

<style>
    .nc-card { display:flex; flex-direction:column; background:#fff; border:1px solid #e4e4e7; border-radius:10px; overflow:hidden; }
    .nc-head { display:flex; align-items:center; justify-content:space-between; padding:0.5rem 0.75rem; border-bottom:1px solid #f4f4f5; gap:0.5rem; flex-wrap:wrap; }
    .nc-head-left { display:flex; align-items:center; gap:0.4rem; min-width:0; flex:1; flex-wrap:wrap; }
    .nc-grip { display:flex; align-items:center; flex-shrink:0; color:#a1a1aa; cursor:grab; }
    .nc-grip:active { cursor:grabbing; }
    .nc-title { font-size:0.875rem; font-weight:600; color:#18181b; }

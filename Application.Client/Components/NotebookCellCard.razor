    .nc-tab-active { background:#2563eb; color:#fff; border-color:#2563eb; }
    .nc-actions { display:flex; align-items:center; gap:0.25rem; flex-shrink:0; }
    .nc-body { padding:0.75rem; display:flex; flex-direction:column; gap:0.5rem; }
    /* Ask AI — a small floating popover anchored to its trigger button, not an inline strip. */

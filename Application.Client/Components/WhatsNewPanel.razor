@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Application.Shared.Models.WhatsNew
@inject HttpClient _httpClient
@inject AuthenticationStateProvider _authenticationStateProvider

<div class="wn-anchor">
    <button class="wn-trigger" type="button" @onclick="TogglePanel" title="What's new" aria-label="What's new">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/><circle cx="12" cy="12" r="2.5" fill="currentColor" stroke="none"/></svg>
        @if (_unseenCount > 0)
        {
            <span class="wn-badge">@(_unseenCount > 9 ? "9+" : _unseenCount.ToString())</span>
        }
    </button>

    @if (_open)
    {
        <div class="wn-backdrop" @onclick="ClosePanel"></div>
        <div class="wn-panel" @onclick:stopPropagation="true">
            <div class="wn-panel-head">What's New</div>
            @if (_loading)
            {
                <div class="wn-loading"><span class="ds-spinner" style="width:16px;height:16px;border-width:2px"></span></div>
            }
            else if (_items.Count == 0)
            {
                <div class="wn-empty">Nothing here yet.</div>
            }
            else
            {
                <div class="wn-list">
                    @foreach (var item in _items)
                    {
                        <div class="wn-item">
                            <div class="wn-item-head">
                                @if (!string.IsNullOrWhiteSpace(item.Category))
                                {
                                    <span class="wn-tag">@item.Category</span>
                                }
                                @if (item.IsNew)
                                {
                                    <span class="wn-new-pill">New</span>
                                }
                                <span class="wn-time">@RelativeTime(item.CreatedAt)</span>
                            </div>
                            <div class="wn-title">@item.Title</div>
                            <div class="wn-desc">@item.Description</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _open;
    private bool _loading;
    private bool _loaded;
    private List<WhatsNewItemDto> _items = new();
    private int _unseenCount;

    protected override async Task OnInitializedAsync()
    {
        await SetUserHeaderAsync();
        await LoadFeedAsync();
    }

    private async Task SetUserHeaderAsync()
    {
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _httpClient.DefaultRequestHeaders.Remove("UserId");
                _httpClient.DefaultRequestHeaders.Add("UserId", userId);
            }
        }
    }

    private async Task LoadFeedAsync()
    {
        try
        {
            _loading = true;
            StateHasChanged();
            var feed = await _httpClient.GetFromJsonAsync<WhatsNewFeedDto>("api/whatsnew");
            _items = feed?.Items ?? new();
            _unseenCount = feed?.UnseenCount ?? 0;
            _loaded = true;
        }
        catch { /* the icon just stays quiet if the feed can't be reached */ }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task TogglePanel()
    {
        _open = !_open;
        if (_open)
        {
            if (!_loaded) await LoadFeedAsync();
            if (_unseenCount > 0)
            {
                // Optimistic: clear the badge immediately, persist in the background.
                _unseenCount = 0;
                foreach (var item in _items) item.IsNew = false;
                _ = MarkSeenAsync();
            }
        }
    }

    private void ClosePanel() => _open = false;

    private async Task MarkSeenAsync()
    {
        try { await _httpClient.PostAsync("api/whatsnew/seen", null); }
        catch { /* best-effort — worst case the badge reappears next load */ }
    }

    private static string RelativeTime(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 60) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays}d ago";
        if (span.TotalDays < 365) return $"{(int)(span.TotalDays / 30)}mo ago";
        return $"{(int)(span.TotalDays / 365)}y ago";
    }
}

<style>
    .wn-anchor { position: relative; display: flex; align-items: center; }
    .wn-trigger {
        position: relative; display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border: none; background: none; cursor: pointer;
        border-radius: 7px; color: #374151; transition: background 0.12s;
    }
    .wn-trigger:hover { background: #f3f4f6; }
    .wn-badge {
        position: absolute; top: 2px; right: 2px; min-width: 15px; height: 15px; padding: 0 3px;
        border-radius: 9999px; background: #ef4444; color: #fff; font-size: 10px; font-weight: 700;
        line-height: 15px; text-align: center; box-shadow: 0 0 0 2px #fff;
    }
    .wn-backdrop { position: fixed; inset: 0; z-index: 900; background: transparent; }
    .wn-panel {
        position: absolute; top: calc(100% + 6px); right: 0; z-index: 901;
        width: 360px; max-width: calc(100vw - 2rem); max-height: 420px; overflow-y: auto;
        background: #fff; border: 1px solid #e5e7eb; border-radius: 10px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.16), 0 2px 8px rgba(0,0,0,0.06);
        animation: wn-fade-in 0.14s ease-out;
    }
    @@keyframes wn-fade-in {
        from { opacity: 0; transform: translateY(-4px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .wn-panel-head {
        font-size: 0.8125rem; font-weight: 700; color: #18181b; padding: 0.75rem 0.9rem 0.5rem;
        position: sticky; top: 0; background: #fff; border-bottom: 1px solid #f4f4f5;
    }
    .wn-loading, .wn-empty { display: flex; align-items: center; justify-content: center; padding: 1.5rem; color: #a1a1aa; font-size: 0.8125rem; }
    .wn-list { display: flex; flex-direction: column; }
    .wn-item { padding: 0.7rem 0.9rem; border-bottom: 1px solid #f4f4f5; }
    .wn-item:last-child { border-bottom: none; }
    .wn-item-head { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.25rem; }
    .wn-tag {
        font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
        color: #4338ca; background: #eef2ff; padding: 0.1rem 0.4rem; border-radius: 9999px;
    }
    .wn-new-pill {
        font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
        color: #15803d; background: #dcfce7; padding: 0.1rem 0.4rem; border-radius: 9999px;
    }
    .wn-time { font-size: 0.6875rem; color: #a1a1aa; margin-left: auto; flex-shrink: 0; }
    .wn-title { font-size: 0.8438rem; font-weight: 600; color: #18181b; margin-bottom: 0.15rem; }
    .wn-desc { font-size: 0.8125rem; color: #52525b; line-height: 1.4; }

    @@media (max-width: 640px) {
        /* Anchored right:0 off the trigger button, the panel can otherwise run past the left edge
           of a narrow viewport — pin it to the viewport instead, with matching side padding. */
        .wn-panel {
            position: fixed;
            top: 58px;
            left: 12px;
            right: 12px;
            width: auto;
            max-width: none;
        }
    }

    /* ── Dark mode ─────────────────────────────────────────────────────── */
    [data-theme="dark"] .wn-trigger { color: #9aa1ac; }
    [data-theme="dark"] .wn-trigger:hover { background: #20242c; color: #f3f4f6; }
    [data-theme="dark"] .wn-badge { box-shadow: 0 0 0 2px #14161c; }
    [data-theme="dark"] .wn-panel { background: #181a20; border-color: #2b303b; box-shadow: 0 12px 32px rgba(0,0,0,0.6), 0 2px 8px rgba(0,0,0,0.4); }
    [data-theme="dark"] .wn-panel-head { color: #f3f4f6; background: #181a20; border-bottom-color: #23272f; }
    [data-theme="dark"] .wn-loading,
    [data-theme="dark"] .wn-empty { color: #9aa1ac; }
    [data-theme="dark"] .wn-item { border-bottom-color: #23272f; }
    [data-theme="dark"] .wn-tag { color: #c7d2fe; background: rgba(99,102,241,0.15); }
    [data-theme="dark"] .wn-new-pill { color: #4ade80; background: rgba(34,197,94,0.15); }
    [data-theme="dark"] .wn-time { color: #6b7280; }
    [data-theme="dark"] .wn-title { color: #f3f4f6; }
    [data-theme="dark"] .wn-desc { color: #c5cad4; }
</style>

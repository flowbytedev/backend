@implements IAsyncDisposable
@inject IJSRuntime _js

@if (_failed)
{
    <textarea class="mse-fallback" style="width:100%;height:@Height;font-family:ui-monospace,Consolas,monospace;font-size:13px;padding:8px;border:1px solid #e4e4e7;border-radius:6px;box-sizing:border-box"
              @bind="_fallbackValue" @bind:event="oninput" @bind:after="OnFallbackChanged" @onkeydown="OnFallbackKeyDown"
              placeholder="SELECT * FROM ..."></textarea>
}
else
{
    <div id="@_id" class="mse-host" style="height:@Height;border:1px solid #e4e4e7;border-radius:6px;overflow:hidden"></div>
}

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Height { get; set; } = "240px";
    /// <summary>Table (and cell-reference) names to offer as autocomplete suggestions in FROM/JOIN.</summary>
    [Parameter] public List<string>? Tables { get; set; }
    /// <summary>Per-table column names ("table" or "table.column"-prefixed key -> column names), sourced
    /// from the cell's dataset schema, offered as qualified ("table.column") and unqualified suggestions.</summary>
    [Parameter] public Dictionary<string, List<string>>? Columns { get; set; }
    /// <summary>Fired on Ctrl+Enter (Cmd+Enter on Mac) inside the editor — the conventional "run" shortcut.</summary>
    [Parameter] public EventCallback OnRunRequested { get; set; }

    private readonly string _id = "monaco-" + Guid.NewGuid().ToString("N");
    private IJSObjectReference? _module;
    private DotNetObjectReference<MonacoSqlEditor>? _ref;
    private bool _initialized;
    private bool _failed;
    private string? _fallbackValue;
    private string? _lastValue;
    private List<string>? _lastTables;
    private Dictionary<string, List<string>>? _lastColumns;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _module = await _js.InvokeAsync<IJSObjectReference>("import", "./js/monaco-sql-editor.js");
                _ref = DotNetObjectReference.Create(this);
                await _module.InvokeVoidAsync("init", _id, _ref, Value ?? "");
                _initialized = true;
                _lastValue = Value;
                _lastTables = Tables;
                _lastColumns = Columns;
                await _module.InvokeVoidAsync("setCompletions", _id, Tables ?? new List<string>(), Columns ?? new Dictionary<string, List<string>>());
            }
            catch
            {
                // Monaco unavailable (load/CSP failure) — degrade to a plain textarea.
                _failed = true;
                _fallbackValue = Value;
                StateHasChanged();
            }
            return;
        }

        if (!_initialized || _module == null) return;

        // Push externally-driven Value changes (e.g. loading a saved query) into the editor.
        if (Value != _lastValue)
        {
            _lastValue = Value;
            try { await _module.InvokeVoidAsync("setValue", _id, Value ?? ""); } catch { }
        }

        // Push an updated table list / column map (e.g. the user picked a different dataset) for autocomplete.
        if (!TablesEqual(Tables, _lastTables) || !ReferenceEquals(Columns, _lastColumns))
        {
            _lastTables = Tables;
            _lastColumns = Columns;
            try { await _module.InvokeVoidAsync("setCompletions", _id, Tables ?? new List<string>(), Columns ?? new Dictionary<string, List<string>>()); } catch { }
        }
    }

    private static bool TablesEqual(List<string>? a, List<string>? b)
    {
        if (a == null && b == null) return true;
        if (a == null || b == null) return false;
        return a.SequenceEqual(b, StringComparer.Ordinal);
    }

    [JSInvokable]
    public async Task OnValueChanged(string value)
    {
        _lastValue = value;
        Value = value;
        if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(value);
    }

    [JSInvokable]
    public async Task OnRunShortcut()
    {
        if (OnRunRequested.HasDelegate) await OnRunRequested.InvokeAsync();
    }

    private async Task OnFallbackChanged()
    {
        Value = _fallbackValue;
        _lastValue = _fallbackValue;
        if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(_fallbackValue ?? "");
    }

    // Same shortcut for the degraded (Monaco-unavailable) plain-textarea fallback.
    private async Task OnFallbackKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey) && OnRunRequested.HasDelegate)
            await OnRunRequested.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module != null && _initialized) await _module.InvokeVoidAsync("dispose", _id);
            if (_module != null) await _module.DisposeAsync();
        }
        catch { /* ignore teardown races */ }
        _ref?.Dispose();
    }
}

<style>
    /* Dark mode: only the editor chrome (border/fallback textarea) is ours.
       Monaco's own surface + syntax colors are themed in JS (monaco-sql-editor.js) — not fought here. */
    [data-theme="dark"] .mse-host { border-color:#2b303b !important; }
    [data-theme="dark"] .mse-fallback { border-color:#2b303b !important; background:#12141a !important; color:#e6e9ef !important; }
</style>

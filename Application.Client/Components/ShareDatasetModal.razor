@using Application.Shared.Models.Data
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject AuthenticationStateProvider _authenticationStateProvider

@if (IsVisible)
{
    <div class="ds-modal-backdrop" @onclick="HandleBackdropClick">
        <div class="ds-modal" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">
                    Share Dataset
                    @if (!string.IsNullOrEmpty(DatasetName))
                    {
                        <span class="sd-title-meta" style="color:#71717a;font-weight:400"> — @DatasetName</span>
                    }
                </h2>
                <button class="ds-modal-close" @onclick="CloseDialog" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>

            <div class="ds-modal-body">
                <EditForm Model="@shareRequest" OnValidSubmit="@HandleShareSubmit">
                    <DataAnnotationsValidator />

                    <div class="ds-field">
                        <label class="ds-label">Email Address</label>
                        <div class="sd-autocomplete">
                            <input class="ds-input" type="text" autocomplete="off"
                                   placeholder="Search company members by name or email"
                                   value="@shareRequest.Email"
                                   @oninput="OnEmailInput" @onfocus="OnEmailFocus" @onblur="OnEmailBlur" />
                            @if (showSuggestions && memberSuggestions.Any())
                            {
                                <div class="sd-suggestions">
                                    @foreach (var m in memberSuggestions)
                                    {
                                        var member = m;
                                        <div class="sd-suggestion" @onmousedown="() => SelectMember(member)">
                                            <div class="sd-suggestion-avatar">@(string.IsNullOrEmpty(member.Email) ? "?" : member.Email[..1].ToUpper())</div>
                                            <div style="min-width:0">
                                                @if (!string.IsNullOrWhiteSpace(member.FullName) && member.FullName != member.Email)
                                                {
                                                    <div class="sd-suggestion-name">@member.FullName</div>
                                                }
                                                <div class="sd-suggestion-email">@member.Email</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <ValidationMessage For="() => shareRequest.Email" class="ds-error" />
                    </div>

                    <div class="ds-field">
                        <label class="ds-label">Access Level</label>
                        <select class="ds-select" @bind="selectedUserTypeString">
                            <option value="Viewer">Viewer — Can view and query data</option>
                            <option value="Editor">Editor — Can modify dataset structure</option>
                            <option value="Admin">Admin — Full access including sharing</option>
                        </select>
                    </div>

                    <div class="ds-field" style="margin-bottom:0">
                        <label class="ds-label">Tables</label>
                        <div style="display:flex;gap:1.25rem;margin-bottom:0.5rem">
                            <label style="display:flex;align-items:center;gap:0.375rem;font-size:0.875rem;cursor:pointer">
                                <input type="radio" name="tableScope" checked="@shareAllTables" @onchange="@(() => shareAllTables = true)" /> All tables
                            </label>
                            <label style="display:flex;align-items:center;gap:0.375rem;font-size:0.875rem;cursor:pointer">
                                <input type="radio" name="tableScope" checked="@(!shareAllTables)" @onchange="@(() => shareAllTables = false)" disabled="@(datasetTables.Count == 0)" /> Specific tables
                            </label>
                        </div>
                        @if (!shareAllTables)
                        {
                            @if (datasetTables.Count == 0)
                            {
                                <span class="ds-hint">This dataset has no tables to scope.</span>
                            }
                            else
                            {
                                <div class="sd-tables-box" style="max-height:180px;overflow-y:auto;border:1px solid #e4e4e7;border-radius:6px;padding:0.5rem;display:flex;flex-direction:column;gap:0.25rem">
                                    @foreach (var t in datasetTables)
                                    {
                                        <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.8125rem;cursor:pointer">
                                            <input type="checkbox" checked="@selectedTables.Contains(t)" @onchange="e => ToggleTable(t, (bool)e.Value!)" />
                                            <span style="font-family:ui-monospace,Consolas,monospace">@t</span>
                                        </label>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="ds-modal-footer">
                        <button type="submit" class="btn btn-default" style="flex:1" disabled="@isSharing">
                            @if (isSharing)
                            {
                                <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span>
                                <span>Sharing...</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                                <span>Share Dataset</span>
                            }
                        </button>
                        <button type="button" class="btn btn-outline" style="flex:1" @onclick="CloseDialog">Cancel</button>
                    </div>
                </EditForm>

                @if (isLoadingShares)
                {
                    <hr class="ds-divider" />
                    <div class="ds-loading" style="padding:1.5rem 0">
                        <div class="ds-spinner"></div>
                        <span>Loading shared users...</span>
                    </div>
                }
                else if (sharedUsers?.Any() == true)
                {
                    <hr class="ds-divider" />
                    <p class="sd-shared-cap" style="font-size:0.8125rem;font-weight:500;color:#71717a;margin:0 0 0.625rem 0;text-transform:uppercase;letter-spacing:0.05em">Shared With</p>
                    <div style="display:flex;flex-direction:column;gap:0.5rem">
                        @foreach (var user in sharedUsers)
                        {
                            <div class="ds-user-row">
                                <div>
                                    <p class="ds-user-email">@user.Email</p>
                                    <p class="ds-user-meta">
                                        <span class="ds-badge @GetBadgeClass(user.Type)">@GetAccessLevelText(user.Type)</span>
                                        <span style="margin-left:0.375rem">· @user.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        <span style="margin-left:0.375rem" title="@(user.Tables.Count == 0 ? "All tables" : string.Join(", ", user.Tables))">
                                            · @(user.Tables.Count == 0 ? "All tables" : $"{user.Tables.Count} table{(user.Tables.Count == 1 ? "" : "s")}")
                                        </span>
                                    </p>
                                </div>
                                <button class="btn-icon btn-icon-delete" title="Remove access" @onclick="() => RemoveUserAccess(user.UserId)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .sd-autocomplete { position: relative; }
    .sd-suggestions {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 20;
        background: #fff; border: 1px solid #e4e4e7; border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.12); max-height: 240px; overflow-y: auto; padding: 4px;
    }
    .sd-suggestion {
        display: flex; align-items: center; gap: .5rem; padding: .4rem .5rem;
        border-radius: 6px; cursor: pointer;
    }
    .sd-suggestion:hover { background: #f4f4f5; }
    .sd-suggestion-avatar {
        flex: 0 0 auto; width: 26px; height: 26px; border-radius: 50%;
        background: #e4e4e7; color: #3f3f46; font-size: .75rem; font-weight: 600;
        display: flex; align-items: center; justify-content: center;
    }
    .sd-suggestion-name { font-size: .8125rem; font-weight: 600; color: #18181b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sd-suggestion-email { font-size: .75rem; color: #71717a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* ── Dark mode ─────────────────────────────────────────────────────── */
    [data-theme="dark"] .sd-suggestions { background: #181a20; border-color: #2b303b; box-shadow: 0 8px 24px rgba(0,0,0,.5); }
    [data-theme="dark"] .sd-suggestion:hover { background: #20242c; }
    [data-theme="dark"] .sd-suggestion-avatar { background: #2b303b; color: #e6e9ef; }
    [data-theme="dark"] .sd-suggestion-name { color: #f3f4f6; }
    [data-theme="dark"] .sd-suggestion-email { color: #9aa1ac; }
    [data-theme="dark"] .sd-title-meta { color: #9aa1ac !important; }
    [data-theme="dark"] .sd-shared-cap { color: #9aa1ac !important; }
    [data-theme="dark"] .sd-tables-box { border-color: #2b303b !important; }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string DatasetId { get; set; } = string.Empty;
    [Parameter] public string DatasetName { get; set; } = string.Empty;
    [Parameter] public string CompanyId { get; set; } = string.Empty;

    private ShareDatasetRequest shareRequest = new();
    private List<DatasetUserDto>? sharedUsers;
    private bool isSharing = false;
    private bool isLoadingShares = false;
    private string selectedUserTypeString = "Viewer";

    private bool shareAllTables = true;
    private List<string> datasetTables = new();
    private HashSet<string> selectedTables = new(StringComparer.OrdinalIgnoreCase);

    private List<UserMention> memberSuggestions = new();
    private bool showSuggestions = false;
    private CancellationTokenSource? suggestCts;

    private async Task OnEmailInput(ChangeEventArgs e)
    {
        shareRequest.Email = e.Value?.ToString() ?? string.Empty;
        await SearchMembers(shareRequest.Email);
    }

    private async Task OnEmailFocus() => await SearchMembers(shareRequest.Email);

    // Delay hiding so an @onmousedown selection on a suggestion registers before blur closes the list.
    private async Task OnEmailBlur()
    {
        await Task.Delay(150);
        showSuggestions = false;
        StateHasChanged();
    }

    private async Task SearchMembers(string term)
    {
        // Debounce rapid keystrokes.
        suggestCts?.Cancel();
        var cts = suggestCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(200, cts.Token);

            if (!_httpClient.DefaultRequestHeaders.Contains("X-Company-ID"))
                _httpClient.DefaultRequestHeaders.Add("X-Company-ID", CompanyId);

            var url = $"api/DataViews/users/search?maxResults=8";
            if (!string.IsNullOrWhiteSpace(term))
                url += $"&searchTerm={Uri.EscapeDataString(term)}";

            var results = await _httpClient.GetFromJsonAsync<List<UserMention>>(url, cts.Token);
            if (cts.IsCancellationRequested) return;

            memberSuggestions = results ?? new();
            showSuggestions = memberSuggestions.Any();
            StateHasChanged();
        }
        catch (OperationCanceledException) { /* superseded by a newer keystroke */ }
        catch (Exception ex) { Console.WriteLine($"Member search failed: {ex.Message}"); }
    }

    private void SelectMember(UserMention member)
    {
        shareRequest.Email = member.Email;
        showSuggestions = false;
        StateHasChanged();
    }

    private void ToggleTable(string table, bool on)
    {
        if (on) selectedTables.Add(table);
        else selectedTables.Remove(table);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !string.IsNullOrEmpty(DatasetId))
        {
            shareRequest = new ShareDatasetRequest
            {
                DatasetId = DatasetId,
                UserType = DatasetUserType.Viewer
            };
            selectedUserTypeString = "Viewer";
            shareAllTables = true;
            selectedTables.Clear();
            await LoadDatasetTables();
            await LoadSharedUsers();
        }
    }

    private async Task LoadDatasetTables()
    {
        datasetTables = new();
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            // Try the dataset's own tables first; fall back to external source tables.
            var response = await _httpClient.GetAsync($"api/datasets/{DatasetId}/tables");
            if (!response.IsSuccessStatusCode)
                response = await _httpClient.GetAsync($"api/datasets/{DatasetId}/source-tables");

            if (response.IsSuccessStatusCode)
                datasetTables = await response.Content.ReadFromJsonAsync<List<string>>() ?? new();
        }
        catch { /* no tables (404) or external not configured — leave empty, "All tables" stays selected */ }
    }

    private async Task LoadSharedUsers()
    {
        try
        {
            isLoadingShares = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            var response = await _httpClient.GetAsync($"api/datasets/{DatasetId}/sharing");
            if (response.IsSuccessStatusCode)
                sharedUsers = await response.Content.ReadFromJsonAsync<List<DatasetUserDto>>();
            else
                _toastService.ShowError("Failed to load shared users");
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading shared users: {ex.Message}");
        }
        finally
        {
            isLoadingShares = false;
            StateHasChanged();
        }
    }

    private async Task HandleShareSubmit()
    {
        try
        {
            isSharing = true;
            StateHasChanged();

            shareRequest.UserType = selectedUserTypeString switch
            {
                "Admin" => DatasetUserType.Admin,
                "Editor" => DatasetUserType.Editor,
                _ => DatasetUserType.Viewer
            };

            if (shareAllTables)
            {
                shareRequest.Tables = null;
            }
            else
            {
                if (selectedTables.Count == 0)
                {
                    _toastService.ShowWarning("Select at least one table, or choose 'All tables'.");
                    isSharing = false;
                    return;
                }
                shareRequest.Tables = selectedTables.ToList();
            }

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{DatasetId}/sharing", shareRequest);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Dataset shared with {shareRequest.Email}");
                shareRequest.Email = string.Empty;
                shareRequest.UserType = DatasetUserType.Viewer;
                shareRequest.Tables = null;
                selectedUserTypeString = "Viewer";
                shareAllTables = true;
                selectedTables.Clear();
                await LoadSharedUsers();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to share dataset: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error sharing dataset: {ex.Message}");
        }
        finally
        {
            isSharing = false;
            StateHasChanged();
        }
    }

    private async Task RemoveUserAccess(string userId)
    {
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(currentUserId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", currentUserId);
                }
            }

            var response = await _httpClient.DeleteAsync($"api/datasets/{DatasetId}/sharing/{userId}");
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("User access removed");
                await LoadSharedUsers();
            }
            else
            {
                _toastService.ShowError("Failed to remove user access");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error removing user access: {ex.Message}");
        }
    }

    private async Task CloseDialog()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleBackdropClick() => await CloseDialog();

    private string GetAccessLevelText(DatasetUserType userType) => userType switch
    {
        DatasetUserType.Admin => "Admin",
        DatasetUserType.Editor => "Editor",
        _ => "Viewer"
    };

    private string GetBadgeClass(DatasetUserType userType) => userType switch
    {
        DatasetUserType.Admin => "ds-badge-admin",
        DatasetUserType.Editor => "ds-badge-editor",
        _ => "ds-badge-viewer"
    };
}

@implements IAsyncDisposable
@inject IJSRuntime _js

<div style="height:@Height"><canvas id="@_id"></canvas></div>

@code {
    [Parameter] public List<Dictionary<string, object?>>? Rows { get; set; }
    [Parameter] public string? ChartType { get; set; } = "bar";
    [Parameter] public string? XColumn { get; set; }
    [Parameter] public List<string>? YColumns { get; set; }
    [Parameter] public string Height { get; set; } = "380px";

    private readonly string _id = "chart-" + Guid.NewGuid().ToString("N");
    private IJSObjectReference? _module;
    private string? _lastSignature;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Redraw only when the inputs actually change (avoids re-rendering the chart every cycle).
        var signature = $"{ChartType}|{XColumn}|{string.Join(",", YColumns ?? new())}|{Rows?.Count ?? 0}|{Height}";
        if (signature == _lastSignature) return;
        _lastSignature = signature;
        await Draw();
    }

    private async Task Draw()
    {
        try
        {
            _module ??= await _js.InvokeAsync<IJSObjectReference>("import", "./js/result-chart.js");
            var config = BuildConfig();
            if (config == null)
            {
                await _module.InvokeVoidAsync("destroy", _id);
                return;
            }
            await _module.InvokeVoidAsync("render", _id, config);
        }
        catch { /* charting unavailable — leave the canvas blank */ }
    }

    private object? BuildConfig()
    {
        if (Rows == null || Rows.Count == 0 || string.IsNullOrEmpty(XColumn) || YColumns == null || YColumns.Count == 0)
            return null;

        var palette = new[] { "#2563eb", "#16a34a", "#d97706", "#dc2626", "#7c3aed", "#0891b2", "#db2777" };
        var labels = Rows.Select(r => r.TryGetValue(XColumn!, out var v) ? v?.ToString() ?? "" : "").ToList();

        // "area" is a line chart with the region filled; pie/doughnut color each slice individually.
        var requested = (string.IsNullOrEmpty(ChartType) ? "bar" : ChartType).ToLowerInvariant();
        var isArea = requested == "area";
        var isSlices = requested is "pie" or "doughnut";
        var type = isArea ? "line" : requested;

        var datasets = new List<object>();
        for (int i = 0; i < YColumns.Count; i++)
        {
            var col = YColumns[i];
            var data = Rows.Select(r => ToNumber(r.TryGetValue(col, out var v) ? v : null)).ToList();
            var color = palette[i % palette.Length];
            // Slice charts color each point; bar/line/area use one color per series.
            object bg = isSlices
                ? Rows.Select((_, idx) => palette[idx % palette.Length]).Cast<object>().ToList()
                : color;
            datasets.Add(new
            {
                label = col,
                data,
                backgroundColor = bg,
                borderColor = color,
                borderWidth = 1,
                fill = isArea,
                tension = isArea ? 0.3 : 0,
            });
        }

        return new
        {
            type,
            data = new { labels, datasets },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = true } },
            },
        };
    }

    private static double? ToNumber(object? v)
    {
        if (v == null) return null;
        return v switch
        {
            double d => d,
            decimal m => (double)m,
            int i => i,
            long l => l,
            float f => f,
            _ => double.TryParse(v.ToString(), out var parsed) ? parsed : null,
        };
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module != null)
            {
                await _module.InvokeVoidAsync("destroy", _id);
                await _module.DisposeAsync();
            }
        }
        catch { /* ignore teardown races */ }
    }
}

@page "/data/datasets"
@using System.Net.Http.Json
@using Application.Shared.Enums
@using Application.Shared.Models
@using Application.Shared.Models.Data
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@inject Application.Client.Services.ActivityLogClient _activityLog
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Datasets</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to view datasets.</p>
    </div>
}
else
{
<div class="ds-page">
    <div class="ds-header">
        <div>
            <h1 class="ds-title">Datasets</h1>
            <p class="ds-subtitle">
                @if (!isLoading)
                {
                    <span>@(allItems?.Count ?? 0) dataset@(allItems?.Count == 1 ? "" : "s")</span>
                }
            </p>
        </div>
        @if (canEdit)
        {
        <button class="btn btn-default" @onclick="CreateDataset">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            New Dataset
        </button>
        }
    </div>

    <div class="ds-card">
        <div class="ds-card-toolbar">
            <div class="ds-search-wrap">
                <svg class="ds-search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input class="ds-search" type="search" placeholder="Search datasets..." @bind="searchTerm" @bind:event="oninput" @bind:after="HandleSearch" />
            </div>
        </div>

        @if (isLoading)
        {
            <div class="ds-loading">
                <div class="ds-spinner"></div>
                <span>Loading datasets...</span>
            </div>
        }
        else if (pagedItems?.Any() == true)
        {
            <div class="ds-table-wrap">
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("name")'>
                                <span>Name</span> @SortIcon("name")
                            </th>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("description")'>
                                <span>Description</span> @SortIcon("description")
                            </th>
                            <th class="ds-th">Source Type</th>
                            <th class="ds-th">Source Entity</th>
                            <th class="ds-th">Tables</th>
                            <th class="ds-th">Size</th>
                            <th class="ds-th">Rows</th>
                            <th class="ds-th">Status</th>
                            <th class="ds-th">Shared</th>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("created")'>
                                <span>Created</span> @SortIcon("created")
                            </th>
                            <th class="ds-th ds-th-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dataset in pagedItems)
                        {
                            <tr class="ds-tr ds-tr-clickable" @onclick="() => OpenDataset(dataset)"
                                @oncontextmenu="e => OnRowContextMenu(e, dataset)" @oncontextmenu:preventDefault="true">
                                <td class="ds-td ds-td-name">
                                    <span class="ds-dataset-name">@dataset.Name</span>
                                    @if (IsDefaultDataset(dataset.Id))
                                    {
                                        <span title="Your default dataset" style="margin-left:0.4rem;font-size:0.625rem;font-weight:700;color:#b45309;background:#fef3c7;border-radius:9999px;padding:0.05rem 0.4rem;text-transform:uppercase;letter-spacing:0.03em">Default</span>
                                    }
                                </td>
                                <td class="ds-td">
                                    <span class="ds-dataset-desc">@dataset.Description</span>
                                </td>
                                <td class="ds-td">
                                    @if (dataset.SourceType == DatasetSourceType.External)
                                    {
                                        var info = SourceInfo(dataset.SourceEntityId);
                                        <span style="display:inline-flex;align-items:center;font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:9999px;background:#eef2ff;color:#4f46e5;text-transform:uppercase;letter-spacing:0.03em">
                                            @(info?.DatabaseType.ToString() ?? "External")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:9999px;background:#f4f4f5;color:#71717a;text-transform:uppercase;letter-spacing:0.03em">Local</span>
                                    }
                                </td>
                                <td class="ds-td">
                                    @if (dataset.SourceType == DatasetSourceType.External && !string.IsNullOrEmpty(dataset.SourceEntityId))
                                    {
                                        <a href="@($"/status/entities/{dataset.SourceEntityId}?c={companyId}")"
                                           title="@(SourceInfo(dataset.SourceEntityId)?.Name ?? "Open entity details")"
                                           @onclick:stopPropagation="true"
                                           style="font-size:0.75rem;color:#2563eb;font-family:ui-monospace,Consolas,monospace;text-decoration:none;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block">
                                            @dataset.SourceEntityId
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.75rem;color:#a1a1aa">—</span>
                                    }
                                </td>
                                <td class="ds-td">
                                    @{ var st = StatsFor(dataset.Id); }
                                    @if (st != null) { <span class="ds-stat">@st.TableCount</span> } else { <span class="ds-stat" style="color:#a1a1aa">—</span> }
                                </td>
                                <td class="ds-td">
                                    @if (st != null && st.DatabaseExists) { <span class="ds-stat">@FormatBytes(st.SizeBytes)</span> } else { <span class="ds-stat" style="color:#a1a1aa">—</span> }
                                </td>
                                <td class="ds-td">
                                    @if (st != null) { <span class="ds-stat">@st.TotalRows.ToString("N0")</span> } else { <span class="ds-stat" style="color:#a1a1aa">—</span> }
                                </td>
                                <td class="ds-td">
                                    @if (st != null)
                                    {
                                        var (bg, fg) = StatusColors(st.Status);
                                        <span style="display:inline-flex;align-items:center;font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:9999px;background:@bg;color:@fg;text-transform:uppercase;letter-spacing:0.03em">@st.Status</span>
                                    }
                                    else { <span style="color:#a1a1aa">—</span> }
                                </td>
                                <td class="ds-td">
                                    @if ((st?.SharedWith ?? 0) > 0)
                                    {
                                        <button type="button" title="@($"Shared with {st!.SharedWith} {(st.SharedWith == 1 ? "person" : "people")} — click to manage")"
                                                @onclick="() => OpenSharedWith(dataset)" @onclick:stopPropagation="true"
                                                style="display:inline-flex;align-items:center;gap:0.25rem;font-size:0.75rem;font-weight:500;color:#4f46e5;background:none;border:none;cursor:pointer;padding:0">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                            <span>@st.SharedWith</span>
                                        </button>
                                    }
                                    else { <span style="font-size:0.75rem;color:#a1a1aa">Private</span> }
                                </td>
                                <td class="ds-td ds-td-date">@dataset.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="ds-td ds-td-actions-cell" @onclick:stopPropagation="true">
                                    <div class="ds-actions">
                                        <button class="btn-icon" title="@(IsPinned(dataset.Id) ? "Unpin" : "Pin to top")" @onclick="() => TogglePin(dataset)" style="@(IsPinned(dataset.Id) ? "color:#4f46e5" : "")">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="@(IsPinned(dataset.Id) ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="17" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>
                                        </button>
                                        <button class="btn-icon" title="@(IsDefaultDataset(dataset.Id) ? "Default dataset (click to clear)" : "Set as default")" @onclick="() => ToggleDefault(dataset)" style="@(IsDefaultDataset(dataset.Id) ? "color:#f59e0b" : "")">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="@(IsDefaultDataset(dataset.Id) ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        </button>
                                        <button class="btn-icon" title="More actions" @onclick="e => OpenActionsMenu(e, dataset)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (contextMenuDataset != null)
            {
                var ds = contextMenuDataset;
                <div class="ctx-backdrop" @onclick="CloseContextMenu" @oncontextmenu="CloseContextMenu" @oncontextmenu:preventDefault="true"></div>
                <div class="ctx-menu" style="left:@(contextMenuX)px; top:@(contextMenuY)px;">
                    <button class="ctx-item" @onclick="() => { CloseContextMenu(); _ = TogglePin(ds); }">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="@(IsPinned(ds.Id) ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="17" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>
                        @(IsPinned(ds.Id) ? "Unpin" : "Pin to top")
                    </button>
                    <button class="ctx-item" @onclick="() => { CloseContextMenu(); _ = ToggleDefault(ds); }">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="@(IsDefaultDataset(ds.Id) ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        @(IsDefaultDataset(ds.Id) ? "Clear default" : "Set as default")
                    </button>
                    <div class="ctx-sep"></div>
                    <button class="ctx-item" @onclick="() => { CloseContextMenu(); OpenDataset(ds); }">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                        Open dataset
                    </button>
                    <button class="ctx-item" @onclick="() => { CloseContextMenu(); ShareDataset(ds); }">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                        Share dataset
                    </button>
                    @if (canEdit)
                    {
                        <div class="ctx-sep"></div>
                        <button class="ctx-item" @onclick="() => { CloseContextMenu(); EditDataset(ds); }">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                            Edit dataset
                        </button>
                        <button class="ctx-item ctx-item-danger" @onclick="() => { CloseContextMenu(); _ = DeleteDataset(ds); }">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                            Delete dataset
                        </button>
                    }
                </div>
            }

            @if (totalPages > 1)
            {
                <div class="ds-pagination">
                    <span>Page @(currentPage + 1) of @totalPages</span>
                    <div class="ds-page-btns">
                        <button class="btn-page" disabled="@(currentPage == 0)" @onclick="PrevPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                        </button>
                        @for (int i = 0; i < totalPages; i++)
                        {
                            var pageIndex = i;
                            <button class="btn-page @(currentPage == pageIndex ? "btn-page-active" : "")" @onclick="() => GoToPage(pageIndex)">@(i + 1)</button>
                        }
                        <button class="btn-page" disabled="@(currentPage >= totalPages - 1)" @onclick="NextPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="ds-empty">
                <div class="ds-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
                </div>
                <h3 class="ds-empty-title">No datasets found</h3>
                <p class="ds-empty-sub">
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <span>No datasets match "<strong>@searchTerm</strong>". Try a different search.</span>
                    }
                    else if (string.IsNullOrEmpty(companyId))
                    {
                        <span>Company ID is required to load datasets.</span>
                    }
                    else
                    {
                        <span>Get started by creating your first dataset.</span>
                    }
                </p>
                @if (canEdit && !string.IsNullOrEmpty(companyId) && string.IsNullOrWhiteSpace(searchTerm))
                {
                    <button class="btn btn-default" @onclick="CreateDataset">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Create Dataset
                    </button>
                }
            </div>
        }
    </div>
</div>
}

<ShareDatasetModal IsVisible="@showShareModal"
                   IsVisibleChanged="@((bool value) => showShareModal = value)"
                   DatasetId="@(selectedDatasetForSharing?.Id ?? string.Empty)"
                   DatasetName="@(selectedDatasetForSharing?.Name ?? string.Empty)"
                   CompanyId="@(companyId ?? string.Empty)" />

@if (showSharedModal)
{
    <div class="ds-modal-backdrop" @onclick="() => showSharedModal = false">
        <div class="ds-modal" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Shared with <span style="color:#71717a;font-weight:400">— @sharedDatasetName</span></h2>
                <button class="ds-modal-close" @onclick="() => showSharedModal = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                @if (isLoadingShared)
                {
                    <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
                }
                else if (!sharedUsers.Any())
                {
                    <span class="ds-dataset-desc">This dataset isn't shared with anyone.</span>
                }
                else
                {
                    <p class="ds-hint" style="margin-top:0">People with access to this dataset. Stopping sharing removes their access entirely.</p>
                    @foreach (var u in sharedUsers)
                    {
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;padding:0.65rem 0;border-top:1px solid #f4f4f5">
                            <div>
                                <div style="font-weight:500;color:#18181b">@(string.IsNullOrEmpty(u.Email) ? u.UserId : u.Email)</div>
                                <div style="font-size:0.75rem;color:#a1a1aa">
                                    @u.Type · @(u.Tables.Any() ? $"{u.Tables.Count} table{(u.Tables.Count == 1 ? "" : "s")}" : "All tables")
                                </div>
                            </div>
                            @if (canEdit)
                            {
                                <button class="btn btn-outline" style="color:#b91c1c;border-color:#fecaca"
                                        @onclick="() => StopSharing(u.UserId)"
                                        disabled="@(isRemovingShare || sharedUsers.Count <= 1)"
                                        title="@(sharedUsers.Count <= 1 ? "Can't remove the only person this dataset is shared with." : "Stop sharing with this person")">Stop sharing</button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

<style>
    /* Dark mode: override hardcoded light inline colors */
    [data-theme="dark"] [style*="color:#18181b"]{color:#f3f4f6!important}
    [data-theme="dark"] [style*="color:#71717a"]{color:#9aa1ac!important}
    [data-theme="dark"] [style*="color:#a1a1aa"]{color:#9aa1ac!important}
    [data-theme="dark"] [style*="color:#2563eb"]{color:#93c5fd!important}
    [data-theme="dark"] [style*="color:#4f46e5"]{color:#818cf8!important}
    [data-theme="dark"] [style*="color:#15803d"]{color:#4ade80!important}
    [data-theme="dark"] [style*="color:#a16207"]{color:#fcd34d!important}
    [data-theme="dark"] [style*="color:#b91c1c"]{color:#f87171!important}
    [data-theme="dark"] [style*="background:#eef2ff"]{background:rgba(129,140,248,.15)!important}
    [data-theme="dark"] [style*="background:#f4f4f5"]{background:#1e222b!important}
    [data-theme="dark"] [style*="background:#dcfce7"]{background:rgba(34,197,94,.15)!important}
    [data-theme="dark"] [style*="background:#fef9c3"]{background:rgba(245,158,11,.12)!important}
    [data-theme="dark"] [style*="background:#fee2e2"]{background:rgba(239,68,68,.12)!important}
    [data-theme="dark"] [style*="1px solid #f4f4f5"]{border-color:#23272f!important}
    [data-theme="dark"] [style*="border-color:#fecaca"]{border-color:rgba(239,68,68,.4)!important}
</style>

@code {
    private List<Dataset>? allItems;
    private List<Dataset>? filteredItems;
    private IEnumerable<Dataset>? pagedItems;
    private string searchTerm = string.Empty;
    private string sortField = "name";
    private bool sortAsc = true;
    private int currentPage = 0;
    private const int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((filteredItems?.Count ?? 0) / (double)pageSize);
    private bool canView;
    private bool canEdit;
    private bool isLoading = true;
    private string? companyId;
    private bool showShareModal = false;
    private Dataset? selectedDatasetForSharing;

    // Lookup of connected Database entities (id → name/type) to label external datasets' source.
    private Dictionary<string, DatabaseEntityOptionDto> sourceDbLookup = new();
    private DatabaseEntityOptionDto? SourceInfo(string? id) =>
        !string.IsNullOrEmpty(id) && sourceDbLookup.TryGetValue(id, out var v) ? v : null;

    // Per-dataset stats (table count, size, rows, status) fetched separately so the base list stays fast.
    private Dictionary<string, DatasetStats> statsLookup = new();
    private DatasetStats? StatsFor(string? id) =>
        !string.IsNullOrEmpty(id) && statsLookup.TryGetValue(id, out var v) ? v : null;

    // Per-user pins + default dataset. Pinned datasets float to the top; a star marks the default.
    private HashSet<string> pinnedIds = new(StringComparer.Ordinal);
    private string? defaultDatasetId;
    private bool IsPinned(string? id) => id != null && pinnedIds.Contains(id);
    private bool IsDefaultDataset(string? id) => id != null && id == defaultDatasetId;

    private sealed class DatasetPreferences
    {
        public List<string>? PinnedDatasetIds { get; set; }
        public string? DefaultDatasetId { get; set; }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int u = 0;
        while (size >= 1024 && u < units.Length - 1) { size /= 1024; u++; }
        return $"{size:0.#} {units[u]}";
    }

    private static (string bg, string fg) StatusColors(string status) => status switch
    {
        "In use" => ("#dcfce7", "#15803d"),
        "External" => ("#eef2ff", "#4f46e5"),
        "Empty" => ("#fef9c3", "#a16207"),
        "No database" => ("#fee2e2", "#b91c1c"),
        _ => ("#f4f4f5", "#71717a"),
    };


    [SupplyParameterFromQuery]
    public string? c { get; set; }

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required to view datasets");
            isLoading = false;
            return;
        }
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        // {companyId}_ADMIN is implicitly allowed by HasCompanyRole.
        canView = user.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = user.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }
        await LoadDatasets();
    }

    private async Task LoadDatasets()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
                if (!string.IsNullOrEmpty(c))
                {
                    _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
                    _httpClient.DefaultRequestHeaders.Add("X-Company-Id", c);
                }
            }

            var response = await _httpClient.GetAsync("api/datasets");
            if (response.IsSuccessStatusCode)
            {
                allItems = await response.Content.ReadFromJsonAsync<List<Dataset>>();
                await LoadPreferences();
                ApplyFilterAndSort();

                // Only fetch the database lookup when at least one dataset is external.
                if (allItems?.Any(d => d.SourceType == DatasetSourceType.External) == true)
                    await LoadSourceDatabases();

                await LoadStats();
            }
            else
            {
                _toastService.ShowError($"Failed to load datasets: {response.StatusCode}");
                allItems = [];
                filteredItems = [];
                pagedItems = [];
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading datasets: {ex.Message}");
            allItems = [];
            filteredItems = [];
            pagedItems = [];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadSourceDatabases()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/datasets/source-databases");
            if (response.IsSuccessStatusCode)
            {
                var dbs = await response.Content.ReadFromJsonAsync<List<DatabaseEntityOptionDto>>() ?? new();
                sourceDbLookup = dbs.ToDictionary(d => d.Id, d => d);
                StateHasChanged();
            }
        }
        catch { /* labels just fall back to the entity id / "External" */ }
    }

    // ----- "Shared with" popup -----
    private bool showSharedModal = false;
    private string? sharedDatasetId;
    private string? sharedDatasetName;
    private List<DatasetUserDto> sharedUsers = new();
    private bool isLoadingShared = false;
    private bool isRemovingShare = false;

    private async Task OpenSharedWith(Dataset ds)
    {
        sharedDatasetId = ds.Id;
        sharedDatasetName = ds.Name;
        sharedUsers = new();
        showSharedModal = true;
        isLoadingShared = true;
        StateHasChanged();
        await LoadSharedUsers();
    }

    private async Task LoadSharedUsers()
    {
        if (string.IsNullOrEmpty(sharedDatasetId)) return;
        try
        {
            isLoadingShared = true;
            StateHasChanged();
            var resp = await _httpClient.GetAsync($"api/datasets/{sharedDatasetId}/sharing");
            if (resp.IsSuccessStatusCode)
                sharedUsers = await resp.Content.ReadFromJsonAsync<List<DatasetUserDto>>() ?? new();
            else
                _toastService.ShowError($"Failed to load shares: {resp.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error loading shares: {ex.Message}"); }
        finally { isLoadingShared = false; StateHasChanged(); }
    }

    private async Task StopSharing(string userId)
    {
        if (string.IsNullOrEmpty(sharedDatasetId)) return;
        try
        {
            isRemovingShare = true;
            StateHasChanged();
            var resp = await _httpClient.DeleteAsync($"api/datasets/{sharedDatasetId}/sharing/{userId}");
            if (resp.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Access removed.");
                if (statsLookup.TryGetValue(sharedDatasetId, out var s) && s.SharedWith > 0) s.SharedWith--;
                await LoadSharedUsers();
            }
            else { _toastService.ShowError($"Failed to remove: {await resp.Content.ReadAsStringAsync()}"); }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isRemovingShare = false; StateHasChanged(); }
    }

    private async Task LoadStats()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/datasets/stats");
            if (response.IsSuccessStatusCode)
            {
                var stats = await response.Content.ReadFromJsonAsync<List<DatasetStats>>() ?? new();
                statsLookup = stats.ToDictionary(s => s.DatasetId, s => s);
                StateHasChanged();
            }
        }
        catch { /* stats are supplementary — the list still renders without them */ }
    }

    private void HandleSearch()
    {
        currentPage = 0;
        ApplyFilterAndSort();
        if (!string.IsNullOrWhiteSpace(searchTerm))
            _ = _activityLog.LogAsync(companyId, "dataset.search", "dataset", route: "/data/datasets", details: searchTerm);
    }

    private void SetSort(string field)
    {
        if (sortField == field) sortAsc = !sortAsc;
        else { sortField = field; sortAsc = true; }
        currentPage = 0;
        ApplyFilterAndSort();
        _ = _activityLog.LogAsync(companyId, "dataset.sort", "dataset", route: "/data/datasets",
            details: $"{sortField} {(sortAsc ? "asc" : "desc")}");
    }

    private void ApplyFilterAndSort()
    {
        var query = allItems?.AsEnumerable() ?? [];
        if (!string.IsNullOrWhiteSpace(searchTerm))
            query = query.Where(d =>
                (d.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true) ||
                (d.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true));

        query = sortField switch
        {
            "description" => sortAsc ? query.OrderBy(d => d.Description) : query.OrderByDescending(d => d.Description),
            "created" => sortAsc ? query.OrderBy(d => d.CreatedAt) : query.OrderByDescending(d => d.CreatedAt),
            _ => sortAsc ? query.OrderBy(d => d.Name) : query.OrderByDescending(d => d.Name),
        };

        // Pinned datasets float to the top (OrderByDescending is stable, so the sort above holds within groups).
        filteredItems = query.OrderByDescending(d => d.Id != null && pinnedIds.Contains(d.Id)).ToList();
        pagedItems = filteredItems.Skip(currentPage * pageSize).Take(pageSize);
        StateHasChanged();
    }

    private async Task LoadPreferences()
    {
        try
        {
            var prefs = await _httpClient.GetFromJsonAsync<DatasetPreferences>("api/datasets/preferences");
            pinnedIds = prefs?.PinnedDatasetIds?.ToHashSet(StringComparer.Ordinal) ?? new(StringComparer.Ordinal);
            defaultDatasetId = prefs?.DefaultDatasetId;
        }
        catch { /* preferences are supplementary — the list still renders without them */ }
    }

    private async Task TogglePin(Dataset dataset)
    {
        if (string.IsNullOrEmpty(dataset.Id)) return;
        var pin = !pinnedIds.Contains(dataset.Id);
        try
        {
            var resp = await _httpClient.PutAsync($"api/datasets/{dataset.Id}/pin?pinned={(pin ? "true" : "false")}", null);
            if (resp.IsSuccessStatusCode)
            {
                if (pin) pinnedIds.Add(dataset.Id); else pinnedIds.Remove(dataset.Id);
                ApplyFilterAndSort();
            }
            else _toastService.ShowError("Couldn't update pin.");
        }
        catch (Exception ex) { _toastService.ShowError($"Pin failed: {ex.Message}"); }
    }

    private async Task ToggleDefault(Dataset dataset)
    {
        if (string.IsNullOrEmpty(dataset.Id)) return;
        var clearing = defaultDatasetId == dataset.Id;
        try
        {
            var resp = clearing
                ? await _httpClient.DeleteAsync("api/datasets/default")
                : await _httpClient.PutAsync($"api/datasets/{dataset.Id}/default", null);
            if (resp.IsSuccessStatusCode)
            {
                defaultDatasetId = clearing ? null : dataset.Id;
                _toastService.ShowSuccess(clearing ? "Default cleared." : "Default dataset set.");
                StateHasChanged();
            }
            else _toastService.ShowError("Couldn't update default.");
        }
        catch (Exception ex) { _toastService.ShowError($"Update failed: {ex.Message}"); }
    }

    private RenderFragment SortIcon(string field) => __builder =>
    {
        if (sortField == field)
        {
            if (sortAsc)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            }
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3"><path d="m18 15-6-6-6 6"/></svg>
        }
    };

    private void PrevPage() { if (currentPage > 0) { currentPage--; ApplyFilterAndSort(); } }
    private void NextPage() { if (currentPage < totalPages - 1) { currentPage++; ApplyFilterAndSort(); } }
    private void GoToPage(int page) { currentPage = page; ApplyFilterAndSort(); }

    // ---- Right-click context menu (mirrors the row's own action buttons) ----
    private Dataset? contextMenuDataset;
    private double contextMenuX;
    private double contextMenuY;

    private void OnRowContextMenu(MouseEventArgs e, Dataset dataset)
    {
        contextMenuDataset = dataset;
        contextMenuX = e.ClientX;
        contextMenuY = e.ClientY;
    }

    // Opened from the row's 3-dot button (far right of the row). Anchor the ~200px-wide menu to the
    // button's left so it opens inward and stays on screen, rather than at the click point.
    private void OpenActionsMenu(MouseEventArgs e, Dataset dataset)
    {
        contextMenuDataset = dataset;
        contextMenuX = Math.Max(8, e.ClientX - 200);
        contextMenuY = e.ClientY + 12;
    }

    private void CloseContextMenu() => contextMenuDataset = null;

    private void CreateDataset() => _navigationManager.NavigateTo($"/data/datasets/create?c={companyId}");
    private void OpenDataset(Dataset dataset) => _navigationManager.NavigateTo($"/data/tables?c={companyId}&d={dataset.Id}");
    private void EditDataset(Dataset dataset) => _navigationManager.NavigateTo($"/data/datasets/edit/{dataset.Id}?c={companyId}");
    private void ShareDataset(Dataset dataset) { selectedDatasetForSharing = dataset; showShareModal = true; }

    private async Task DeleteDataset(Dataset dataset)
    {
        if (string.IsNullOrEmpty(dataset.Id))
        {
            _toastService.ShowError("Invalid dataset ID");
            return;
        }
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }
            var response = await _httpClient.DeleteAsync($"api/Datasets/{dataset.Id}");
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Dataset '{dataset.Name}' deleted successfully");
                await LoadDatasets();
            }
            else
            {
                _toastService.ShowError($"Failed to delete dataset: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error deleting dataset: {ex.Message}");
        }
    }
}

<style>
    /* Dataset filter picker */
    .ig-picker { display: flex; align-items: center; gap: 0.5rem; max-width: 640px; }
    .ig-combo { position: relative; flex: 1 1 auto; min-width: 0; }
    .ig-combo-btn {
        display: flex; align-items: center; gap: 0.75rem; width: 100%;
        padding: 0.55rem 0.75rem; background: #fff; border: 1px solid #e4e4e7;
        border-radius: 0.5rem; cursor: pointer; text-align: left; font-family: inherit;
        transition: border-color 0.12s, box-shadow 0.12s;
    }
    .ig-combo-btn:hover { border-color: #d4d4d8; }
    .ig-combo-btn-open { border-color: #18181b; box-shadow: 0 0 0 2px rgba(24,24,27,0.08); }
    .ig-combo-lead { display: flex; align-items: center; gap: 0.6rem; min-width: 0; flex: 1; }
    .ig-combo-caret { color: #a1a1aa; flex-shrink: 0; transition: transform 0.15s; }

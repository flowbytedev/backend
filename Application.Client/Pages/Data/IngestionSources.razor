    .ig-combo-avatar {
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        width: 34px; height: 34px; border-radius: 0.5rem; background: #18181b; color: #fff;
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.02em;
    }
    .ig-combo-avatar-all { background: #eef2ff; color: #4f46e5; }
    .ig-combo-text { display: flex; flex-direction: column; min-width: 0; gap: 1px; }
    .ig-combo-name { font-size: 0.875rem; font-weight: 600; color: #18181b; display: flex; align-items: center; gap: 0.4rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ig-combo-sub { font-size: 0.75rem; color: #a1a1aa; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .ig-combo-tag { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; padding: 0.05rem 0.4rem; border-radius: 9999px; }
    .ig-tag-loc { background: #f0fdf4; color: #16a34a; }
    .ig-tag-ext { background: #eff6ff; color: #2563eb; }

    .ig-combo-backdrop { position: fixed; inset: 0; z-index: 40; }
    .ig-combo-menu {
        position: absolute; top: calc(100% + 6px); left: 0; right: 0; z-index: 50;
        max-height: 380px; overflow-y: auto; padding: 6px;
        background: #fff; border: 1px solid #e4e4e7; border-radius: 0.625rem;
        box-shadow: 0 12px 32px -8px rgba(0,0,0,0.18), 0 2px 6px -2px rgba(0,0,0,0.08);

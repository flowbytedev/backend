    .ig-combo-menu-head { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #a1a1aa; padding: 0.4rem 0.6rem 0.5rem; }
    .ig-combo-item {
        display: flex; align-items: center; gap: 0.6rem; width: 100%;
        padding: 0.5rem 0.6rem; border: none; background: none; cursor: pointer;
        border-radius: 0.5rem; text-align: left; font-family: inherit; transition: background 0.1s;
    }
    .ig-combo-item:hover { background: #f4f4f5; }
    .ig-combo-item-on { background: #f4f4f5; }
    .ig-combo-count {
        margin-left: auto; flex-shrink: 0; min-width: 22px; text-align: center;
        font-size: 0.72rem; font-weight: 700; color: #3f3f46;
        background: #f4f4f5; border: 1px solid #e4e4e7; border-radius: 9999px; padding: 0.1rem 0.45rem;
        font-variant-numeric: tabular-nums;
    }
    .ig-combo-count-zero { color: #a1a1aa; }
    .ig-clear { flex-shrink: 0; white-space: nowrap; }

    /* Dataset link in the table */
    .ig-dslink { border: none; background: none; padding: 0; font: inherit; color: #2563eb; cursor: pointer; font-size: 0.8125rem; }
    .ig-dslink:hover { text-decoration: underline; }

    /* Schedule status badge */
    .ig-status { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.15rem 0.55rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; white-space: nowrap; }
    .ig-status-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .ig-st-active { color: #16a34a; background: #f0fdf4; }
    .ig-st-running { color: #2563eb; background: #eff6ff; }
    .ig-st-running .ig-status-dot { animation: ig-pulse 1.2s ease-in-out infinite; }
    .ig-st-pending { color: #b45309; background: #fffbeb; }
    .ig-st-error { color: #dc2626; background: #fef2f2; }
    .ig-st-paused { color: #71717a; background: #f4f4f5; }
    @@keyframes ig-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* Resume (play) button reads as a positive action */
    .btn-icon-resume { color: #16a34a; }
</style>

@code {
    private List<Dataset> datasets = new();
    private List<string> datasetTables = new();
    private List<IngestionSourceDto>? sources;
    private List<IngestionRunDto>? runs;

    private bool showLogModal = false;
    private string? logModalText;

    private void ViewLog(IngestionRunDto r)
    {
        logModalText = string.IsNullOrWhiteSpace(r.Log) ? "(no log captured for this run)" : r.Log;
        showLogModal = true;
    }

    private bool isLoading = true;
    private bool isLoadingSources = false;
    private bool isSaving = false;
    private bool canView;
    private bool canEdit;
    private string? companyId;
    private string selectedDatasetId = string.Empty;

    private bool showForm = false;
    private string? editingId;
    private string? editingDatasetId;
    private bool editingHasSecret;
    private SaveIngestionSourceRequest form = new();
    private IngestionSourceConfig config = new();
    private string keyColumnsText = string.Empty;
    private string headersText = string.Empty;

    private bool datasetMenuOpen = false;

    private string? expandedRunsId;
    private string? reconcilingId;
    private string? batchQueuingId;
    private string? togglingId;

    // The dataset picker only filters — an empty selection shows every source.
    private IEnumerable<IngestionSourceDto> FilteredSources =>
        (sources ?? Enumerable.Empty<IngestionSourceDto>())
            .Where(s => string.IsNullOrEmpty(selectedDatasetId) || s.DatasetId == selectedDatasetId);

    private int SourceCount(string? datasetId) => sources?.Count(s => s.DatasetId == datasetId) ?? 0;

    private string DatasetName(string? datasetId)
        => datasets.FirstOrDefault(d => d.Id == datasetId)?.Name ?? "Unknown dataset";

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : (parts[0][..1] + parts[1][..1]).ToUpperInvariant();
    }

    [SupplyParameterFromQuery(Name = "c")]
    public string? c { get; set; }

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }

        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }

        try { datasets = await _httpClient.GetFromJsonAsync<List<Dataset>>("api/datasets") ?? new(); }
        catch { datasets = new(); }
        isLoading = false;
        await LoadAllSources();
        _ = _activityLog.LogAsync(companyId, "ingestion.page_open", "ingestion", route: "/data/ingestion");
    }

    private void ToggleDatasetMenu() => datasetMenuOpen = !datasetMenuOpen;

    // The dataset picker is only a filter now — selecting one narrows the list (and enables "New Source").
    private async Task SelectDataset(string id)
    {
        datasetMenuOpen = false;
        selectedDatasetId = id ?? string.Empty;
        showForm = false;
        expandedRunsId = null;
        datasetTables = new();
        if (string.IsNullOrEmpty(selectedDatasetId)) return;

        // Load the target-table suggestions for the create form.
        try { datasetTables = await _httpClient.GetFromJsonAsync<List<string>>($"api/datasets/{selectedDatasetId}/tables") ?? new(); }
        catch { datasetTables = new(); }
    }

    // Loads every source across the company's datasets; the dataset picker filters this client-side.
    private async Task LoadAllSources()
    {
        try
        {
            isLoadingSources = true;
            StateHasChanged();
            sources = await _httpClient.GetFromJsonAsync<List<IngestionSourceDto>>("api/ingestion") ?? new();
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Failed to load sources: {ex.Message}");
            sources = new();
        }
        finally { isLoadingSources = false; StateHasChanged(); }
    }

    private void StartCreate()
    {
        editingId = null;
        editingHasSecret = false;
        form = new SaveIngestionSourceRequest { CronExpression = "0 * * * *", IsEnabled = true, SourceKind = "ExternalDatabase", ImportMode = "Append" };
        config = new IngestionSourceConfig { Method = "GET", AuthType = "none" };
        keyColumnsText = string.Empty;
        headersText = string.Empty;
        showForm = true;
    }

    // Loads an AI-proposed draft into the normal create form so the user reviews every field (and enters
    // the secret) before saving through the existing create endpoint. Never persists directly.
    private void ApplyDraft(IngestionDraft draft)
    {
        editingId = null;
        editingHasSecret = false;
        form = new SaveIngestionSourceRequest
        {
            Name = draft.Name ?? string.Empty,
            Description = draft.Description,
            TargetTable = draft.TargetTable ?? string.Empty,
            SourceKind = string.IsNullOrWhiteSpace(draft.SourceKind) ? "ExternalDatabase" : draft.SourceKind,
            SourceEntityId = draft.SourceEntityId,
            ImportMode = string.IsNullOrWhiteSpace(draft.ImportMode) ? "Append" : draft.ImportMode,
            CreateIfNotExists = draft.CreateIfNotExists,
            IncrementalColumn = draft.IncrementalColumn,
            CronExpression = string.IsNullOrWhiteSpace(draft.CronExpression) ? "0 * * * *" : draft.CronExpression,
            TimeZone = draft.TimeZone,
            IsEnabled = draft.IsEnabled,
            Secret = null,
        };
        config = draft.Config ?? new IngestionSourceConfig();
        if (string.IsNullOrWhiteSpace(config.Method)) config.Method = "GET";
        if (string.IsNullOrWhiteSpace(config.AuthType)) config.AuthType = "none";
        keyColumnsText = string.Join(", ", draft.KeyColumns ?? new());
        headersText = config.Headers == null ? "" : string.Join("\n", config.Headers.Select(h => $"{h.Key}: {h.Value}"));

        showForm = true;
        _toastService.ShowInfo("Draft loaded — review the fields and enter any secret before saving.");
    }

    private void StartEdit(IngestionSourceDto s)
    {
        editingId = s.Id;
        editingDatasetId = s.DatasetId;
        editingHasSecret = s.HasSecret;
        form = new SaveIngestionSourceRequest
        {
            TargetTable = s.TargetTable,
            Name = s.Name,
            Description = s.Description,
            SourceKind = s.SourceKind,
            SourceEntityId = s.SourceEntityId,
            ImportMode = s.ImportMode,
            CreateIfNotExists = s.CreateIfNotExists,
            IncrementalColumn = s.IncrementalColumn,
            CronExpression = s.CronExpression,
            TimeZone = s.TimeZone,
            IsEnabled = s.IsEnabled,
            Secret = null
        };
        config = s.Config ?? new IngestionSourceConfig();
        keyColumnsText = string.Join(", ", s.KeyColumns ?? new());
        headersText = config.Headers == null ? "" : string.Join("\n", config.Headers.Select(h => $"{h.Key}: {h.Value}"));
        showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(form.Name) || string.IsNullOrWhiteSpace(form.TargetTable))
        {
            _toastService.ShowWarning("Name and target table are required");
            return;
        }

        // Parse headers text into the config.
        if (form.SourceKind == "Rest")
        {
            config.Headers = ParseHeaders(headersText);
        }
        form.Config = config;
        form.KeyColumns = string.IsNullOrWhiteSpace(keyColumnsText)
            ? new()
            : keyColumnsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        // Empty string means "no change"; send null so the stored secret is kept.
        if (string.IsNullOrEmpty(form.Secret)) form.Secret = null;

        try
        {
            isSaving = true;
            // Create targets the currently-filtered dataset; edit keeps the source's own dataset.
            var datasetForSave = editingId == null ? selectedDatasetId : editingDatasetId;
            HttpResponseMessage response = editingId == null
                ? await _httpClient.PostAsJsonAsync($"api/datasets/{datasetForSave}/ingestion", form)
                : await _httpClient.PutAsJsonAsync($"api/datasets/{datasetForSave}/ingestion/{editingId}", form);

            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess(editingId == null ? "Source created" : "Source updated");
                showForm = false;
                await LoadAllSources();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to save source: {msg}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving source: {ex.Message}"); }
        finally { isSaving = false; }
    }

    private async Task Pause(IngestionSourceDto s) => await SetEnabled(s, false);
    private async Task Resume(IngestionSourceDto s) => await SetEnabled(s, true);

    private async Task SetEnabled(IngestionSourceDto s, bool enabled)
    {
        try
        {
            togglingId = s.Id;
            StateHasChanged();
            var verb = enabled ? "resume" : "pause";
            var response = await _httpClient.PostAsync($"api/datasets/{s.DatasetId}/ingestion/{s.Id}/{verb}", null);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess(enabled ? $"{s.Name} resumed" : $"{s.Name} paused");
                await LoadAllSources();
            }
            else
            {
                _toastService.ShowError($"Failed to {verb}: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error updating schedule: {ex.Message}"); }
        finally { togglingId = null; StateHasChanged(); }
    }

    // Compact display of a long id (run/job) — first 8 chars; the full value is on the cell's title.
    private static string Short(string? id) => string.IsNullOrEmpty(id) ? "—" : (id.Length <= 10 ? id : id[..8] + "…");

    private async Task RunBatch(IngestionSourceDto s)
    {
        try
        {
            batchQueuingId = s.Id;
            StateHasChanged();
            var response = await _httpClient.PostAsync($"api/datasets/{s.DatasetId}/ingestion/{s.Id}/run-batch", null);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"{s.Name} queued — it will run in the background (requires the scheduler to be running).");
            }
            else if ((int)response.StatusCode == 503)
            {
                _toastService.ShowError(await response.Content.ReadAsStringAsync());
            }
            else
            {
                _toastService.ShowError($"Failed to queue: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error queueing batch run: {ex.Message}"); }
        finally { batchQueuingId = null; StateHasChanged(); }
    }

    private async Task ReconcileRuns(IngestionSourceDto s)
    {
        try
        {
            reconcilingId = s.Id;
            StateHasChanged();
            var response = await _httpClient.PostAsync($"api/datasets/{s.DatasetId}/ingestion/{s.Id}/runs/reconcile", null);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Stuck run(s) marked as failed");
                await LoadAllSources();
                if (expandedRunsId == s.Id) await LoadRuns(s);
            }
            else
            {
                _toastService.ShowError($"Failed to reconcile: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error reconciling runs: {ex.Message}"); }
        finally { reconcilingId = null; StateHasChanged(); }
    }

    private async Task DeleteSource(IngestionSourceDto s)
    {
        try
        {
            var response = await _httpClient.DeleteAsync($"api/datasets/{s.DatasetId}/ingestion/{s.Id}");
            if (response.IsSuccessStatusCode) { _toastService.ShowSuccess("Source deleted"); await LoadAllSources(); }
            else _toastService.ShowError($"Failed to delete: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting source: {ex.Message}"); }
    }

    private async Task ToggleRuns(IngestionSourceDto s)
    {
        if (expandedRunsId == s.Id) { expandedRunsId = null; return; }
        expandedRunsId = s.Id;
        runs = null;
        await LoadRuns(s);
    }

    private async Task LoadRuns(IngestionSourceDto s)
    {
        try { runs = await _httpClient.GetFromJsonAsync<List<IngestionRunDto>>($"api/datasets/{s.DatasetId}/ingestion/{s.Id}/runs") ?? new(); }
        catch { runs = new(); }
    }

    private static Dictionary<string, string>? ParseHeaders(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var dict = new Dictionary<string, string>();
        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var idx = line.IndexOf(':');
            if (idx > 0) dict[line.Substring(0, idx).Trim()] = line.Substring(idx + 1).Trim();
        }
        return dict.Count > 0 ? dict : null;
    }

    private string SecretHint() => form.SourceKind switch
    {
        "Rest" => "bearer token or basic password",
        "Blob" => "connection string or SAS URL",
        "Sftp" => "password",
        _ => "optional"
    };

    private static string KindLabel(string kind) => kind switch
    {
        "ExternalDatabase" => "Database",
        "Rest" => "REST API",
        "Blob" => "Blob",
        "Sftp" => "SFTP",
        _ => kind
    };

    private RenderFragment FileFormatSelect() => __builder =>
    {
        <select class="ds-select" @bind="config.FileFormat">
            <option value="">Auto (by extension)</option>
            <option value="Csv">CSV</option>
            <option value="Tsv">TSV</option>
            <option value="Json">JSON</option>
            <option value="Parquet">Parquet</option>
            <option value="Excel">Excel</option>
        </select>
    };

    private RenderFragment StatusBadge(IngestionSourceDto s) => __builder =>
    {
        var (cls, label) = s.Status switch
        {
            "Active" => ("ig-st-active", "Active"),
            "Running" => ("ig-st-running", "Running"),
            "Pending" => ("ig-st-pending", "Pending"),
            "Error" => ("ig-st-error", "Error"),
            _ => ("ig-st-paused", "Paused"),
        };
        var title = s.Status switch
        {
            "Active" => s.NextRunAt.HasValue ? $"Next run {s.NextRunAt.Value.ToLocalTime():MMM dd, HH:mm}" : "Running on schedule",
            "Pending" => "Enabled, but not yet registered with the scheduler (is it running?)",
            "Error" => s.LastRunMessage ?? "The last run failed",
            "Running" => "A run is in progress",
            _ => "Paused — not running on schedule",
        };
        <span class="ig-status @cls" title="@title"><span class="ig-status-dot"></span>@label</span>
    };

    private RenderFragment RunBadge(IngestionSourceDto s) => __builder =>
    {
        if (string.IsNullOrEmpty(s.LastRunStatus))
        {
            <span class="ds-dataset-desc">Never run</span>
        }
        else
        {
            var color = s.LastRunStatus == "Success" ? "#16a34a" : s.LastRunStatus == "Failed" ? "#dc2626" : "#71717a";
            <span title="@(s.LastRunAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm"))"
                  style="@($"display:inline-block;padding:0.125rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:600;color:{color};background:{color}1a")">
                @s.LastRunStatus
            </span>
        }
    };
}

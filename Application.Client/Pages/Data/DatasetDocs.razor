@page "/data/docs"
@using System.Net.Http.Json
@using Application.Shared.Models
@using Application.Shared.Models.Data
@using Application.Shared.Enums
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DataAdminAccess)]

<PageTitle>Data Documentation</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to view dataset documentation.</p>
    </div>
}
else
{
<div class="dd-page">
    <div class="dd-header">
        <div>
            <h1 class="dd-title">Data Documentation</h1>
            <p class="dd-subtitle">Describe your columns — what each one means, its type/unit, and whether it holds personal data. Generate a first draft with AI, then edit.</p>
        </div>
        @if (canEdit && !string.IsNullOrEmpty(selectedTable))
        {
            <div class="dd-actions">
                <button class="btn btn-secondary" @onclick="Generate" disabled="@(generating || saving)">
                    @if (generating)
                    {
                        <span class="ds-spinner"></span> <span>Generating…</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.9L19 9.8l-4.1 3.2L16 18l-4-3-4 3 1.1-5L5 9.8l5.1-1.9z"/></svg>
                        <span>Generate with AI</span>
                    }
                </button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(saving || generating)">
                    @if (saving) { <span class="ds-spinner"></span> <span>Saving…</span> } else { <span>Save</span> }
                </button>
            </div>
        }
    </div>

    <div class="dd-pickers">
        <DatasetTablePicker CompanyId="@(companyId ?? string.Empty)"
                            UserId="@userId"
                            TableLabel="Table"
                            ShowDocsBadge="true"
                            @bind-DatasetId="selectedDatasetId"
                            @bind-DatasetId:after="OnDatasetPicked"
                            @bind-TableName="selectedTable"
                            @bind-TableName:after="OnTablePicked"
                            @bind-SnapshotMode="snapshotMode"
                            @bind-SnapshotMode:after="OnModePicked" />
    </div>

    @if (loadingDocs)
    {
        <div class="dd-loading"><span class="ds-spinner"></span> Loading columns…</div>
    }
    else if (doc != null && doc.Columns.Count > 0)
    {
        <div class="dd-table-wrap">
            <table class="dd-table">
                <thead>
                    <tr>
                        <th>Column</th>
                        <th>Type</th>
                        <th>Display name</th>
                        <th>Description</th>
                        <th>Semantic type</th>
                        <th>Unit</th>
                        <th class="dd-pii">PII</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in doc.Columns)
                    {
                        <tr>
                            <td class="dd-colname">
                                @col.ColumnName
                                @if (col.IsAiGenerated) { <span class="dd-badge" title="AI-generated — review and edit">AI</span> }
                            </td>
                            <td class="dd-type">@col.DataType</td>
                            <td><input class="ds-input dd-in" @bind="col.DisplayName" disabled="@(!canEdit)" /></td>
                            <td><input class="ds-input dd-in" @bind="col.Description" disabled="@(!canEdit)" /></td>
                            <td><input class="ds-input dd-in dd-narrow" @bind="col.SemanticType" disabled="@(!canEdit)" /></td>
                            <td><input class="ds-input dd-in dd-narrow" @bind="col.Unit" disabled="@(!canEdit)" /></td>
                            <td class="dd-pii">
                                <input type="checkbox" @bind="col.IsPii" disabled="@(!canEdit)" />
                                @if (col.IsPii)
                                {
                                    <input class="ds-input dd-in dd-narrow" placeholder="type" @bind="col.PiiType" disabled="@(!canEdit)" />
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (!string.IsNullOrEmpty(selectedTable))
    {
        <div class="dd-empty">This table has no columns to document.</div>
    }
    else
    {
        <div class="dd-empty">Pick a dataset and table to view and document its columns.</div>
    }
</div>
}

@code {
    [SupplyParameterFromQuery(Name = "c")]
    public string? c { get; set; }

    // Optional deep-link from the Tables page: preselect dataset + table and load docs immediately.
    [SupplyParameterFromQuery(Name = "d")]
    public string? d { get; set; }

    [SupplyParameterFromQuery(Name = "t")]
    public string? t { get; set; }

    // Optional deep-link mode: "false" opens on the live Source layer (external datasets), else Snapshot.
    [SupplyParameterFromQuery(Name = "snapshot")]
    public bool? snapshot { get; set; }

    private string? companyId;
    private string? userId;
    private bool isLoading = true;
    private bool canView, canEdit;

    private string selectedDatasetId = string.Empty;
    private string selectedTable = string.Empty;

    // For External datasets: true documents the DuckDB snapshot, false documents the live source. Local
    // datasets only have a DuckDB layer, so this stays true (and the toggle is hidden). The picker owns the
    // Source/Snapshot toggle and keeps this in sync via @bind-SnapshotMode.
    private bool snapshotMode = true;
    private string SnapshotFlag => snapshotMode ? "true" : "false";

    private TableDocDto? doc;
    private bool loadingDocs, generating, saving;

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.HasCompanyRole(companyId, "DATA_ADMIN");
        canEdit = authState.User.HasCompanyRole(companyId, "DATA_ADMIN");
        if (!canView) { isLoading = false; return; }

        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }

        isLoading = false;

        // Deep link from the Tables page: preselect the dataset + table (the picker loads its own lists) and
        // load docs right away. The Tables page passes ?snapshot=false when the table was chosen from an
        // external dataset's live Source view, so the picker opens on Source and selects that table.
        if (!string.IsNullOrEmpty(d))
        {
            selectedDatasetId = d;
            snapshotMode = snapshot ?? true;
            if (!string.IsNullOrEmpty(t))
            {
                selectedTable = t;
                await LoadDocs();
            }
        }
    }

    // The picker owns dataset/table/mode selection and keeps the bound fields in sync; these :after hooks
    // just react. Changing the dataset or mode clears the table (via the picker) and any loaded docs.
    private void OnDatasetPicked() => doc = null;

    private void OnModePicked() => doc = null;

    private async Task OnTablePicked()
    {
        doc = null;
        if (!string.IsNullOrEmpty(selectedTable))
            await LoadDocs();
    }

    private async Task LoadDocs()
    {
        loadingDocs = true;
        StateHasChanged();
        try
        {
            doc = await _httpClient.GetFromJsonAsync<TableDocDto>($"api/datasets/{selectedDatasetId}/tables/{Uri.EscapeDataString(selectedTable)}/docs?snapshot={SnapshotFlag}");
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Failed to load columns: {ex.Message}");
            doc = null;
        }
        finally { loadingDocs = false; StateHasChanged(); }
    }

    private async Task Generate()
    {
        if (string.IsNullOrEmpty(selectedTable)) return;
        generating = true;
        StateHasChanged();
        try
        {
            var response = await _httpClient.PostAsync($"api/datasets/{selectedDatasetId}/tables/{Uri.EscapeDataString(selectedTable)}/docs/generate?snapshot={SnapshotFlag}", null);
            if (response.IsSuccessStatusCode)
            {
                doc = await response.Content.ReadFromJsonAsync<TableDocDto>();
                _toastService.ShowSuccess("AI documentation generated — review and save.");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Generation failed ({(int)response.StatusCode}): {body}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Generation error: {ex.Message}");
        }
        finally { generating = false; StateHasChanged(); }
    }

    private async Task Save()
    {
        if (doc == null) return;
        saving = true;
        StateHasChanged();
        try
        {
            var edits = doc.Columns.Select(c => new SaveColumnDocRequest
            {
                ColumnName = c.ColumnName,
                DisplayName = c.DisplayName,
                Description = c.Description,
                SemanticType = c.SemanticType,
                Unit = c.Unit,
                IsPii = c.IsPii,
                PiiType = c.PiiType,
            }).ToList();

            var response = await _httpClient.PutAsJsonAsync($"api/datasets/{selectedDatasetId}/tables/{Uri.EscapeDataString(selectedTable)}/docs?snapshot={SnapshotFlag}", edits);
            if (response.IsSuccessStatusCode)
            {
                doc = await response.Content.ReadFromJsonAsync<TableDocDto>();
                _toastService.ShowSuccess("Documentation saved.");
            }
            else
            {
                _toastService.ShowError($"Save failed ({(int)response.StatusCode}).");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Save error: {ex.Message}");
        }
        finally { saving = false; StateHasChanged(); }
    }
}

<style>
    .dd-page { padding: 1.25rem 1.5rem; }
    .dd-header { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1rem; }
    .dd-title { margin:0; font-size:1.25rem; font-weight:700; color:#18181b; }
    .dd-subtitle { margin:0.2rem 0 0; font-size:0.85rem; color:#71717a; max-width:60ch; }
    .dd-actions { display:flex; gap:0.5rem; flex-shrink:0; }
    .dd-pickers { display:flex; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
    .dd-field { display:flex; flex-direction:column; gap:0.25rem; min-width:240px; }
    .dd-label { font-size:0.75rem; font-weight:600; color:#52525b; }
    .dd-seg { display:flex; border:1px solid #e4e4e7; border-radius:8px; overflow:hidden; width:fit-content; }
    .dd-seg-btn { padding:0.45rem 0.85rem; font-size:0.8125rem; font-weight:600; color:#52525b; background:#fff; border:none; cursor:pointer; }
    .dd-seg-btn + .dd-seg-btn { border-left:1px solid #e4e4e7; }
    .dd-seg-active { background:#eff6ff; color:#2563eb; }
    .dd-loading, .dd-empty { padding:2rem; text-align:center; color:#71717a; font-size:0.875rem; }
    .dd-table-wrap { overflow:auto; border:1px solid #e4e4e7; border-radius:10px; }
    .dd-table { width:100%; border-collapse:collapse; font-size:0.8125rem; }
    .dd-table thead th { text-align:left; padding:0.55rem 0.6rem; background:#fafafa; border-bottom:1px solid #e4e4e7; font-weight:600; color:#52525b; white-space:nowrap; }
    .dd-table tbody td { padding:0.35rem 0.6rem; border-bottom:1px solid #f4f4f5; vertical-align:top; }
    .dd-colname { font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-weight:600; color:#27272a; white-space:nowrap; }
    .dd-type { color:#71717a; white-space:nowrap; }
    .dd-badge { display:inline-block; margin-left:0.35rem; font-size:0.65rem; font-weight:700; color:#3730a3; background:#e0e7ff; border-radius:4px; padding:0.05rem 0.3rem; vertical-align:middle; }
    .dd-in { width:100%; min-width:120px; }
    .dd-narrow { min-width:90px; }
    .dd-pii { white-space:nowrap; }
    .dd-pii input[type=checkbox] { margin-right:0.35rem; }

    /* ---- Dark mode ---- */
    [data-theme="dark"] .dd-title { color:#f3f4f6; }
    [data-theme="dark"] .dd-subtitle { color:#9aa1ac; }
    [data-theme="dark"] .dd-label { color:#9aa1ac; }
    [data-theme="dark"] .dd-seg { border-color:#2b303b; }
    [data-theme="dark"] .dd-seg-btn { background:#181a20; color:#9aa1ac; }
    [data-theme="dark"] .dd-seg-btn + .dd-seg-btn { border-left-color:#2b303b; }
    [data-theme="dark"] .dd-seg-active { background:rgba(37,99,235,0.18); color:#93c5fd; }
    [data-theme="dark"] .dd-loading, [data-theme="dark"] .dd-empty { color:#9aa1ac; }
    [data-theme="dark"] .dd-table-wrap { border-color:#2b303b; }
    [data-theme="dark"] .dd-table thead th { background:#1e222b; border-bottom-color:#2b303b; color:#9aa1ac; }
    [data-theme="dark"] .dd-table tbody td { border-bottom-color:#23272f; color:#e6e9ef; }
    [data-theme="dark"] .dd-colname { color:#e6e9ef; }
    [data-theme="dark"] .dd-type { color:#9aa1ac; }
    [data-theme="dark"] .dd-badge { color:#a5b4fc; background:rgba(99,102,241,.15); }
</style>

    private async Task MoveTableSubmit()
    {
        if (string.IsNullOrWhiteSpace(moveTargetDatasetId))
        {
            _toastService.ShowWarning("Select a destination dataset");
            return;
        }
        try
        {
            isMovingTable = true;
            StateHasChanged();
            await SetUserHeaderAsync();

            var targetName = allDatasets.FirstOrDefault(d => d.Id == moveTargetDatasetId)?.Name ?? moveTargetDatasetId;
            var request = new MoveTableRequest { TargetDatasetId = moveTargetDatasetId };
            var response = await _httpClient.PostAsJsonAsync($"api/Datasets/{datasetId}/tables/{moveTableName}/move", request);

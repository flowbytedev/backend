    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int u = 0;
        while (size >= 1024 && u < units.Length - 1) { size /= 1024; u++; }
        return $"{size:0.#} {units[u]}";
    }

    // Pill colors for an ingestion source's last-run status (paused overrides status).
    private static (string bg, string fg) IngestionColors(string? status, bool enabled)
    {
        if (!enabled) return ("#f4f4f5", "#71717a");
        return (status?.ToLowerInvariant()) switch
        {
            "success" or "succeeded" or "completed" => ("#dcfce7", "#15803d"),
            "failed" or "error" => ("#fee2e2", "#b91c1c"),
            "running" => ("#dbeafe", "#1d4ed8"),
            _ => ("#eef2ff", "#4f46e5"),
        };
    }

    private static string RelativeTime(DateTime? utc)
    {
        if (!utc.HasValue) return "never";
        var span = DateTime.UtcNow - utc.Value;
        if (span.TotalSeconds < 60) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays}d ago";
        if (span.TotalDays < 365) return $"{(int)(span.TotalDays / 30)}mo ago";
        return $"{(int)(span.TotalDays / 365)}y ago";
    }

    private List<string>? tables;
    private List<string>? filteredItems;
    private IEnumerable<string>? pagedItems;
    private string searchTerm = string.Empty;
    private bool sortAsc = true;
    private int currentPage = 0;
    private const int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((filteredItems?.Count ?? 0) / (double)pageSize);
    private bool isLoading = true;
    private string? companyId;
    private string? datasetId;
    private string? datasetName;
    private bool dbExists = true;       // assume present until checked, so the button doesn't flash
    private bool isCreatingDb = false;

    // External datasets can be viewed as the live Source or the saved Snapshot; local datasets are always
    // the (DuckDB) snapshot, so the toggle is hidden for them.
    private bool isExternal;
    private bool snapshotMode = true;
    private bool modeInitialized;
    // Viewing an external dataset's live source tables is limited to data admins ({companyId}_DATA_ADMIN)
    // and company admins; everyone else only ever sees the local DuckDB snapshot.
    private bool canViewSource;

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        datasetId = d;

        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required to view tables");
            isLoading = false;
            return;
        }
        if (string.IsNullOrEmpty(datasetId))
        {
            _toastService.ShowWarning("Dataset ID is required to view tables");
            isLoading = false;
            return;
        }
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        canView = user.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = user.HasCompanyRole(companyId, "EDIT_DATA");
        canViewSource = user.HasCompanyRole(companyId, "DATA_ADMIN");
        if (!canView) { isLoading = false; return; }
        await CheckDatabaseAsync();
        await LoadTables();
    }

    private async Task SetUserHeaderAsync()
    {
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _httpClient.DefaultRequestHeaders.Remove("UserId");
                _httpClient.DefaultRequestHeaders.Add("UserId", userId);
            }
        }
        if (!string.IsNullOrEmpty(companyId))
        {
            _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
            _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);
        }
    }

    private async Task CheckDatabaseAsync()
    {
        try
        {
            await SetUserHeaderAsync();
            var resp = await _httpClient.GetAsync($"api/Datasets/{datasetId}/database-exists");
            if (resp.IsSuccessStatusCode)
                dbExists = await resp.Content.ReadFromJsonAsync<bool>();
        }
        catch { /* on error, leave dbExists as-is (assume present) */ }
    }

    private async Task CreateDatabase()
    {
        try
        {
            isCreatingDb = true;
            StateHasChanged();

            await SetUserHeaderAsync();
            var resp = await _httpClient.PostAsync($"api/Datasets/{datasetId}/database", null);
            if (resp.IsSuccessStatusCode)
            {
                dbExists = true;
                _toastService.ShowSuccess("Dataset database created.");
                await LoadTables();
            }
            else
            {
                _toastService.ShowError($"Failed to create database: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error creating database: {ex.Message}");
        }
        finally
        {
            isCreatingDb = false;
            StateHasChanged();
        }
    }

    private async Task SetMode(bool snapshot)
    {
        if (snapshotMode == snapshot) return;
        snapshotMode = snapshot;
        currentPage = 0;
        searchTerm = string.Empty;
        await LoadTables();
    }

    private async Task LoadTables()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // Set BOTH the UserId and X-Company-Id headers before any fetch. On a direct page refresh
            // (deep link) this is the first request on a fresh HttpClient, so the company header must be
            // set here — otherwise the API rejects the request and the table list fails to load.
            await SetUserHeaderAsync();

            var datasetResponse = await _httpClient.GetAsync($"api/Datasets/{datasetId}");
            if (datasetResponse.IsSuccessStatusCode)
            {
                var dataset = await datasetResponse.Content.ReadFromJsonAsync<Dataset>();
                datasetName = dataset?.Name;
                isExternal = dataset?.SourceType == DatasetSourceType.External;
                // Default external datasets to the live Source view for data admins; local datasets — and
                // users without source access — stay on the Snapshot (DuckDB) view.
                if (!modeInitialized) { snapshotMode = !isExternal || !canViewSource; modeInitialized = true; }
            }

            // Source mode lists the external database's live tables; snapshot mode lists the DuckDB tables.
            var tablesUrl = (isExternal && !snapshotMode)
                ? $"api/Datasets/{datasetId}/source-tables"
                : $"api/Datasets/{datasetId}/tables";
            var response = await _httpClient.GetAsync(tablesUrl);
            if (response.IsSuccessStatusCode)
            {
                tables = await response.Content.ReadFromJsonAsync<List<string>>();
                await LoadTablePins();
                ApplyFilterAndSort();
                await LoadTableStats();
                await LoadDocumentedTables();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                // No tables yet (e.g. empty or not-yet-created database) — show the empty state, not an error.
                tables = [];
                ApplyFilterAndSort();
            }
            else
            {
                _toastService.ShowError($"Failed to load tables: {response.StatusCode}");
                tables = [];
                filteredItems = [];
                pagedItems = [];
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading tables: {ex.Message}");
            tables = [];
            filteredItems = [];
            pagedItems = [];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadTableStats()
    {
        try
        {
            await SetUserHeaderAsync();
            var response = await _httpClient.GetAsync($"api/Datasets/{datasetId}/tables/stats");
            if (response.IsSuccessStatusCode)
            {
                var stats = await response.Content.ReadFromJsonAsync<List<TableStats>>() ?? new();
                tableStats = stats.ToDictionary(s => s.TableName, s => s);
                StateHasChanged();
            }
        }
        catch { /* stats are supplementary — the table list still renders without them */ }
    }

    // Names of tables that already have column docs for the current view (source layer when viewing an
    // external dataset's live source, otherwise the DuckDB snapshot) — used to badge them "DOCS".
    private async Task LoadDocumentedTables()
    {
        try
        {
            await SetUserHeaderAsync();
            var snap = (isExternal && !snapshotMode) ? "false" : "true";
            var names = await _httpClient.GetFromJsonAsync<List<string>>(
                $"api/Datasets/{datasetId}/documented-tables?snapshot={snap}");
            documentedTables = names?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new(StringComparer.OrdinalIgnoreCase);
            StateHasChanged();
        }
        catch { /* doc badges are supplementary — the table list still renders without them */ }
    }

    private void HandleSearch()
    {
        currentPage = 0;
        ApplyFilterAndSort();
        if (!string.IsNullOrWhiteSpace(searchTerm))
            _ = _activityLog.LogAsync(companyId, "table.search", "table", datasetId, route: "/data/tables", details: searchTerm);
    }

    private void ToggleSort()
    {
        sortAsc = !sortAsc;
        ApplyFilterAndSort();
        _ = _activityLog.LogAsync(companyId, "table.sort", "table", datasetId, route: "/data/tables",
            details: sortAsc ? "asc" : "desc");
    }

    private void ApplyFilterAndSort()
    {
        var query = tables?.AsEnumerable() ?? [];
        if (!string.IsNullOrWhiteSpace(searchTerm))
            query = query.Where(t => t.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        query = sortAsc ? query.OrderBy(t => t) : query.OrderByDescending(t => t);
        // Pinned tables float to the top (OrderByDescending is stable, so the name sort holds within groups).
        filteredItems = query.OrderByDescending(t => pinnedTables.Contains(t)).ToList();
        pagedItems = filteredItems.Skip(currentPage * pageSize).Take(pageSize);
        StateHasChanged();
    }

    // Per-user table pins (float to the top of the list).
    private HashSet<string> pinnedTables = new(StringComparer.OrdinalIgnoreCase);
    private bool IsTablePinned(string name) => pinnedTables.Contains(name);

    private async Task LoadTablePins()
    {
        try
        {
            var pins = await _httpClient.GetFromJsonAsync<List<string>>($"api/datasets/{datasetId}/table-pins");
            pinnedTables = pins?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new(StringComparer.OrdinalIgnoreCase);
        }
        catch { /* pins are supplementary — the list still renders without them */ }
    }

    private async Task ToggleTablePin(string tableName)
    {
        var pin = !pinnedTables.Contains(tableName);
        try
        {
            var resp = await _httpClient.PutAsync(
                $"api/datasets/{datasetId}/tables/{Uri.EscapeDataString(tableName)}/pin?pinned={(pin ? "true" : "false")}", null);
            if (resp.IsSuccessStatusCode)
            {
                if (pin) pinnedTables.Add(tableName); else pinnedTables.Remove(tableName);
                ApplyFilterAndSort();
            }
            else _toastService.ShowError("Couldn't update pin.");
        }
        catch (Exception ex) { _toastService.ShowError($"Pin failed: {ex.Message}"); }
    }

    private void PrevPage() { if (currentPage > 0) { currentPage--; ApplyFilterAndSort(); } }
    private void NextPage() { if (currentPage < totalPages - 1) { currentPage++; ApplyFilterAndSort(); } }
    private void GoToPage(int page) { currentPage = page; ApplyFilterAndSort(); }


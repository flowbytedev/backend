@code {
    [SupplyParameterFromQuery] public string? c { get; set; }
    [SupplyParameterFromQuery] public string? d { get; set; }

    // ----- "Shared with" popup (per table) -----
    private bool showSharedModal = false;
    private string sharedTableName = string.Empty;
    private List<DatasetUserDto> sharedTableUsers = new();
    private bool isLoadingShared = false;
    private bool isRemovingShare = false;

    private async Task OpenSharedWith(string tableName)
    {
        sharedTableName = tableName;
        sharedTableUsers = new();
        showSharedModal = true;
        isLoadingShared = true;
        StateHasChanged();
        await LoadSharedTableUsers();
    }

    private async Task LoadSharedTableUsers()
    {
        try
        {
            isLoadingShared = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var all = await _httpClient.GetFromJsonAsync<List<DatasetUserDto>>($"api/datasets/{datasetId}/sharing") ?? new();
            // People who can reach this table: full-dataset users + users scoped to it.
            sharedTableUsers = all.Where(u => u.Tables.Count == 0 || u.Tables.Contains(sharedTableName)).ToList();
        }
        catch (Exception ex) { _toastService.ShowError($"Error loading shares: {ex.Message}"); }
        finally { isLoadingShared = false; StateHasChanged(); }
    }

    private Task StopSharingTable(string userId)
        => RemoveShare($"api/datasets/{datasetId}/sharing/{userId}/tables/{Uri.EscapeDataString(sharedTableName)}");

    private Task RemoveFromDataset(string userId)
        => RemoveShare($"api/datasets/{datasetId}/sharing/{userId}");

    private async Task RemoveShare(string url)
    {
        try
        {
            isRemovingShare = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var resp = await _httpClient.DeleteAsync(url);
            if (resp.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Access removed.");
                await LoadSharedTableUsers();
                await LoadTableStats(); // refresh the badge counts
            }
            else { _toastService.ShowError($"Failed to remove: {await resp.Content.ReadAsStringAsync()}"); }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isRemovingShare = false; StateHasChanged(); }
    }

    private bool showConnectModal = false;
    private string connectTableName = string.Empty;
    private List<DashboardPageInfo> availableDashboards = new();
    private HashSet<string> connectedPageUrls = new();
    private bool isLoadingLinks = false;
    private bool isSavingLink = false;

    private async Task OpenConnect(string tableName)
    {
        connectTableName = tableName;
        connectedPageUrls = new();
        showConnectModal = true;
        isLoadingLinks = true;
        StateHasChanged();
        try
        {
            await SetUserHeaderAsync();
            if (availableDashboards.Count == 0)
                availableDashboards = await _httpClient.GetFromJsonAsync<List<DashboardPageInfo>>("api/dashboard-links/dashboards") ?? new();

            var links = await _httpClient.GetFromJsonAsync<List<DashboardDataLink>>(
                $"api/dashboard-links?datasetId={Uri.EscapeDataString(datasetId!)}&tableName={Uri.EscapeDataString(tableName)}") ?? new();
            connectedPageUrls = links.Select(l => l.PageUrl).ToHashSet();
        }
        catch (Exception ex) { _toastService.ShowError($"Error loading dashboards: {ex.Message}"); }
        finally { isLoadingLinks = false; StateHasChanged(); }
    }

    private async Task ConnectDashboard(string pageUrl)
    {
        try
        {
            isSavingLink = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var req = new DashboardLinkRequest { PageUrl = pageUrl, DatasetId = datasetId!, TableName = connectTableName };
            var resp = await _httpClient.PostAsJsonAsync("api/dashboard-links", req);
            if (resp.IsSuccessStatusCode)
            {
                connectedPageUrls.Add(pageUrl);
                _toastService.ShowSuccess("Table connected to dashboard.");
            }
            else
            {
                _toastService.ShowError($"Failed to connect: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isSavingLink = false; StateHasChanged(); }
    }

    private async Task DisconnectDashboard(string pageUrl)
    {
        try
        {
            isSavingLink = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var resp = await _httpClient.DeleteAsync($"api/dashboard-links?pageUrl={Uri.EscapeDataString(pageUrl)}");
            if (resp.IsSuccessStatusCode || resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                connectedPageUrls.Remove(pageUrl);
                _toastService.ShowSuccess("Disconnected.");
            }
            else
            {
                _toastService.ShowError($"Failed to disconnect: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isSavingLink = false; StateHasChanged(); }
    }

    private bool showApiDocs = false;
    private string? apiDocsTable;

    // Per-table share dialog
    private bool showShareTable = false;
    private string shareTableName = string.Empty;
    private string shareTableEmail = string.Empty;
    private string shareTableType = "Viewer";
    private bool isSharingTable = false;

    // Per-table column scoping in the share-table dialog.
    private bool shareTableSpecificColumns = false;
    private bool shareTableColumnsLoading = false;
    private List<string> shareTableColumns = new();
    private HashSet<string> shareTableSelectedColumns = new(StringComparer.OrdinalIgnoreCase);

    private List<UserMention> shareTableMemberSuggestions = new();
    private bool showShareTableSuggestions = false;
    private CancellationTokenSource? shareTableSuggestCts;

    private void OpenShareTable(string tableName)
    {
        shareTableName = tableName;
        shareTableEmail = string.Empty;
        shareTableType = "Viewer";
        showShareTable = true;
        showShareTableSuggestions = false;
        shareTableMemberSuggestions = new();
        shareTableSpecificColumns = false;
        shareTableColumnsLoading = false;
        shareTableColumns = new();
        shareTableSelectedColumns = new(StringComparer.OrdinalIgnoreCase);
    }

    private async Task SetShareTableColumnMode(bool specific)
    {
        shareTableSpecificColumns = specific;
        if (specific)
        {
            await EnsureShareTableColumnsLoaded();
            if (shareTableSelectedColumns.Count == 0)
                shareTableSelectedColumns = new HashSet<string>(shareTableColumns, StringComparer.OrdinalIgnoreCase);
        }
    }

    private void ToggleShareTableColumn(string column, bool on)
    {
        if (on) shareTableSelectedColumns.Add(column);
        else shareTableSelectedColumns.Remove(column);
    }

    private async Task EnsureShareTableColumnsLoaded()
    {
        if (shareTableColumns.Count > 0) return;
        shareTableColumnsLoading = true;
        StateHasChanged();
        try
        {
            await SetUserHeaderAsync();
            var cols = await _httpClient.GetFromJsonAsync<List<Column>>(
                $"api/datasets/{datasetId}/tables/{Uri.EscapeDataString(shareTableName)}/columns");
            shareTableColumns = cols?.Select(c => c.Name).Where(n => !string.IsNullOrWhiteSpace(n)).ToList() ?? new();
        }
        catch { shareTableColumns = new(); }
        finally { shareTableColumnsLoading = false; StateHasChanged(); }
    }

    private async Task OnShareTableEmailInput(ChangeEventArgs e)
    {
        shareTableEmail = e.Value?.ToString() ?? string.Empty;
        await SearchShareTableMembers(shareTableEmail);
    }

    private async Task OnShareTableEmailFocus() => await SearchShareTableMembers(shareTableEmail);

    // Delay hiding so an @onmousedown selection on a suggestion registers before blur closes the list.
    private async Task OnShareTableEmailBlur()
    {
        await Task.Delay(150);
        showShareTableSuggestions = false;
        StateHasChanged();
    }

    private async Task SearchShareTableMembers(string term)
    {
        // Debounce rapid keystrokes.
        shareTableSuggestCts?.Cancel();
        var cts = shareTableSuggestCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(200, cts.Token);
            await SetUserHeaderAsync();

            var url = "api/DataViews/users/search?maxResults=8";
            if (!string.IsNullOrWhiteSpace(term))
                url += $"&searchTerm={Uri.EscapeDataString(term)}";

            var results = await _httpClient.GetFromJsonAsync<List<UserMention>>(url, cts.Token);
            if (cts.IsCancellationRequested) return;

            shareTableMemberSuggestions = results ?? new();
            showShareTableSuggestions = shareTableMemberSuggestions.Any();
            StateHasChanged();
        }
        catch (OperationCanceledException) { /* superseded by a newer keystroke */ }
        catch (Exception ex) { Console.WriteLine($"Member search failed: {ex.Message}"); }
    }

    private void SelectShareTableMember(UserMention member)
    {
        shareTableEmail = member.Email;
        showShareTableSuggestions = false;
        StateHasChanged();
    }

    private async Task ShareTableSubmit()
    {
        if (string.IsNullOrWhiteSpace(shareTableEmail))
        {
            _toastService.ShowWarning("Enter an email address");
            return;
        }
        if (shareTableSpecificColumns && shareTableSelectedColumns.Count == 0)
        {
            _toastService.ShowWarning("Select at least one column, or choose 'All columns'.");
            return;
        }
        try
        {
            isSharingTable = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            var request = new GrantTableShareRequest
            {
                Email = shareTableEmail.Trim(),
                DatasetId = datasetId!,
                TableName = shareTableName,
                UserType = shareTableType switch
                {
                    "Admin" => DatasetUserType.Admin,
                    "Editor" => DatasetUserType.Editor,
                    _ => DatasetUserType.Viewer
                },
                // Empty list = all columns (clears any restriction); specific list = restrict to those.
                Columns = shareTableSpecificColumns ? shareTableSelectedColumns.ToList() : new List<string>()
            };

            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{datasetId}/sharing/grant-table", request);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Table '{shareTableName}' shared with {shareTableEmail}");
                showShareTable = false;
            }
            else
            {
                _toastService.ShowError($"Failed to share table: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error sharing table: {ex.Message}");
        }
        finally
        {
            isSharingTable = false;
            StateHasChanged();
        }
    }


            else
            {
                _toastService.ShowError($"Failed to move table: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error moving table: {ex.Message}");
        }
        finally
        {
            isMovingTable = false;
            StateHasChanged();
        }
    }


                var notified = outcome?.UsersNotified ?? 0;
                _toastService.ShowSuccess($"Table '{moveTableName}' moved to '{targetName}'" +
                    (notified > 0 ? $" — {notified} user{(notified == 1 ? "" : "s")} notified." : "."));
                showMoveTable = false;

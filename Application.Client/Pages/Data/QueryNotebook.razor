@page "/data/notebook"
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Application.Shared.Models
@using Application.Shared.Models.Notebooks
@using Application.Shared.Services
@implements IDisposable
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject StateContainer _stateContainer
@inject AuthenticationStateProvider _authenticationStateProvider
@inject IJSRuntime _jsRuntime
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.QueryAccess)]

<PageTitle>Query Notebook</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to use the query notebook.</p>
    </div>
}
else if (string.IsNullOrEmpty(n))
{
    @* ---------------- List view ---------------- *@
    <div class="ds-page">
        <div class="ds-header">
            <div>
                <h1 class="ds-title">Query Notebooks</h1>
                <p class="ds-subtitle">Chain SQL cells together — run one, reference its result in the next.</p>
            </div>
            @if (canEdit)
            {
                <div style="display:flex;align-items:center;gap:0.5rem">
                    <label class="btn btn-outline" for="nb-import-input" style="@(isImporting ? "opacity:0.6;pointer-events:none;" : "")margin:0;cursor:pointer">
                        @if (isImporting) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span> <span>Importing…</span> } else { <span>Import</span> }
                    </label>
                    <InputFile OnChange="ImportNotebookFile" style="display:none" id="nb-import-input" accept=".json" />
                    <button class="btn btn-default" @onclick="StartCreate">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        New Notebook
                    </button>
                </div>
            }
        </div>

        @if (showCreateForm)
        {
            <div class="ds-form-card" style="padding:0.75rem;margin-bottom:1rem">
                <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                    <input class="ds-input" placeholder="Notebook name" @bind="newName" style="flex:1;min-width:180px" />
                    <input class="ds-input" placeholder="Description (optional)" @bind="newDescription" style="flex:1;min-width:180px" />
                    <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8125rem"><input type="checkbox" @bind="newShared" /> Shared</label>
                    <button class="btn btn-default" @onclick="CreateNotebook">Create</button>
                    <button class="btn btn-outline" @onclick="() => showCreateForm = false">Cancel</button>
                </div>
            </div>
        }

        <div class="ds-card">
            @if (notebooks.Count > 0)
            {
                <div class="ds-card-toolbar">
                    <div class="ds-search-wrap">
                        <svg class="ds-search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input class="ds-search" type="search" placeholder="Filter notebooks..." @bind="searchTerm" @bind:event="oninput" />
                    </div>
                </div>
            }

            @if (isLoading)
            {
                <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
            }
            else if (notebooks.Count == 0)
            {
                <div class="ds-empty">
                    <div class="ds-empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </div>
                    <h3 class="ds-empty-title">No notebooks yet</h3>
                    <p class="ds-empty-sub">Create your first notebook to get started.</p>
                    @if (canEdit)
                    {
                        <button class="btn btn-default" @onclick="StartCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            New Notebook
                        </button>
                    }
                </div>
            }
            else if (FilteredNotebooks.Count == 0)
            {
                <div class="ds-empty">
                    <div class="ds-empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <h3 class="ds-empty-title">No notebooks found</h3>
                    <p class="ds-empty-sub">No notebooks match "<strong>@searchTerm</strong>". Try a different search.</p>
                </div>
            }
            else
            {
                <div class="ds-table-wrap">
                    <table class="ds-table">
                        <thead>
                            <tr>
                                <th class="ds-th">Name</th>
                                <th class="ds-th">Description</th>
                                <th class="ds-th">Cells</th>
                                <th class="ds-th">Visibility</th>
                                <th class="ds-th">Modified</th>
                                <th class="ds-th">Created By</th>
                                <th class="ds-th ds-th-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var nb in FilteredNotebooks)
                            {
                                <tr class="ds-tr" style="cursor:pointer" @onclick="() => Open(nb.Id)">
                                    <td class="ds-td ds-td-name">
                                        <div style="display:flex;align-items:center;gap:0.5rem">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#71717a;flex-shrink:0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                            <span class="ds-dataset-name">@nb.Name</span>
                                        </div>
                                    </td>
                                    <td class="ds-td">
                                        <span style="color:@(string.IsNullOrWhiteSpace(nb.Description) ? "#a1a1aa" : "inherit")">@(string.IsNullOrWhiteSpace(nb.Description) ? "—" : nb.Description)</span>
                                    </td>
                                    <td class="ds-td"><span class="ds-stat">@nb.CellCount</span></td>
                                    <td class="ds-td">
                                        @if (nb.IsShared)
                                        {
                                            <span class="nb-badge-shared" style="font-size:0.6875rem;font-weight:600;padding:0.1rem 0.5rem;border-radius:9999px;background:#dcfce7;color:#15803d">Shared</span>
                                        }
                                        else
                                        {
                                            <span style="font-size:0.75rem;color:#a1a1aa">Private</span>
                                        }
                                    </td>
                                    <td class="ds-td"><span style="font-size:0.8125rem;color:#71717a">@((nb.ModifiedAt ?? nb.CreatedAt).ToLocalTime().ToString("MMM dd, yyyy"))</span></td>
                                    <td class="ds-td"><span style="font-size:0.8125rem;color:#71717a">@(nb.CreatedBy ?? "—")</span></td>
                                    <td class="ds-td ds-td-actions-cell" @onclick:stopPropagation="true">
                                        <div class="ds-actions">
                                            <button class="btn-icon btn-icon-open" title="Open" @onclick="() => Open(nb.Id)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                            </button>
                                            <button class="btn-icon" title="Duplicate" @onclick="() => DuplicateNotebook(nb)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                                            </button>
                                            <button class="btn-icon" title="Export as JSON" @onclick="() => ExportNotebook(nb)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3"/><path d="m6 10 6 6 6-6"/><path d="M19 21H5"/></svg>
                                            </button>
                                            @if (nb.CanEdit)
                                            {
                                                <button class="btn-icon btn-icon-delete" title="Delete notebook" @onclick="() => DeleteNotebook(nb)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else
{
    @* ---------------- Editor view ---------------- *@
    <div class="ds-page">
        <div class="ds-header">
            <div style="display:flex;align-items:center;gap:0.75rem">
                <button class="btn-icon" title="Back to notebooks" @onclick="BackToList">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                </button>
                <div>
                    <h1 class="ds-title">@(currentNotebook?.Name ?? "Notebook")</h1>
                    @if (!string.IsNullOrWhiteSpace(currentNotebook?.Description))
                    {
                        <p class="ds-subtitle">@currentNotebook!.Description</p>
                    }
                </div>
            </div>
            @if (currentNotebook != null)
            {
                <div style="display:flex;align-items:center;gap:0.5rem">
                    <button class="btn btn-outline" @onclick="() => _showGraph = true" disabled="@(currentNotebook.Cells.Count == 0)">
                        Dependency Graph
                    </button>
                    @if (isRunningAll)
                    {
                        <button class="btn btn-outline" @onclick="CancelRunAll">
                            <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span> <span>Cancel</span>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline" @onclick="OnRunAllClicked" disabled="@(currentNotebook.Cells.Count == 0)">
                            Run All
                        </button>
                    }
                    <button class="btn-icon" title="Duplicate notebook" @onclick="() => DuplicateNotebook(currentNotebook)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                    </button>
                    <button class="btn-icon" title="Export as JSON" @onclick="() => ExportNotebook(currentNotebook)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3"/><path d="m6 10 6 6 6-6"/><path d="M19 21H5"/></svg>
                    </button>
                    @if (currentNotebook.CanEdit)
                    {
                        <button class="btn-icon @(currentNotebook.ScheduleEnabled ? "nc-ai-btn-active" : "")" title="Schedule recurring runs" @onclick="OpenSchedule">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
                        </button>
                        <button class="btn-icon" title="Share notebook" @onclick="() => _showShare = true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                        </button>
                        <button class="btn-icon btn-icon-delete" title="Delete notebook" @onclick="() => DeleteNotebook(currentNotebook)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        </button>
                    }
                </div>
            }
        </div>

        @if (currentNotebook != null && (_storageSummary != null || currentNotebook.ScheduleEnabled))
        {
            <div class="nb-substats">
                @if (currentNotebook.ScheduleEnabled)
                {
                    <span title="@currentNotebook.CronExpression">
                        ⏱ Scheduled (@currentNotebook.CronExpression)
                        @if (currentNotebook.LastScheduledRunAt != null)
                        {
                            <span> · last run @currentNotebook.LastScheduledRunAt.Value.ToLocalTime().ToString("MMM dd, h:mm tt") (@currentNotebook.LastScheduledRunStatus)</span>
                        }
                    </span>
                }
                @if (_storageSummary != null && _storageSummary.ObjectCount > 0)
                {
                    <span>@_storageSummary.ObjectCount table@(_storageSummary.ObjectCount == 1 ? "" : "s") · @_storageSummary.TotalRows.ToString("N0") rows · @FormatBytes(_storageSummary.TotalSizeBytes)</span>
                }
            </div>
        }

        @if (isLoading)
        {
            <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
        }
        else if (currentNotebook == null)
        {
            <div class="ds-empty">
                <h3 class="ds-empty-title">Notebook not found</h3>
                <p class="ds-empty-sub">It may have been deleted, or you don't have access to it.</p>
                <button class="btn btn-default" @onclick="BackToList">Back to notebooks</button>
            </div>
        }
        else
        {
            <div class="nb-cells">
                @for (var i = 0; i < currentNotebook.Cells.Count; i++)
                {
                    var index = i;
                    var cell = currentNotebook.Cells[index];
                    <div id="cell-@cell.Id" class="nb-cell-wrap @(_dragOverIndex == index && _dragIndex != index ? "nb-drag-over" : "") @(_dragIndex == index ? "nb-dragging" : "")"
                         @key="cell.Id"
                         @ondragenter="() => OnDragEnter(index)"
                         @ondragover:preventDefault="true"
                         @ondrop="() => OnDrop(index)"
                         @ondrop:preventDefault="true">
                        <NotebookCellCard Cell="cell" NotebookId="@currentNotebook.Id" CompanyId="@companyId" Datasets="datasets"
                                          AvailableReferences="PriorSqlCells(index)"
                                          ShowDragHandle="true"
                                          ExternalResult="@ResultFor(cell.Id)"
                                          OnDragStart="() => OnDragStart(index)"
                                          OnDragEnd="OnDragEnd"
                                          OnUpdated="c => OnCellUpdated(index, c)"
                                          OnRemove="RemoveCell" />
                    </div>
                }
            </div>

            @if (canEdit)
            {
                <div class="nb-add-row">
                    <button class="btn btn-outline" @onclick='() => AddCell("sql")'>+ SQL Cell</button>
                    <button class="btn btn-outline" @onclick='() => AddCell("markdown")'>+ Markdown Cell</button>
                    <div class="nb-tpl-anchor">
                        <button class="btn btn-outline" @onclick="() => _showTemplates = !_showTemplates">▾ Templates</button>
                        @if (_showTemplates)
                        {
                            <div class="nb-tpl-backdrop" @onclick="() => _showTemplates = false"></div>
                            <div class="nb-tpl-pop" @onclick:stopPropagation="true">
                                <div class="nb-tpl-pop-head">SQL Snippets</div>
                                @foreach (var tpl in SnippetTemplates)
                                {
                                    <button type="button" class="nb-tpl-item" @onclick="() => AddFromTemplate(tpl)">
                                        <span class="nb-tpl-name">@tpl.Label</span>
                                        <span class="nb-tpl-desc">@tpl.Description</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
}

@if (_showSchedule && currentNotebook != null)
{
    <div class="ds-modal-backdrop" @onclick="() => _showSchedule = false">
        <div class="ds-modal" style="width:min(420px, 90vw)" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Schedule</h2>
                <button class="ds-modal-close" @onclick="() => _showSchedule = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                <label style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;font-size:0.875rem;cursor:pointer">
                    <input type="checkbox" @bind="_scheduleEnabled" /> Run this notebook on a recurring schedule
                </label>
                <div class="ds-field">
                    <label class="ds-label">Cron expression</label>
                    <input class="ds-input" placeholder="0 6 * * *" @bind="_scheduleCron" disabled="@(!_scheduleEnabled)" />
                    <span class="ds-hint">Standard 5-field cron (minute hour day month weekday). E.g. "0 6 * * *" = daily at 6am.</span>
                </div>
                <div class="ds-field">
                    <label class="ds-label">Time zone <span style="color:#71717a;font-weight:400">(optional)</span></label>
                    <input class="ds-input" placeholder="Asia/Beirut" @bind="_scheduleTimeZone" disabled="@(!_scheduleEnabled)" />
                </div>
                <div class="ds-modal-footer">
                    <button type="button" class="btn btn-default" style="flex:1" @onclick="SaveSchedule" disabled="@_savingSchedule">
                        @if (_savingSchedule) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span> } else { <span>Save</span> }
                    </button>
                    <button type="button" class="btn btn-outline" style="flex:1" @onclick="() => _showSchedule = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showRunAllParamPrompt && currentNotebook != null)
{
    <div class="ds-modal-backdrop" @onclick="() => _showRunAllParamPrompt = false">
        <div class="ds-modal" style="width:min(420px, 90vw)" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Run parameters</h2>
                <button class="ds-modal-close" @onclick="() => _showRunAllParamPrompt = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                @foreach (var name in _pendingRunAllParamNames)
                {
                    <div class="ds-field">
                        <label class="ds-label">@("{{" + name + "}}")</label>
                        <input class="ds-input" @bind="_runAllParamValues[name]" @bind:event="oninput" />
                    </div>
                }
                <div class="ds-modal-footer">
                    <button type="button" class="btn btn-default" style="flex:1" @onclick="ConfirmRunAllParamPrompt">Run All</button>
                    <button type="button" class="btn btn-outline" style="flex:1" @onclick="() => _showRunAllParamPrompt = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showGraph && currentNotebook != null)
{
    <div class="ds-modal-backdrop" @onclick="() => _showGraph = false">
        <div class="ds-modal" style="width:min(1000px, 94vw)" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Dependency Graph</h2>
                <button class="ds-modal-close" @onclick="() => _showGraph = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                <NotebookDependencyGraph Cells="currentNotebook.Cells" />
            </div>
        </div>
    </div>
}

<ShareNotebookModal @bind-IsVisible="_showShare" NotebookId="@(currentNotebook?.Id ?? string.Empty)" NotebookName="@(currentNotebook?.Name ?? string.Empty)" CompanyId="@companyId" />

<style>
    .nb-cells { display:flex; flex-direction:column; gap:0.75rem; }
    .nb-cell-wrap { transition: box-shadow 0.15s ease; border-radius:10px; }
    .nb-cell-wrap.nb-dragging { opacity:0.4; }
    .nb-cell-wrap.nb-drag-over {
        box-shadow: 0 0 0 2px #2563eb inset, 0 0 0 5px rgba(37,99,235,0.18), 0 0 22px rgba(37,99,235,0.45);
        animation: nb-drop-glow 1s ease-in-out infinite;
    }
    @@keyframes nb-drop-glow {
        0%, 100% { box-shadow: 0 0 0 2px #2563eb inset, 0 0 0 5px rgba(37,99,235,0.18), 0 0 22px rgba(37,99,235,0.45); }
        50% { box-shadow: 0 0 0 3px #3b82f6 inset, 0 0 0 7px rgba(59,130,246,0.26), 0 0 30px rgba(59,130,246,0.6); }
    }
    .nb-add-row { display:flex; justify-content:center; gap:0.5rem; margin-top:0.75rem; }
    .nb-substats { display:flex; gap:1rem; font-size:0.75rem; color:#71717a; margin:-0.5rem 0 0.75rem; }
    .nb-tpl-anchor { position:relative; display:inline-flex; }
    .nb-tpl-backdrop { position:fixed; inset:0; z-index:40; background:transparent; }
    .nb-tpl-pop {
        position:absolute; bottom:calc(100% + 8px); left:50%; transform:translateX(-50%); z-index:50;
        width:320px; max-height:360px; overflow-y:auto;
        background:#fff; border:1px solid #e4e4e7; border-radius:12px;
        box-shadow:0 12px 32px rgba(0,0,0,0.16), 0 2px 8px rgba(0,0,0,0.06);
    }

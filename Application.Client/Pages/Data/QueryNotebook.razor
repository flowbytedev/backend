@page "/data/notebook"
@using System.Net.Http.Json
@using Application.Shared.Models
@using Application.Shared.Models.Notebooks
@using Application.Shared.Services
@implements IDisposable
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject StateContainer _stateContainer
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Query Notebook</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to use the query notebook.</p>
    </div>
}
else if (string.IsNullOrEmpty(n))
{
    @* ---------------- List view ---------------- *@
    <div class="ds-page">
        <div class="ds-header">
            <div>
                <h1 class="ds-title">Query Notebooks</h1>
                <p class="ds-subtitle">Chain SQL cells together — run one, reference its result in the next.</p>
            </div>
            @if (canEdit)
            {
                <button class="btn btn-default" @onclick="StartCreate">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    New Notebook
                </button>
            }
        </div>

        @if (showCreateForm)
        {
            <div class="ds-form-card" style="padding:0.75rem;margin-bottom:1rem">
                <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                    <input class="ds-input" placeholder="Notebook name" @bind="newName" style="flex:1;min-width:180px" />
                    <input class="ds-input" placeholder="Description (optional)" @bind="newDescription" style="flex:1;min-width:180px" />
                    <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8125rem"><input type="checkbox" @bind="newShared" /> Shared</label>
                    <button class="btn btn-default" @onclick="CreateNotebook">Create</button>
                    <button class="btn btn-outline" @onclick="() => showCreateForm = false">Cancel</button>
                </div>
            </div>
        }

        <div class="ds-card">
            @if (isLoading)
            {
                <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
            }
            else if (notebooks.Count == 0)
            {
                <div class="ds-empty">
                    <div class="ds-empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </div>
                    <h3 class="ds-empty-title">No notebooks yet</h3>
                    <p class="ds-empty-sub">Create your first notebook to get started.</p>
                    @if (canEdit)
                    {
                        <button class="btn btn-default" @onclick="StartCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            New Notebook
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="ds-table-wrap">
                    <table class="ds-table">
                        <thead>
                            <tr>
                                <th class="ds-th">Name</th>
                                <th class="ds-th">Description</th>
                                <th class="ds-th">Cells</th>
                                <th class="ds-th">Visibility</th>
                                <th class="ds-th">Modified</th>
                                <th class="ds-th">Created By</th>
                                <th class="ds-th ds-th-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var nb in notebooks)
                            {
                                <tr class="ds-tr" style="cursor:pointer" @onclick="() => Open(nb.Id)">
                                    <td class="ds-td ds-td-name">
                                        <div style="display:flex;align-items:center;gap:0.5rem">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#71717a;flex-shrink:0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                            <span class="ds-dataset-name">@nb.Name</span>
                                        </div>
                                    </td>
                                    <td class="ds-td">
                                        <span style="color:@(string.IsNullOrWhiteSpace(nb.Description) ? "#a1a1aa" : "inherit")">@(string.IsNullOrWhiteSpace(nb.Description) ? "—" : nb.Description)</span>
                                    </td>
                                    <td class="ds-td"><span class="ds-stat">@nb.CellCount</span></td>
                                    <td class="ds-td">
                                        @if (nb.IsShared)
                                        {
                                            <span style="font-size:0.6875rem;font-weight:600;padding:0.1rem 0.5rem;border-radius:9999px;background:#dcfce7;color:#15803d">Shared</span>
                                        }
                                        else
                                        {
                                            <span style="font-size:0.75rem;color:#a1a1aa">Private</span>
                                        }
                                    </td>
                                    <td class="ds-td"><span style="font-size:0.8125rem;color:#71717a">@((nb.ModifiedAt ?? nb.CreatedAt).ToLocalTime().ToString("MMM dd, yyyy"))</span></td>
                                    <td class="ds-td"><span style="font-size:0.8125rem;color:#71717a">@(nb.CreatedBy ?? "—")</span></td>
                                    <td class="ds-td ds-td-actions-cell" @onclick:stopPropagation="true">
                                        <div class="ds-actions">
                                            <button class="btn-icon btn-icon-open" title="Open" @onclick="() => Open(nb.Id)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                            </button>
                                            @if (nb.CanEdit)
                                            {
                                                <button class="btn-icon btn-icon-delete" title="Delete notebook" @onclick="() => DeleteNotebook(nb)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else
{
    @* ---------------- Editor view ---------------- *@
    <div class="ds-page">
        <div class="ds-header">
            <div style="display:flex;align-items:center;gap:0.75rem">
                <button class="btn-icon" title="Back to notebooks" @onclick="BackToList">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                </button>
                <div>
                    <h1 class="ds-title">@(currentNotebook?.Name ?? "Notebook")</h1>
                    @if (!string.IsNullOrWhiteSpace(currentNotebook?.Description))
                    {
                        <p class="ds-subtitle">@currentNotebook!.Description</p>
                    }
                </div>
            </div>
            @if (currentNotebook != null)
            {
                <div style="display:flex;align-items:center;gap:0.5rem">
                    <button class="btn btn-outline" @onclick="RunAll" disabled="@(isRunningAll || currentNotebook.Cells.Count == 0)">
                        @if (isRunningAll) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span> <span>Running…</span> } else { <span>Run All</span> }
                    </button>
                    @if (currentNotebook.CanEdit)
                    {
                        <button class="btn-icon btn-icon-delete" title="Delete notebook" @onclick="() => DeleteNotebook(currentNotebook)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        </button>
                    }
                </div>
            }
        </div>

        @if (isLoading)
        {
            <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
        }
        else if (currentNotebook == null)
        {
            <div class="ds-empty">
                <h3 class="ds-empty-title">Notebook not found</h3>
                <p class="ds-empty-sub">It may have been deleted, or you don't have access to it.</p>
                <button class="btn btn-default" @onclick="BackToList">Back to notebooks</button>
            </div>
        }
        else
        {
            <div class="nb-cells">
                @for (var i = 0; i < currentNotebook.Cells.Count; i++)
                {
                    var index = i;
                    var cell = currentNotebook.Cells[index];
                    <div class="nb-cell-wrap @(_dragOverIndex == index && _dragIndex != index ? "nb-drag-over" : "") @(_dragIndex == index ? "nb-dragging" : "")"
                         @key="cell.Id"
                         @ondragenter="() => OnDragEnter(index)"
                         @ondragover:preventDefault="true"
                         @ondrop="() => OnDrop(index)"
                         @ondrop:preventDefault="true">
                        <NotebookCellCard Cell="cell" NotebookId="@currentNotebook.Id" Datasets="datasets"
                                          AvailableReferences="PriorSqlCells(index)"
                                          ShowDragHandle="true"
                                          ExternalResult="@ResultFor(cell.Id)"
                                          OnDragStart="() => OnDragStart(index)"
                                          OnDragEnd="OnDragEnd"
                                          OnUpdated="c => OnCellUpdated(index, c)"
                                          OnRemove="RemoveCell" />
                    </div>
                }
            </div>

            @if (canEdit)
            {
                <div class="nb-add-row">
                    <button class="btn btn-outline" @onclick='() => AddCell("sql")'>+ SQL Cell</button>
                    <button class="btn btn-outline" @onclick='() => AddCell("markdown")'>+ Markdown Cell</button>
                </div>
            }
        }
    </div>
}

<style>
    .nb-cells { display:flex; flex-direction:column; gap:0.75rem; }
    .nb-cell-wrap { transition: box-shadow 0.15s ease; border-radius:10px; }
    .nb-cell-wrap.nb-dragging { opacity:0.4; }
    .nb-cell-wrap.nb-drag-over {
        box-shadow: 0 0 0 2px #2563eb inset, 0 0 0 5px rgba(37,99,235,0.18), 0 0 22px rgba(37,99,235,0.45);
        animation: nb-drop-glow 1s ease-in-out infinite;
    }
    @@keyframes nb-drop-glow {
        0%, 100% { box-shadow: 0 0 0 2px #2563eb inset, 0 0 0 5px rgba(37,99,235,0.18), 0 0 22px rgba(37,99,235,0.45); }
        50% { box-shadow: 0 0 0 3px #3b82f6 inset, 0 0 0 7px rgba(59,130,246,0.26), 0 0 30px rgba(59,130,246,0.6); }
    }
    .nb-add-row { display:flex; justify-content:center; gap:0.5rem; margin-top:0.75rem; }
</style>

@code {
    [SupplyParameterFromQuery(Name = "c")]
    public string? c { get; set; }

    [SupplyParameterFromQuery(Name = "n")]
    public string? n { get; set; }

    private string? companyId;
    private bool isLoading = true;
    private bool canView;
    private bool canEdit;

    private List<Dataset> datasets = new();
    private List<QueryNotebookDto> notebooks = new();
    private QueryNotebookDto? currentNotebook;
    private string? _openNotebookId; // last id we actually loaded, so OnParametersSetAsync only reacts to real changes

    private bool showCreateForm;
    private string newName = string.Empty;
    private string newDescription = string.Empty;
    private bool newShared;
    private bool isRunningAll;

    private Dictionary<string, NotebookCellRunResult> _runAllResults = new();

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }

        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }

        try { datasets = await _httpClient.GetFromJsonAsync<List<Dataset>>("api/datasets") ?? new(); }
        catch { datasets = new(); }

        // The sidebar's "..." menu (DatabaseExplorerTree) creates cells directly via the API, since it's
        // a separate component with no parent/child relationship to this page — it notifies us here so
        // our in-memory cell list picks up the change.
        _stateContainer.NotebookCellsChangedExternally += OnCellsChangedExternally;

        await Sync();
        isLoading = false;
    }

    private void OnCellsChangedExternally()
    {
        _openNotebookId = null;
        _ = ReloadAfterExternalChangeAsync();
    }

    private async Task ReloadAfterExternalChangeAsync()
    {
        await Sync();
        StateHasChanged();
    }

    // Re-navigating within this same page (list <-> editor, or switching notebooks) reuses the component
    // and only calls OnParametersSet — react here so the sidebar/back-nav stay in sync with the URL.
    protected override async Task OnParametersSetAsync()
    {
        if (isLoading || string.IsNullOrEmpty(companyId)) return;
        await Sync();
    }

    private async Task Sync()
    {
        if (string.IsNullOrEmpty(n))
        {
            currentNotebook = null;
            _openNotebookId = null;
            _stateContainer.NotebookExplorerNotebookId = null;
            if (notebooks.Count == 0) await LoadNotebooks();
            return;
        }

        if (_openNotebookId == n) return; // already showing this notebook
        _openNotebookId = n;
        _runAllResults.Clear();
        try { currentNotebook = await _httpClient.GetFromJsonAsync<QueryNotebookDto>($"api/query-notebooks/{n}"); }
        catch (Exception ex) { currentNotebook = null; _toastService.ShowError($"Failed to load notebook: {ex.Message}"); }
        _stateContainer.NotebookExplorerNotebookId = currentNotebook != null ? n : null;
    }

    private async Task LoadNotebooks()
    {
        try { notebooks = await _httpClient.GetFromJsonAsync<List<QueryNotebookDto>>("api/query-notebooks") ?? new(); }
        catch { notebooks = new(); }
    }

    private void Open(string id) => _navigationManager.NavigateTo($"data/notebook?c={companyId}&n={id}");
    private void BackToList() => _navigationManager.NavigateTo($"data/notebook?c={companyId}");

    private void StartCreate()
    {
        newName = string.Empty;
        newDescription = string.Empty;
        newShared = false;
        showCreateForm = true;
    }

    private async Task CreateNotebook()
    {
        if (string.IsNullOrWhiteSpace(newName)) { _toastService.ShowWarning("Enter a name"); return; }
        try
        {
            var request = new SaveNotebookRequest { Name = newName.Trim(), Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim(), IsShared = newShared };
            var response = await _httpClient.PostAsJsonAsync("api/query-notebooks", request);
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<QueryNotebookDto>();
                showCreateForm = false;
                if (created != null) Open(created.Id);
                else await LoadNotebooks();
            }
            else
            {
                _toastService.ShowError(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error creating notebook: {ex.Message}"); }
    }

    private async Task DeleteNotebook(QueryNotebookDto? notebook)
    {
        if (notebook == null) return;
        try
        {
            var response = await _httpClient.DeleteAsync($"api/query-notebooks/{notebook.Id}");
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Notebook deleted");
                notebooks.RemoveAll(x => x.Id == notebook.Id);
                if (n == notebook.Id) BackToList();
            }
            else
            {
                _toastService.ShowError($"Delete failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting notebook: {ex.Message}"); }
    }

    private async Task AddCell(string cellType)
    {
        if (currentNotebook == null) return;
        try
        {
            var request = new SaveNotebookCellRequest
            {
                CellType = cellType,
                Name = cellType == "sql" ? $"cell_{currentNotebook.Cells.Count + 1}" : null,
            };
            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/cells", request);
            if (response.IsSuccessStatusCode)
            {
                var cell = await response.Content.ReadFromJsonAsync<NotebookCellDto>();
                if (cell != null) currentNotebook.Cells.Add(cell);
            }
            else
            {
                _toastService.ShowError(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error adding cell: {ex.Message}"); }
    }

    private void OnCellUpdated(int index, NotebookCellDto updated)
    {
        if (currentNotebook == null || index < 0 || index >= currentNotebook.Cells.Count) return;
        currentNotebook.Cells[index] = updated;
    }

    private async Task RemoveCell(string cellId)
    {
        if (currentNotebook == null) return;
        try
        {
            var response = await _httpClient.DeleteAsync($"api/query-notebooks/{currentNotebook.Id}/cells/{cellId}");
            if (response.IsSuccessStatusCode)
            {
                currentNotebook.Cells.RemoveAll(c => c.Id == cellId);
                _runAllResults.Remove(cellId);
            }
            else
            {
                _toastService.ShowError($"Delete failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting cell: {ex.Message}"); }
    }

    private async Task RunAll()
    {
        if (currentNotebook == null) return;
        isRunningAll = true;
        StateHasChanged();
        try
        {
            var response = await _httpClient.PostAsync($"api/query-notebooks/{currentNotebook.Id}/run-all", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RunAllResult>();
                _runAllResults = (result?.Cells ?? new()).Where(c => c.Result != null).ToDictionary(c => c.CellId, c => c.Result!);

                var failedCount = result?.Cells.Count(c => c.Status == "error") ?? 0;
                var skippedCount = result?.Cells.Count(c => c.Status == "skipped") ?? 0;
                if (failedCount > 0)
                    _toastService.ShowError($"Run All: {failedCount} cell(s) failed" + (skippedCount > 0 ? $", {skippedCount} skipped." : "."));
                else
                    _toastService.ShowSuccess("Run All completed.");

                // Reload so LastRunStatus/LastMaterializedObject (and available reference lists) are fresh.
                _openNotebookId = null;
                await Sync();
            }
            else
            {
                _toastService.ShowError($"Run All failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error running notebook: {ex.Message}"); }
        finally { isRunningAll = false; StateHasChanged(); }
    }

    private NotebookCellRunResult? ResultFor(string cellId) => _runAllResults.TryGetValue(cellId, out var r) ? r : null;

    // Cells a given cell may reference — earlier SQL cells (by current order) that already have a name.
    private List<NotebookCellDto> PriorSqlCells(int index)
    {
        if (currentNotebook == null) return new();
        return currentNotebook.Cells.Take(index).Where(c => c.CellType == "sql" && !string.IsNullOrWhiteSpace(c.Name)).ToList();
    }

    // ---- drag & drop reordering ----
    private int? _dragIndex;
    private int? _dragOverIndex;

    // Native dragenter bubbles from EVERY nested element inside a cell card (header buttons, inputs, the
    // Monaco container, the results table…), so it fires far more often than the hovered cell actually
    // changes. Each Blazor event triggers a render by default; with many heavy cell cards (Monaco editors
    // etc.) that adds up to visible lag. ShouldRender lets us skip the render entirely for the very common
    // "still hovering the same cell" case, only re-rendering when the drag target genuinely changes.
    private bool _suppressNextRender;

    protected override bool ShouldRender()
    {
        if (_suppressNextRender) { _suppressNextRender = false; return false; }
        return true;
    }

    private void OnDragStart(int index) => _dragIndex = index;

    private void OnDragEnter(int index)
    {
        if (_dragOverIndex == index) { _suppressNextRender = true; return; }
        _dragOverIndex = index;
    }

    private async Task OnDragEnd() => await Commit(_dragOverIndex);
    private async Task OnDrop(int target) => await Commit(target);

    private async Task Commit(int? target)
    {
        var from = _dragIndex;
        _dragIndex = null;
        _dragOverIndex = null;

        if (currentNotebook == null || from == null || target == null) { StateHasChanged(); return; }

        var list = currentNotebook.Cells;
        var to = target.Value;
        if (from < 0 || from >= list.Count || to < 0 || to >= list.Count || from == to) { StateHasChanged(); return; }

        var item = list[from.Value];
        list.RemoveAt(from.Value);
        list.Insert(to, item);
        StateHasChanged();
        await PersistOrder();
    }

    private async Task PersistOrder()
    {
        if (currentNotebook == null) return;
        var orderedIds = currentNotebook.Cells.Select(c => c.Id).ToList();
        try
        {
            var response = await _httpClient.PutAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/cells/reorder", orderedIds);
            if (!response.IsSuccessStatusCode)
                _toastService.ShowError($"Save order failed: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving order: {ex.Message}"); }
    }

    // Leaving this page entirely (route change, not just ?n= toggling) must restore the normal sidebar.
    public void Dispose()
    {
        _stateContainer.NotebookExplorerNotebookId = null;
        _stateContainer.NotebookCellsChangedExternally -= OnCellsChangedExternally;
    }
}

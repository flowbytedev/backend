@code {
    [SupplyParameterFromQuery(Name = "c")]
    public string? c { get; set; }

    [SupplyParameterFromQuery(Name = "n")]
    public string? n { get; set; }

    private string? companyId;
    private bool isLoading = true;
    private bool canView;
    private bool canEdit;

    private List<Dataset> datasets = new();
    private List<QueryNotebookDto> notebooks = new();
    private string searchTerm = string.Empty;
    private QueryNotebookDto? currentNotebook;
    private string? _openNotebookId; // last id we actually loaded, so OnParametersSetAsync only reacts to real changes

    // Filters by name/description, contains, case-insensitive — mirrors the datasets/tables list search.
    private List<QueryNotebookDto> FilteredNotebooks => string.IsNullOrWhiteSpace(searchTerm)
        ? notebooks
        : notebooks.Where(nb =>
            (nb.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true) ||
            (nb.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)).ToList();

    private bool showCreateForm;
    private string newName = string.Empty;
    private string newDescription = string.Empty;
    private bool newShared;
    private bool isRunningAll;

    private Dictionary<string, NotebookCellRunResult> _runAllResults = new();

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.HasCompanyRole(companyId, "QUERY");
        canEdit = authState.User.HasCompanyRole(companyId, "QUERY");
        if (!canView) { isLoading = false; return; }

        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }

        try { datasets = await _httpClient.GetFromJsonAsync<List<Dataset>>("api/datasets") ?? new(); }
        catch { datasets = new(); }

        // The sidebar's "..." menu (DatabaseExplorerTree) creates cells directly via the API, since it's
        // a separate component with no parent/child relationship to this page — it notifies us here so
        // our in-memory cell list picks up the change.
        _stateContainer.NotebookCellsChangedExternally += OnCellsChangedExternally;

        await Sync();
        isLoading = false;
    }

    private void OnCellsChangedExternally()
    {
        _openNotebookId = null;
        _ = ReloadAfterExternalChangeAsync();
    }

    private async Task ReloadAfterExternalChangeAsync()
    {
        await Sync();
        StateHasChanged();
    }

    // Re-navigating within this same page (list <-> editor, or switching notebooks) reuses the component
    // and only calls OnParametersSet — react here so the sidebar/back-nav stay in sync with the URL.
    protected override async Task OnParametersSetAsync()
    {
        if (isLoading || string.IsNullOrEmpty(companyId)) return;
        await Sync();
    }

    private async Task Sync()
    {
        if (string.IsNullOrEmpty(n))
        {
            currentNotebook = null;
            _openNotebookId = null;
            _stateContainer.NotebookExplorerNotebookId = null;
            if (notebooks.Count == 0) await LoadNotebooks();
            return;
        }

        if (_openNotebookId == n) return; // already showing this notebook
        _openNotebookId = n;
        _runAllResults.Clear();
        try { currentNotebook = await _httpClient.GetFromJsonAsync<QueryNotebookDto>($"api/query-notebooks/{n}"); }
        catch (Exception ex) { currentNotebook = null; _toastService.ShowError($"Failed to load notebook: {ex.Message}"); }
        _stateContainer.NotebookExplorerNotebookId = currentNotebook != null ? n : null;
        await LoadStorageSummary();
    }

    private async Task LoadNotebooks()
    {
        try { notebooks = await _httpClient.GetFromJsonAsync<List<QueryNotebookDto>>("api/query-notebooks") ?? new(); }
        catch { notebooks = new(); }
    }

    private void Open(string id) => _navigationManager.NavigateTo($"data/notebook?c={companyId}&n={id}");
    private void BackToList() => _navigationManager.NavigateTo($"data/notebook?c={companyId}");

    private void StartCreate()
    {
        newName = string.Empty;
        newDescription = string.Empty;
        newShared = false;
        showCreateForm = true;
    }

    private async Task CreateNotebook()
    {
        if (string.IsNullOrWhiteSpace(newName)) { _toastService.ShowWarning("Enter a name"); return; }
        try
        {
            var request = new SaveNotebookRequest { Name = newName.Trim(), Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim(), IsShared = newShared };
            var response = await _httpClient.PostAsJsonAsync("api/query-notebooks", request);
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<QueryNotebookDto>();
                showCreateForm = false;
                if (created != null) Open(created.Id);
                else await LoadNotebooks();
            }
            else
            {
                _toastService.ShowError(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error creating notebook: {ex.Message}"); }
    }

    private async Task DeleteNotebook(QueryNotebookDto? notebook)
    {
        if (notebook == null) return;
        try
        {
            var response = await _httpClient.DeleteAsync($"api/query-notebooks/{notebook.Id}");
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Notebook deleted");
                notebooks.RemoveAll(x => x.Id == notebook.Id);
                if (n == notebook.Id) BackToList();
            }
            else
            {
                _toastService.ShowError($"Delete failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting notebook: {ex.Message}"); }
    }

    private async Task DuplicateNotebook(QueryNotebookDto? notebook)
    {
        if (notebook == null) return;
        try
        {
            var request = new DuplicateNotebookRequest { Name = $"{notebook.Name} (copy)" };
            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{notebook.Id}/duplicate", request);
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<QueryNotebookDto>();
                _toastService.ShowSuccess("Notebook duplicated");
                if (created != null) Open(created.Id);
                else await LoadNotebooks();
            }
            else
            {
                _toastService.ShowError($"Duplicate failed: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error duplicating notebook: {ex.Message}"); }
    }

    private async Task ExportNotebook(QueryNotebookDto? notebook)
    {
        if (notebook == null) return;
        try
        {
            var response = await _httpClient.GetAsync($"api/query-notebooks/{notebook.Id}/export");
            if (!response.IsSuccessStatusCode)
            {
                _toastService.ShowError($"Export failed: {response.StatusCode}");
                return;
            }
            var json = await response.Content.ReadAsStringAsync();
            var fileName = $"{notebook.Name}.notebook.json";
            await _jsRuntime.InvokeVoidAsync("downloadTextFile", fileName, "application/json", json);
        }
        catch (Exception ex) { _toastService.ShowError($"Error exporting notebook: {ex.Message}"); }
    }

    private async Task ImportNotebookFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        isImporting = true;
        StateHasChanged();
        try
        {
            NotebookExportDto? export;
            using (var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
            {
                export = await System.Text.Json.JsonSerializer.DeserializeAsync<NotebookExportDto>(stream, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            if (export == null) { _toastService.ShowError("That file isn't a valid notebook export."); return; }

            var response = await _httpClient.PostAsJsonAsync("api/query-notebooks/import", export);
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<QueryNotebookDto>();
                _toastService.ShowSuccess("Notebook imported");
                if (created != null) Open(created.Id);
                else await LoadNotebooks();
            }
            else
            {
                _toastService.ShowError($"Import failed: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error importing notebook: {ex.Message}"); }
        finally { isImporting = false; StateHasChanged(); }
    }

    private async Task AddCell(string cellType, string? initialSql = null)
    {
        if (currentNotebook == null) return;
        try
        {
            var request = new SaveNotebookCellRequest
            {
                CellType = cellType,
                Name = cellType == "sql" ? $"cell_{currentNotebook.Cells.Count + 1}" : null,
                Sql = initialSql,
            };
            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/cells", request);
            if (response.IsSuccessStatusCode)
            {
                var cell = await response.Content.ReadFromJsonAsync<NotebookCellDto>();
                if (cell != null) currentNotebook.Cells.Add(cell);
            }
            else
            {
                _toastService.ShowError(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error adding cell: {ex.Message}"); }
    }

    private bool _showTemplates;
    private bool _showGraph;
    private bool _showShare;
    private bool isImporting;

    private async Task AddFromTemplate(SnippetTemplate tpl)
    {
        _showTemplates = false;
        await AddCell("sql", tpl.Sql);
    }

    private record SnippetTemplate(string Label, string Description, string Sql);

    private static readonly SnippetTemplate[] SnippetTemplates =
    {
        new("Preview rows", "First 100 rows of a table", "SELECT *\nFROM your_table\nLIMIT 100;"),
        new("Row count by group", "Count rows per distinct value", "SELECT column_a, COUNT(*) AS row_count\nFROM your_table\nGROUP BY column_a\nORDER BY row_count DESC;"),
        new("Top N by value", "Highest N rows by a column", "SELECT *\nFROM your_table\nORDER BY value_column DESC\nLIMIT 10;"),
        new("Date range filter", "Rows within a date range", "SELECT *\nFROM your_table\nWHERE date_column BETWEEN '2024-01-01' AND '2024-12-31';"),
        new("Join two tables", "Combine rows from two tables", "SELECT a.*, b.*\nFROM table_a a\nJOIN table_b b ON a.id = b.a_id;"),
        new("Running total", "Cumulative sum via a window function", "SELECT *,\n       SUM(value_column) OVER (ORDER BY date_column) AS running_total\nFROM your_table;"),
        new("De-duplicate rows", "Distinct rows only", "SELECT DISTINCT *\nFROM your_table;"),
        new("Percent of total", "Each group's share of the overall total", "SELECT category,\n       SUM(value_column) AS total,\n       SUM(value_column) * 100.0 / SUM(SUM(value_column)) OVER () AS pct_of_total\nFROM your_table\nGROUP BY category;"),
    };

    private void OnCellUpdated(int index, NotebookCellDto updated)
    {
        if (currentNotebook == null || index < 0 || index >= currentNotebook.Cells.Count) return;
        currentNotebook.Cells[index] = updated;
    }

    private async Task RemoveCell(string cellId)
    {
        if (currentNotebook == null) return;
        try
        {
            var response = await _httpClient.DeleteAsync($"api/query-notebooks/{currentNotebook.Id}/cells/{cellId}");
            if (response.IsSuccessStatusCode)
            {
                currentNotebook.Cells.RemoveAll(c => c.Id == cellId);
                _runAllResults.Remove(cellId);
            }
            else
            {
                _toastService.ShowError($"Delete failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting cell: {ex.Message}"); }
    }

    private static readonly Regex RunAllParamPattern = new(@"\{\{\s*(\w+)\s*\}\}", RegexOptions.Compiled);
    private bool _showRunAllParamPrompt;
    private List<string> _pendingRunAllParamNames = new();
    private Dictionary<string, string> _runAllParamValues = new(StringComparer.OrdinalIgnoreCase);

    private async Task OnRunAllClicked()
    {
        if (currentNotebook == null) return;
        var names = currentNotebook.Cells
            .Where(c => c.CellType == "sql")
            .SelectMany(c => RunAllParamPattern.Matches(c.Sql ?? "").Select(m => m.Groups[1].Value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (names.Count == 0) { await RunAll(null); return; }

        _pendingRunAllParamNames = names;
        foreach (var n in names)
            if (!_runAllParamValues.ContainsKey(n)) _runAllParamValues[n] = string.Empty;
        _showRunAllParamPrompt = true;
    }

    private async Task ConfirmRunAllParamPrompt()
    {
        _showRunAllParamPrompt = false;
        await RunAll(_pendingRunAllParamNames.ToDictionary(n => n, n => _runAllParamValues.TryGetValue(n, out var v) ? v : "", StringComparer.OrdinalIgnoreCase));
    }

    private async Task RunAll(Dictionary<string, string>? parameters)
    {
        if (currentNotebook == null) return;
        isRunningAll = true;
        StateHasChanged();
        try
        {
            var response = await _httpClient.PostAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/run-all", new RunNotebookRequest { Parameters = parameters });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RunAllResult>();
                _runAllResults = (result?.Cells ?? new()).Where(c => c.Result != null).ToDictionary(c => c.CellId, c => c.Result!);

                var failedCount = result?.Cells.Count(c => c.Status == "error") ?? 0;
                var skippedCount = result?.Cells.Count(c => c.Status == "skipped") ?? 0;
                if (failedCount > 0)
                    _toastService.ShowError($"Run All: {failedCount} cell(s) failed" + (skippedCount > 0 ? $", {skippedCount} skipped." : "."));
                else
                    _toastService.ShowSuccess("Run All completed.");

                // Reload so LastRunStatus/LastMaterializedObject (and available reference lists) are fresh.
                _openNotebookId = null;
                await Sync();
                await LoadStorageSummary();
            }
            else
            {
                _toastService.ShowError($"Run All failed: {response.StatusCode}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error running notebook: {ex.Message}"); }
        finally { isRunningAll = false; StateHasChanged(); }
    }

    private async Task CancelRunAll()
    {
        if (currentNotebook == null) return;
        try { await _httpClient.PostAsync($"api/query-notebooks/{currentNotebook.Id}/run-all/cancel", null); }
        catch { /* best-effort — RunAll's own finally clears isRunningAll once it observes the cancellation */ }
    }

    // ---- schedule ----
    private bool _showSchedule;
    private bool _scheduleEnabled;
    private string _scheduleCron = string.Empty;
    private string _scheduleTimeZone = string.Empty;
    private bool _savingSchedule;

    private void OpenSchedule()
    {
        if (currentNotebook == null) return;
        _scheduleEnabled = currentNotebook.ScheduleEnabled;
        _scheduleCron = currentNotebook.CronExpression ?? string.Empty;
        _scheduleTimeZone = currentNotebook.ScheduleTimeZone ?? string.Empty;
        _showSchedule = true;
    }

    private async Task SaveSchedule()
    {
        if (currentNotebook == null) return;
        if (_scheduleEnabled && string.IsNullOrWhiteSpace(_scheduleCron))
        {
            _toastService.ShowWarning("Enter a cron expression, or turn the schedule off.");
            return;
        }

        _savingSchedule = true;
        StateHasChanged();
        try
        {
            var request = new ScheduleNotebookRequest
            {
                Enabled = _scheduleEnabled,
                CronExpression = string.IsNullOrWhiteSpace(_scheduleCron) ? null : _scheduleCron.Trim(),
                TimeZone = string.IsNullOrWhiteSpace(_scheduleTimeZone) ? null : _scheduleTimeZone.Trim(),
            };
            var response = await _httpClient.PutAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/schedule", request);
            if (response.IsSuccessStatusCode)
            {
                currentNotebook = await response.Content.ReadFromJsonAsync<QueryNotebookDto>();
                _toastService.ShowSuccess("Schedule saved.");
                _showSchedule = false;
            }
            else
            {
                _toastService.ShowError($"Couldn't save schedule: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving schedule: {ex.Message}"); }
        finally { _savingSchedule = false; StateHasChanged(); }
    }

    // ---- storage summary ----
    private NotebookStorageSummaryDto? _storageSummary;

    private async Task LoadStorageSummary()
    {
        if (currentNotebook == null) { _storageSummary = null; return; }
        try { _storageSummary = await _httpClient.GetFromJsonAsync<NotebookStorageSummaryDto>($"api/query-notebooks/{currentNotebook.Id}/storage"); }
        catch { _storageSummary = null; }
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1) { size /= 1024; unit++; }
        return $"{size:0.#} {units[unit]}";
    }

    private NotebookCellRunResult? ResultFor(string cellId) => _runAllResults.TryGetValue(cellId, out var r) ? r : null;

    // Cells a given cell may reference — earlier SQL cells (by current order) that already have a name.
    private List<NotebookCellDto> PriorSqlCells(int index)
    {
        if (currentNotebook == null) return new();
        return currentNotebook.Cells.Take(index).Where(c => c.CellType == "sql" && !string.IsNullOrWhiteSpace(c.Name)).ToList();
    }

    // ---- drag & drop reordering ----
    private int? _dragIndex;
    private int? _dragOverIndex;

    // Native dragenter bubbles from EVERY nested element inside a cell card (header buttons, inputs, the
    // Monaco container, the results table…), so it fires far more often than the hovered cell actually
    // changes. Each Blazor event triggers a render by default; with many heavy cell cards (Monaco editors
    // etc.) that adds up to visible lag. ShouldRender lets us skip the render entirely for the very common
    // "still hovering the same cell" case, only re-rendering when the drag target genuinely changes.
    private bool _suppressNextRender;

    protected override bool ShouldRender()
    {
        if (_suppressNextRender) { _suppressNextRender = false; return false; }
        return true;
    }

    private void OnDragStart(int index) => _dragIndex = index;

    private void OnDragEnter(int index)
    {
        if (_dragOverIndex == index) { _suppressNextRender = true; return; }
        _dragOverIndex = index;
    }

    private async Task OnDragEnd() => await Commit(_dragOverIndex);
    private async Task OnDrop(int target) => await Commit(target);

    private async Task Commit(int? target)
    {
        var from = _dragIndex;
        _dragIndex = null;
        _dragOverIndex = null;

        if (currentNotebook == null || from == null || target == null) { StateHasChanged(); return; }

        var list = currentNotebook.Cells;
        var to = target.Value;
        if (from < 0 || from >= list.Count || to < 0 || to >= list.Count || from == to) { StateHasChanged(); return; }

        var item = list[from.Value];
        list.RemoveAt(from.Value);
        list.Insert(to, item);
        StateHasChanged();
        await PersistOrder();
    }

    private async Task PersistOrder()
    {
        if (currentNotebook == null) return;
        var orderedIds = currentNotebook.Cells.Select(c => c.Id).ToList();
        try
        {
            var response = await _httpClient.PutAsJsonAsync($"api/query-notebooks/{currentNotebook.Id}/cells/reorder", orderedIds);
            if (!response.IsSuccessStatusCode)
                _toastService.ShowError($"Save order failed: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving order: {ex.Message}"); }
    }

    // Leaving this page entirely (route change, not just ?n= toggling) must restore the normal sidebar.
    public void Dispose()
    {
        _stateContainer.NotebookExplorerNotebookId = null;
        _stateContainer.NotebookCellsChangedExternally -= OnCellsChangedExternally;
    }
}

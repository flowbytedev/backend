    [data-theme="dark"] .sd-scope .bg-red-100 { background-color: rgba(239,68,68,0.15); }
    [data-theme="dark"] .sd-scope .border-red-200 { border-color: rgba(239,68,68,0.30); }
    [data-theme="dark"] .sd-scope .text-red-400,
    [data-theme="dark"] .sd-scope .text-red-500,
    [data-theme="dark"] .sd-scope .text-red-600,
    [data-theme="dark"] .sd-scope .text-red-700,
    [data-theme="dark"] .sd-scope .text-red-800 { color: #f87171; }
    [data-theme="dark"] .sd-scope .hover\:text-red-600:hover,
    [data-theme="dark"] .sd-scope .hover\:text-red-800:hover { color: #fca5a5; }

    [data-theme="dark"] .sd-scope .bg-green-50 { background-color: rgba(34,197,94,0.12); }
    [data-theme="dark"] .sd-scope .bg-green-100 { background-color: rgba(34,197,94,0.15); }
    [data-theme="dark"] .sd-scope .border-green-200 { border-color: rgba(34,197,94,0.30); }
    [data-theme="dark"] .sd-scope .text-green-500,
    [data-theme="dark"] .sd-scope .text-green-600,

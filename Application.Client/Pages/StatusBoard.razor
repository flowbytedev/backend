    [data-theme="dark"] .sd-scope .bg-orange-100 { background-color: rgba(249,115,22,0.15); }
    [data-theme="dark"] .sd-scope .border-orange-200 { border-color: rgba(249,115,22,0.30); }
    [data-theme="dark"] .sd-scope .text-orange-600,
    [data-theme="dark"] .sd-scope .text-orange-700,
    [data-theme="dark"] .sd-scope .text-orange-800 { color: #fdba74; }

    [data-theme="dark"] .sd-scope .bg-blue-50 { background-color: rgba(59,130,246,0.10); }
    [data-theme="dark"] .sd-scope .bg-blue-100 { background-color: rgba(59,130,246,0.15); }
    [data-theme="dark"] .sd-scope .border-blue-200 { border-color: rgba(59,130,246,0.30); }
    [data-theme="dark"] .sd-scope .text-blue-600,
    [data-theme="dark"] .sd-scope .text-blue-700,
    [data-theme="dark"] .sd-scope .text-blue-800 { color: #93c5fd; }
    [data-theme="dark"] .sd-scope .text-blue-900 { color: #bfdbfe; }

    [data-theme="dark"] .sd-scope .bg-purple-50 { background-color: rgba(168,85,247,0.12); }
    [data-theme="dark"] .sd-scope .bg-purple-100 { background-color: rgba(168,85,247,0.18); }
    [data-theme="dark"] .sd-scope .text-purple-700,
    [data-theme="dark"] .sd-scope .text-purple-800 { color: #d8b4fe; }

    [data-theme="dark"] .sd-scope .bg-indigo-50 { background-color: rgba(129,140,248,0.14); }
    [data-theme="dark"] .sd-scope .bg-indigo-100 { background-color: rgba(129,140,248,0.20); }
    [data-theme="dark"] .sd-scope .border-indigo-200 { border-color: rgba(129,140,248,0.30); }
    [data-theme="dark"] .sd-scope .text-indigo-600,
    [data-theme="dark"] .sd-scope .text-indigo-700 { color: #a5b4fc; }
    [data-theme="dark"] .sd-scope .text-indigo-800 { color: #c7d2fe; }
    [data-theme="dark"] .sd-scope .hover\:text-indigo-600:hover,
    [data-theme="dark"] .sd-scope .hover\:text-indigo-800:hover { color: #c7d2fe; }

    [data-theme="dark"] .sd-scope .bg-gray-200 { background-color: #23272f; }
    [data-theme="dark"] .sd-scope .bg-gray-300 { background-color: #363c48; }

    [data-theme="dark"] .sd-scope .ring-white { --tw-ring-color: #181a20; }
    [data-theme="dark"] .sd-scope .ring-offset-1 { --tw-ring-offset-color: #181a20; }
</style>

<div class="min-h-screen bg-gray-50 p-6 sd-scope">
    <!-- Header -->
    <div class="mb-6 flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Status</h1>
            <p class="mt-1 text-sm text-gray-500">Last 30 days of uptime, grouped by type. Click a type to expand.</p>
        </div>
        <div class="flex items-center gap-2">
            <div class="relative">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                     class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" value="@filter" @oninput="OnFilterChanged" placeholder="Filter entities…"
                       class="w-56 rounded-md border border-gray-300 bg-white pl-8 pr-8 py-1.5 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400" />
                @if (HasFilter)
                {
                    <button @onclick="ClearFilter" title="Clear filter"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                }
            </div>
            <button @onclick="Reload" disabled="@isLoading"
                    class="inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 disabled:opacity-50">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                Reload
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
    }
    else if (overview is null || !overview.Groups.Any())
    {
        <div class="bg-white rounded-lg border border-gray-200 text-center py-16 text-sm text-gray-500">
            No monitored assets yet.
        </div>
    }
    else
    {
        var banner = GetBanner();
        <!-- Overall banner -->
        <div class="rounded-lg border @banner.Border @banner.Bg px-4 py-3 mb-6 flex items-center gap-3">
            <span class="w-2.5 h-2.5 rounded-full @banner.Dot"></span>
            <span class="text-sm font-semibold @banner.Text">@banner.Message</span>
        </div>

        var filteredGroups = FilteredGroups().ToList();
        @if (!filteredGroups.Any())
        {
            <div class="bg-white rounded-lg border border-gray-200 text-center py-16 text-sm text-gray-500">
                No entities match "<span class="font-medium text-gray-700">@filter</span>".
            </div>
        }
        <div class="space-y-4">
            @foreach (var group in filteredGroups)
            {
                var isOpen = expanded.Contains(group.EntityType) || HasFilter;
                <div class="bg-white rounded-lg border border-gray-200">
                    <!-- Card header -->
                    <button @onclick="() => Toggle(group.EntityType)"
                            class="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 rounded-lg">
                        <div class="flex items-center gap-3">
                            <span class="text-lg">@TypeIcon(group.EntityType)</span>
                            <span class="text-sm font-semibold text-gray-900">@group.TypeLabel</span>
                            @{ var shown = FilteredEntities(group).Count(); }
                            <span class="text-xs text-gray-400">@(HasFilter ? $"{shown} / {group.EntityCount}" : group.EntityCount.ToString())</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="inline-flex items-center gap-1 text-xs font-medium @StatusTextClass(group.WorstCurrentStatus)">
                                <span class="w-1.5 h-1.5 rounded-full @StatusDotClass(group.WorstCurrentStatus)"></span>
                                @StatusLabel(group.WorstCurrentStatus)
                            </span>
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                                 class="text-gray-400 transition-transform @(isOpen ? "rotate-180" : "")"><polyline points="6 9 12 15 18 9"/></svg>
                        </div>
                    </button>

                    @if (isOpen)
                    {
                        <div class="border-t border-gray-100 divide-y divide-gray-100">
                            @foreach (var entity in FilteredEntities(group))
                            {
                                <div class="px-4 py-3">
                                    <div class="flex items-center justify-between mb-2">
                                        <div class="flex items-center gap-2">
                                            <span class="inline-flex items-center gap-1 text-xs font-medium @StatusTextClass(entity.CurrentStatus)">
                                                <span class="w-1.5 h-1.5 rounded-full @StatusDotClass(entity.CurrentStatus)"></span>
                                            </span>
                                            <span class="text-sm font-medium text-gray-900">@entity.Name</span>
                                        </div>
                                        <span class="text-xs text-gray-400">@(HasData(entity) ? $"{entity.UptimePercent}% uptime" : "No data")</span>
                                    </div>

                                    <!-- 30-day bar -->
                                    <div class="flex gap-0.5 items-stretch">
                                        @foreach (var day in entity.Days)
                                        {
                                            var isDayOpen = openEntityId == entity.EntityId && openDate == day.Date;
                                            <button @onclick="() => ToggleDay(entity.EntityId, day.Date)"
                                                    title="@($"{day.Date:MMM d} — {(day.Status.HasValue ? StatusLabel(day.Status.Value) : "No data")}")"
                                                    class="flex-1 h-8 rounded-sm cursor-pointer hover:opacity-80 @DayCellClass(day.Status) @(isDayOpen ? "ring-2 ring-offset-1 ring-indigo-400" : "")"></button>
                                        }
                                    </div>

                                    @if (openEntityId == entity.EntityId && openDate.HasValue)
                                    {
                                        <div class="mt-3 rounded-md border border-gray-200 bg-gray-50 p-3">
                                            <div class="text-xs font-semibold text-gray-700 mb-2">@openDate.Value.ToString("MMMM d, yyyy") — events (UTC)</div>
                                            @if (dayLoading)
                                            {
                                                <div class="text-xs text-gray-500">Loading…</div>
                                            }
                                            else if (!dayEvents.Any())
                                            {
                                                <div class="text-xs text-gray-500">No events recorded this day.</div>
                                            }
                                            else
                                            {
                                                <ul class="space-y-1">
                                                    @foreach (var ev in dayEvents)
                                                    {
                                                        <li class="flex items-center gap-3 text-xs">
                                                            <span class="text-gray-400 tabular-nums w-12">@ev.CheckedAt.ToString("HH:mm")</span>
                                                            <span class="inline-flex items-center gap-1 font-medium @StatusTextClass(ev.Status)">
                                                                <span class="w-1.5 h-1.5 rounded-full @StatusDotClass(ev.Status)"></span>
                                                                @StatusLabel(ev.Status)
                                                            </span>
                                                            @if (ev.ResponseTime.HasValue)
                                                            {
                                                                <span class="text-gray-400">@($"{ev.ResponseTime.Value:0} ms")</span>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(ev.StatusMessage))
                                                            {
                                                                <span class="text-gray-600 truncate">@ev.StatusMessage</span>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private StatusOverviewDto? overview;
    private bool isLoading = true;

    private readonly HashSet<AssetType> expanded = new();

    private string filter = "";
    private bool HasFilter => !string.IsNullOrWhiteSpace(filter);

    private string? openEntityId;
    private DateTime? openDate;
    private List<StatusDayEventDto> dayEvents = new();
    private bool dayLoading;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var companyId = StateContainer.Company?.Id;
        if (string.IsNullOrEmpty(companyId)) { isLoading = false; return; }

        isLoading = true;
        overview = await OverviewService.GetOverviewAsync(companyId, 30);
        isLoading = false;
    }

    private async Task Reload()
    {
        openEntityId = null;
        openDate = null;
        await Load();
    }

    private void Toggle(AssetType type)
    {
        if (!expanded.Remove(type)) expanded.Add(type);
    }

    private void OnFilterChanged(ChangeEventArgs e) => filter = e.Value?.ToString() ?? "";

    private void ClearFilter() => filter = "";

    private IEnumerable<StatusOverviewTypeGroup> FilteredGroups()
    {
        if (!HasFilter) return overview!.Groups;
        return overview!.Groups.Where(g => FilteredEntities(g).Any());
    }

    private IEnumerable<StatusOverviewEntity> FilteredEntities(StatusOverviewTypeGroup group)
    {
        if (!HasFilter) return group.Entities;
        var f = filter.Trim();
        return group.Entities.Where(e => e.Name.Contains(f, StringComparison.OrdinalIgnoreCase));
    }

    private async Task ToggleDay(string entityId, DateTime date)
    {
        // Clicking the open cell again closes it.
        if (openEntityId == entityId && openDate == date)
        {
            openEntityId = null;
            openDate = null;
            dayEvents = new();
            return;
        }

        openEntityId = entityId;
        openDate = date;
        dayEvents = new();
        dayLoading = true;

        var companyId = StateContainer.Company?.Id;
        if (!string.IsNullOrEmpty(companyId))
            dayEvents = await OverviewService.GetDayEventsAsync(companyId, entityId, date);

        dayLoading = false;
    }

    private static bool HasData(StatusOverviewEntity e) => e.Days.Any(d => d.Status.HasValue);

    private (string Bg, string Border, string Dot, string Text, string Message) GetBanner()
    {
        var all = overview!.Groups.SelectMany(g => g.Entities).ToList();
        var down = all.Count(e => e.CurrentStatus is AssetStatus.Offline or AssetStatus.Error);
        var degraded = all.Count(e => e.CurrentStatus is AssetStatus.Degraded or AssetStatus.Maintenance);

        if (down > 0)
            return ("bg-red-50", "border-red-200", "bg-red-500", "text-red-700",
                $"{down} component{(down == 1 ? "" : "s")} down{(degraded > 0 ? $", {degraded} degraded" : "")}");
        if (degraded > 0)
            return ("bg-yellow-50", "border-yellow-200", "bg-yellow-500", "text-yellow-700",
                $"{degraded} component{(degraded == 1 ? "" : "s")} degraded");
        return ("bg-green-50", "border-green-200", "bg-green-500", "text-green-700", "All systems operational");
    }

    private static string DayCellClass(AssetStatus? status) => status switch
    {
        AssetStatus.Online => "bg-green-500",
        AssetStatus.Offline => "bg-red-500",
        AssetStatus.Error => "bg-red-500",
        AssetStatus.Degraded => "bg-yellow-500",
        AssetStatus.Maintenance => "bg-yellow-500",
        AssetStatus.Unknown => "bg-gray-300",
        null => "bg-gray-200",
        _ => "bg-gray-200"
    };

    private static string StatusTextClass(AssetStatus status) => status switch
    {
        AssetStatus.Online => "text-green-700",
        AssetStatus.Offline => "text-red-700",
        AssetStatus.Error => "text-red-700",
        AssetStatus.Degraded => "text-yellow-700",
        AssetStatus.Maintenance => "text-blue-700",
        _ => "text-gray-500"
    };

    private static string StatusDotClass(AssetStatus status) => status switch
    {
        AssetStatus.Online => "bg-green-500",
        AssetStatus.Offline => "bg-red-500",
        AssetStatus.Error => "bg-red-500",
        AssetStatus.Degraded => "bg-yellow-500",
        AssetStatus.Maintenance => "bg-blue-500",
        _ => "bg-gray-400"
    };

    private static string StatusLabel(AssetStatus status) => status.ToString();

    private static string TypeIcon(AssetType type) => type switch
    {
        AssetType.Server => "🖥️",
        AssetType.Database => "🗄️",
        AssetType.Report => "📊",
        AssetType.Dataset => "📈",
        AssetType.DataPipeline => "🔄",
        AssetType.Table => "📋",
        AssetType.DataJob => "⚙️",
        _ => "📦"
    };
}

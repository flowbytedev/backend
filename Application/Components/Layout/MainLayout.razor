@inherits LayoutComponentBase
@using System.Security.Claims
@using Application.Shared.Services.Org
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@inject StateContainer _stateContainer
@inject ICompanyService _companyService
@inject IConfiguration _configuration

<div class="al-root">
    <header class="al-header">
        <div class="al-brand">
            <div class="al-brand-icon">D</div>
            <span class="al-brand-name">DATA APP</span>
        </div>
        <div class="al-spacer"></div>
        @if (_stateContainer.Company != null)
        {
            @if (memberCompanies.Count > 1)
            {
                <details class="al-company-switch">
                    <summary class="al-company-badge al-company-badge-btn">
                        <span class="al-company-dot"></span>
                        <span class="al-company-current">@(_stateContainer.Company.Name ?? _stateContainer.Company.Id)</span>
                        <svg class="al-company-caret" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="al-company-menu">
                        <div class="al-company-menu-head">Switch company</div>
                        @foreach (var c in memberCompanies)
                        {
                            var isCurrent = c.Id == _stateContainer.Company.Id;
                            var url = CompanyUrl(c.Id);
                            <a class="al-company-item @(isCurrent ? "al-company-item-on" : "")"
                               href="@url"
                               onclick="event.preventDefault(); window.location.assign('@url');">
                                <span class="al-company-dot"></span>
                                <span class="al-company-item-text">
                                    <span class="al-company-item-name">@(c.Name ?? c.Id)</span>
                                    <span class="al-company-item-id">@c.Id</span>
                                </span>
                                @if (isCurrent)
                                {
                                    <svg class="al-company-check" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                }
                            </a>
                        }
                    </div>
                </details>
            }
            else
            {
                <div class="al-company-badge">
                    <span class="al-company-dot"></span>
                    @(_stateContainer.Company.Name ?? _stateContainer.Company.Id)
                </div>
            }
        }
        <WhatsNewPanel />
        <button class="al-hamburger" type="button" onclick="document.body.classList.toggle('nav-open')" aria-label="Toggle menu">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>
    </header>

    <div class="al-body">
        <NavMenu />
        <main class="al-main">
            @Body
        </main>
    </div>

    <footer class="al-footer">
        <span>Built with ❤️ by @companyName</span>
    </footer>
</div>

<CommandPalette />

<FluentToastProvider MaxToastCount="10" @rendermode="@RenderMode.InteractiveWebAssembly" />
<FluentDialogProvider @rendermode="@RenderMode.InteractiveWebAssembly" />
<FluentMenuProvider @rendermode="@RenderMode.InteractiveWebAssembly" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
    private string companyName = string.Empty;
    private List<Company> memberCompanies = new();

    protected override async Task OnInitializedAsync()
    {
        companyName = _configuration["CompanyName"] ?? "Flowbyte";
        var currentUserId = await GetUserId();
        if (currentUserId is null) return;

        // Companies this user belongs to — powers the company switcher.
        try { memberCompanies = await _companyService.GetCompanies(currentUserId) ?? new(); }
        catch (InvalidOperationException e) { Console.WriteLine(e.Message); }

        var uri = new Uri(_navigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("c", out var companyId))
        {
            _stateContainer.Company = await _companyService.GetCompany(companyId);
        }
        else
        {
            var company = memberCompanies.FirstOrDefault();
            if (company is null) return;
            _stateContainer.Company = company;
            var newUri = QueryHelpers.AddQueryString(uri.AbsoluteUri, "c", company.Id);
            _navigationManager.NavigateTo(newUri);
        }

        _stateContainer.OnChange += StateHasChanged;
    }

    // Current path with the "c" (company) query param swapped, other params preserved.
    private string CompanyUrl(string? id)
    {
        var uri = new Uri(_navigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query)
            .Where(kv => kv.Key != "c")
            .ToDictionary(kv => kv.Key, kv => kv.Value.ToString());
        query["c"] = id ?? string.Empty;
        return QueryHelpers.AddQueryString(uri.GetLeftPart(UriPartial.Path), query);
    }

    private async Task<string?> GetUserId()
    {
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is not null && user.Identity.IsAuthenticated)
            return user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return null;
    }
}